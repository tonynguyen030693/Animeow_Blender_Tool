global proc ukrt_w1() 
{
    int $w_val =`checkBox -q -v  CanneleSize`;
    if ($w_val==0) 
      { 
      window -e -w 175 -h 420  ILY_Natalie_UI;
      checkBox -e -v 1  CanneleSize; 
      } 
    else 
      {
      window -e -w 175 -h 20 ILY_Natalie_UI; 
      checkBox -e -v 0  CanneleSize;          
      }
}


