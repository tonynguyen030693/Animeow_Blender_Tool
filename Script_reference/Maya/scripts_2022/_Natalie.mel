global proc Import_REF()
{
    string $objs[] = `ls -sl`;
    for($i=0;$i < size($objs); $i++)
    {
            string $rNode = $objs[$i];
			$referenceNode = `referenceQuery -rfn $rNode`;
            file -importReference -referenceNode $referenceNode;   
    }

}
///////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////
global proc Remove_REF()
{
    string $objs_rmvref_2[] = `ls -sl`;
    for($i=0;$i < size($objs_rmvref_2); $i++)
    {
            string $rNode = $objs_rmvref_2[$i];
			$referenceNode = `referenceQuery -rfn $rNode`;
            file -removeReference -referenceNode $referenceNode;   
    }
}



///////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////

proc changeName(string $parent){
	string $buffer[];
	string $children[];

	// change name
	if (!`referenceQuery -inr $parent`){//non-referenced file
		if(`gmatch $parent "*:*"`){//use namespace
			$numTokens = `tokenize $parent ":" $buffer`;
			//print($parent + "=> " + $buffer[$numTokens-1] + "\n");
			$newname = `rename $parent $buffer[$numTokens-1]`;

			$children = `listRelatives -c -pa $newname`;
		}
		else
			$children = `listRelatives -c -pa $parent`;
	}
	else 
		$children = `listRelatives -c -pa $parent`;
 
	// change the chilrend's names
	if(size($children) == 0) return;
	
	for($i=0; $i < size($children); $i++){
		changeName($children[$i]);
	}

	return;
}

global proc RmvNamespace(){
	string $selected[] = `ls -selection`;
	for($i=0; $i < size($selected); $i++)
		changeName($selected[$i]);
	
	print ("dsRemovenamespace DONE!!!\n");
select -cl  ;
}



