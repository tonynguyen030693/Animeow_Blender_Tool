global proc ILY_Natalie_overrideTime(int $case)
{
switch ($case)

{
case  1 : 
editRenderLayerAdjustment "defaultRenderGlobals.startFrame";
setAttr "defaultRenderGlobals.startFrame" `floatField -query -value ILY_Natalie_StartFrame`;
break;


case  2 :
editRenderLayerAdjustment -remove "defaultRenderGlobals.startFrame";
break;

case  3 :
editRenderLayerAdjustment "defaultRenderGlobals.endFrame";
setAttr "defaultRenderGlobals.endFrame"  `floatField -query -value ILY_Natalie_EndFrame`;
break;

case  4 :
editRenderLayerAdjustment -remove "defaultRenderGlobals.endFrame";
break;
}
}
///////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////
global proc PlayBlastFrame(int $case)
{

switch ($case)
{

case 1 :

setAttr "defaultRenderGlobals.endFrame" `floatField  -query -value sc_play_EF`;
playbackOptions -aet `floatField  -query -value sc_play_EF`;
playbackOptions -min `getAttr "defaultRenderGlobals.startFrame"` 
		-max `floatField  -query -value sc_play_EF`;
currentTime `floatField  -query -value sc_play_SF`;
break;

case 2 :

setAttr "defaultRenderGlobals.startFrame" `floatField  -query -value sc_play_SF`;
playbackOptions -ast `floatField  -query -value sc_play_SF`;
playbackOptions -max `getAttr "defaultRenderGlobals.endFrame"` 
		-min `floatField  -query -value sc_play_SF`;
currentTime `floatField  -query -value sc_play_SF`;
break;

}
}
