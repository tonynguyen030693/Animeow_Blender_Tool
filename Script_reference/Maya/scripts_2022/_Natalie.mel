global proc MakeHole()
{

//Select Set FaceGrp
string $sel_MakeHole[] = `ls -sl`;
string $pick = $sel_MakeHole[0];
string $array[];
$array = stringToStringArray($pick, ".");
string $name = $array[0];

//Assign Invisible Face
polyHole -assignHole 1;
$createSetResult = `sets -name ($name+"_Invisible_FaceGrp")`;

}

global proc GET_faceID()
{

string $Target[]= `ls -sl`;
string $pick = $Target[0];
string $SetName = $pick+"_Invisible_FaceGrp";
string $Grp = $SetName+"*";
select -r -ne $Grp;

string $get[] = `ls -sl`;

	textScrollList -edit -removeAll invi_fsl;

	for ($i = 0; $i < size($get); $i++)
	{
		textScrollList
			-si "GET_faceID_Sel()"
			-doubleClickCommand "GET_faceID_Sel2()"
			-edit
			-append $get[$i]
			invi_fsl;
	} 
}


global proc GET_faceID_Sel()
{
string	$FaceID[] = `textScrollList -query -selectItem invi_fsl`;
select -r -ne $FaceID;
}

global proc GET_faceID_Sel2()
{
string	$FaceID2[] = `textScrollList -query -selectItem invi_fsl`;
select -r $FaceID2;
}


global proc GET_faceID_Remove()
{
textScrollList -edit -removeAll invi_fsl;
}


global proc NtoP()
{
nurbsToPoly -mnd 1  -ch 1 -f 2 -pt 1 -pc 4848 -chr 0.9 -ft 0.01 -mel 0.001 -d 0.01 -ut 3 -un 5 -vt 3 -vn 5 -uch 1 -ucr 0 -cht 0.2 -es 0 -ntr 0 -mrt 0 -uss 1 ;

}



global proc filterUI()
{
	string $getck =`checkBox -q -v FilterMODE`;
	if( $getck == 1)
	{
	button -e -bgc 0.2 0.2 0.2  button_mesh;
	button -e -bgc 0.2 0.2 0.2  button_curve;
	button -e -bgc 0.2 0.2 0.2  button_loc;
	button -e -l "Nurbs" -bgc 0.2 0.2 0.2  button_light;
	button -e -en 0 button_none;
	button -e -en 0 button_cam;
	button -e -en 0 button_joint;

	}
	else if ( $getck == 0)
	{
	button -e -bgc 0.4 0.4 0.4  button_mesh;
	button -e -bgc 0.4 0.4 0.4  button_curve;
	button -e -bgc 0.4 0.4 0.4  button_loc;
	button -e -l "Light" -bgc 0.4 0.4 0.4  button_light;
	button -e -en 1 button_none;
	button -e -en 1 button_cam;
	button -e -en 1 button_joint;

	}

}

global proc Filtering(int $mask)
{

	switch ( $mask)
	{

		case 1 :
		string $getck_c1 =`checkBox -q -v FilterMODE`; 
		if( $getck_c1 == 1)
		{
			string $sel_Filtering_1[] = `ls -sl -l -fl`;
			string $filter[] = `filterExpand -sm 12 $sel_Filtering_1`;
			select -r $filter;
		}
		else if( $getck_c1 == 0)
		{
				$currentPanel_1 = `getPanel -withFocus`; 
                string $panelType_filter_1 = `getPanel -to $currentPanel_1`; if ($panelType_filter_1 == "modelPanel") { 
                modelEditor -e -polymeshes ( !`modelEditor -q -polymeshes $currentPanel_1` ) $currentPanel_1; };

				$currentPanel_1_a = `getPanel -withFocus`; 
                string $panelType_filter_1_a = `getPanel -to $currentPanel_1_a`; if ($panelType_filter_1_a == "modelPanel") { 
                modelEditor -e -nurbsSurfaces ( !`modelEditor -q -nurbsSurfaces $currentPanel_1_a` ) $currentPanel_1_a; };
		}
		break;
	

		case 2 :
		string $getck_c2 =`checkBox -q -v FilterMODE`; 
		if( $getck_c2 == 1)
		{
			string $sel_Filtering_2[] = `ls -sl -l -fl`;
			string $filter[] = `filterExpand -sm 10 $sel_Filtering_2`;		
			select -r $filter;

		}
		else if( $getck_c2 == 0)
		{
			$currentPanel_2 = `getPanel -withFocus`; 
			string $panelType_filter_2 = `getPanel -to $currentPanel_2`; if ($panelType_filter_2 == "modelPanel") { 
                	modelEditor -e -lights ( !`modelEditor -q -lights $currentPanel_2` ) $currentPanel_2; };
		}
		break;
	

		case 3 :
		string $getck_c3 =`checkBox -q -v FilterMODE`; 
		if( $getck_c3 == 1)
		{
			string $sel_Filtering_3[] = `ls -sl -l -fl`;
			string $filter[] = `filterExpand -sm 9 $sel_Filtering_3`;
			select -r $filter;

		}
		else if( $getck_c3 == 0)
		{
			$currentPanel_3 = `getPanel -withFocus`; 
	                string $panelType_filter_3 = `getPanel -to $currentPanel_3`; if ($panelType_filter_3 == "modelPanel") { 
	                modelEditor -e -nurbsCurves  ( !`modelEditor -q -nurbsCurves  $currentPanel_3` ) $currentPanel_3; };
		}
		break;


		case 4 :

			$currentPanel_4 = `getPanel -withFocus`; 
	                string $panelType_filter_4 = `getPanel -to $currentPanel_4`; if ($panelType_filter_4 == "modelPanel") { 
	                modelEditor -e -cameras ( !`modelEditor -q -cameras $currentPanel_4` ) $currentPanel_4; };		
		break;


		case 5 :
		string $getck_c5 =`checkBox -q -v FilterMODE`; 
		if( $getck_c5 == 1)
		{
			string $sel_Filtering_5[] = `ls -sl -l -fl`;
			string $filter[] = `filterExpand -sm 22 $sel_Filtering_5`;
			select -r $filter;

		}
		else if( $getck_c5 == 0)
		{
			$currentPanel_5 = `getPanel -withFocus`; 
	                string $panelType_filter_5 = `getPanel -to $currentPanel_5`; if ($panelType_filter_5 == "modelPanel") { 
        	        modelEditor -e -locators ( !`modelEditor -q -locators $currentPanel_5` ) $currentPanel_5; };	
		}
		break;


		case 6 :

			$currentPanel_6 = `getPanel -withFocus`; 
	                string $panelType_filter_6 = `getPanel -to $currentPanel_6`; if ($panelType_filter_6 == "modelPanel") { 
        	        modelEditor -e -joints ( !`modelEditor -q -joints $currentPanel_6` ) $currentPanel_6; };	
		break;


		case 7 :
		{
		        string $currentPanel_7 = `getPanel -underPointer`;
    if ("" == $currentPanel_7) {
        $currentPanel_7 = `getPanel -withFocus`;
    }
    if ("" != $currentPanel_7) {
        string $panelType_filter_7 = `getPanel -typeOf $currentPanel_7`;
        if ($panelType_filter_7 ==  "modelPanel") {
            modelEditor -edit -displayAppearance "smoothShaded" -displayTextures off 
                -displayLights "default" $currentPanel_7;
        } else if (`isTrue "MayaCreatorExists"` && `scriptedPanel -exists $currentPanel_7` 
            && `scriptedPanel -query -type $currentPanel_7` == "dynPaintScriptedpanelType_filter_7") {
            dynPaintEditor -edit -displayTextures 0 -displayAppearance "smoothShaded"
                -displayLights "default" ;
        } else if ($panelType_filter_7 ==  "scriptedPanel") {
 			  string $cmd = "modelEditor -edit -displayAppearance \"smoothShaded\" -displayTextures off -displayLights \"default\" "; 
			  scriptedPanelRunTimeCmd( $cmd, $currentPanel_7 ); 
        }
    }


		$currentPanel_7 = `getPanel -withFocus`; 
                string $panelType_filter_7 = `getPanel -to $currentPanel_7`; if ($panelType_filter_7 == "modelPanel") { 
                modelEditor -e -allObjects ( !`modelEditor -q -polymeshes $currentPanel_7` ) $currentPanel_7; };
	}

}

}



