global proc render3_Smooth()
{

string $sel_render3_Smooth[] = `ls -sl -dag`;	
	string $each;	    
	HighQualityDisplay;
	setDisplaySmoothness 3;
	displaySmoothness -divisionsU 3 -divisionsV 3 -pointsWire 16 -pointsShaded 4 -polygonObject 3;
	subdivDisplaySmoothness -smoothness 3;
	for ($each in $sel_render3_Smooth)
	{
		setAttr ($each + ".displaySubdComps") 0;
		setAttr ($each + ".smoothLevel") 0;
		setAttr ($each + ".useSmoothPreviewForRender ") 0; 
		setAttr ($each + ".renderSmoothLevel ") 2; 

	}	



}

global proc Dside()
{
string $sel_Dside[] = `ls -sl -g -s -dag`;	
	for ($each in $sel_Dside)
	{
		$chk=`getAttr ($each+ ".doubleSided")`;
		
		if ($chk==1)
			{ 
		setAttr ($each + ".doubleSided") 0;
			}
		else
		setAttr ($each + ".doubleSided") 1;
	}	
	select $sel_Dside;
}




global proc BBOX_O ( int $cmd ) 
{


switch ( $cmd ) {

		case 1 :
		
/////////////toggle

string $sel_BBOX_O[] = `ls -sl -g -s -dag`;	
	for ($each in $sel_BBOX_O)
	{
		$chk=`getAttr ($each+ ".overrideEnabled")`;
		
		if ($chk==1)
			{ 
		setAttr ($each + ".overrideEnabled") 0;
		setAttr ($each + ".overrideLevelOfDetail") 0;
			}
		else
		setAttr ($each + ".overrideEnabled") 1;
		setAttr ($each + ".overrideLevelOfDetail") 1;
	}	
	select $sel_BBOX_O;

		break;


		case 2 :
/////////////BBox

string $sel_BBOX[] = `ls -sl -g -s -dag`;	
	for ($each in $sel_BBOX)
	{

		setAttr ($each + ".overrideEnabled") 1;
		setAttr ($each + ".overrideLevelOfDetail") 1;
	}	
	select $sel_BBOX;	

		break;


		case 3 :
/////////////BBox

string $sel_BBOX3[] = `ls -sl -g -s -dag`;	
	for ($each in $sel_BBOX3)
	{

		setAttr ($each + ".overrideEnabled") 0;
		setAttr ($each + ".overrideLevelOfDetail") 0;
	}	
	select $sel_BBOX3;	

		break;
}
}




