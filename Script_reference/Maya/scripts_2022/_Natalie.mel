

global proc RS_YetiFriend()
{
if (`window -q -exists RS_YetiFriend_UI`)deleteUI RS_YetiFriend_UI;
window -widthHeight 285 180  -maximizeButton 0 -mnb 1 -menuBar 0 -sizeable 0 -title "RS_YetiFriend" RS_YetiFriend_UI;

string $col =`columnLayout -adjustableColumn 1  -rowSpacing 1`;

rowColumnLayout -numberOfColumns 1 -cw 1 285;
separator -h 5 -style "in";
setParent $col;

rowColumnLayout -numberOfColumns 5 -cw 1 85 -cw 2 5 -cw 3 90 -cw 4 5 -cw 5 90 ;
button -l "Get GuideSet" -h 25 -w 75 -c "RS_YetiFriend_getCurveSET";
separator -h 20 -w 5 -style "none";
button -l "Get Shape" -h 20  -w 75 -c "RS_YetiFriend_getShapes";
separator -h 20 -w 5 -style "none";
text -l ": Curve to Groom" -h 20;

setParent $col;

rowColumnLayout -numberOfColumns 7 -cw 1 85 -cw 2 5 -cw 3 90 -cw 4 5 -cw 5 35 -cw 6 5 -cw 7 60 ;
textField -h 30 -tx "" YetiSet;
separator -h 30 -w 5 -style "none";
textField -h 30 -tx "" YetiMesh;
separator -h 30 -w 5 -style "none";
floatField -v 0.2 -pre 2 YetiWith;
separator -h 30 -w 5 -style "none";
button -l "Run" -c "RS_YetiFriendCMD(1)";

setParent $col;

rowColumnLayout -numberOfColumns 1 -cw 1 285;
separator -h 5 -style "in";
setParent $col;

rowColumnLayout -numberOfColumns 12 -cw 1 35 -cw 2 5  -cw 3 35 -cw 4 5 -cw 5 40 -cw 6 5 -cw 7 50 -cw 8 5 -cw 9 50 -cw 10 5 -cw 11 50;

iconTextButton -image1 "pgYeti_icon.png" -width 32 -height 32 -command ("pgYetiCreateOnMesh();") -annotation ("Create Yeti Node On Selected Mesh") YTButton1;
separator -h 30 -w 5 -style "none";

iconTextButton -image1 "pgYeti_curl_mask.png" -width 32 -height 32 -command ("pgYetiCreateGroomOnMesh();") -annotation ("Create Yeti Groom On Selected Mesh") YTButton2;
separator -h 30 -w 5 -style "none";

button -l "Graph" -width 40 -height 32 -command ("pgYetiTearOffGraphPanel();") -annotation ("Yeti Node Window") YTButton3;
separator -h 30 -w 35 -style "in";

button -l "Ren=1" -width 50 -height 32 -command ("RS_YetiFriendCMD(3);") -annotation ("Render Density to 1") YTButton4;
separator -h 30 -w 5 -style "out";

button -l "Disp=0.1" -width 50 -height 32 -command ("RS_YetiFriendCMD(4);") -annotation ("Display Density to 0.1") YTButton5;
separator -h 30 -w 5 -style "out";

button -l "Output" -width 50 -height 32 -command ("RS_YetiFriendCMD(5);") -annotation ("Display X") YTButton6;
separator -h 30 -w 5 -style "out";

setParent $col;

rowColumnLayout -numberOfColumns 1 -cw 1 285;
separator -h 5 -style "in";
setParent $col;

rowColumnLayout -numberOfColumns 5 -cw 1 85 -cw 2 5 -cw 3 90 -cw 4 5 -cw 5 90 ;
button -l "Get Yeti" -h 25 -c "RS_YetiFriend_getYeti";
separator -h 20 -w 5 -style "none";
button -l "Get Groom" -h 25 -c "RS_YetiFriend_getGroom";
separator -h 20 -w 5 -style "none";
text -l ": Yeti + Groom" -h 20;
setParent $col;


rowColumnLayout -numberOfColumns 5 -cw 1 85 -cw 2 5 -cw 3 90 -cw 4 45 -cw 5 60 ;
textField -h 30 -tx "" YetiNode;
separator -h 20 -w 5 -style "none";
textField -h 30 -tx "" YetiGroom;
separator -h 20 -style "out";
button -l "Run" -c "RS_YetiFriendCMD(2)";

setParent $col;


rowColumnLayout -numberOfColumns 1 -cw 1 285;
separator -h 5 -style "in";
setParent $col;


setParent ..;

showWindow RS_YetiFriend_UI;
pgYetiEnsurePluginLoaded(); 

}


//Get
 global proc RS_YetiFriend_getCurveSET()
{
string $getC_SET[] = `ls -sl -fl`;    
textField -e -tx $getC_SET[0] YetiSet;
}

global proc RS_YetiFriend_getShapes()
{
  //pickWalk -d down;
  string $selectedShapes[] = `listRelatives -s`;
  select $selectedShapes;   
  textField -e -tx $selectedShapes YetiMesh; 
}


global proc RS_YetiFriend_getYeti()
{
  string $selectedShapes[] = `listRelatives -s`;
  textField -e -tx $selectedShapes YetiNode; 
}

global proc RS_YetiFriend_getGroom()
{

  string $selectedShapes[] = `listRelatives -s`;
  textField -e -tx $selectedShapes YetiGroom; 
}

//Run

global proc RS_YetiFriendCMD(int $case)
{
  switch($case)
  {
    case 1 :
        string $C_set = `textField -q -tx YetiSet`;        
        string $M_Shape = `textField -q -tx YetiMesh`; 
        pgYetiConvertGuideSetToGroom( $C_set, $M_Shape, "0.2" );   
    break;
    
    case 2 :
        string $Cur_Groom =`textField -q -tx YetiGroom`; 
        string $My_Yeti =`textField -q -tx YetiNode`;
        pgYetiAddGroom($Cur_Groom, $My_Yeti); 
        textField -e -tx "연결완료" YetiGroom; 
    break;
    
    case 3 :
    string $My_Yeti1 =`textField -q -tx YetiNode`;
    setAttr ($My_Yeti1 + ".renderDensity") 1;
    break;

    case 4 :
    string $My_Yeti2 =`textField -q -tx YetiNode`;    
      $chakeValue1 = `getAttr ($My_Yeti + ".viewportDensity")`;
      if ($chakeValue1 == 1)
      {
      setAttr ($My_Yeti2 + ".viewportDensity") 0.1;       
      }
      else 
      {
          setAttr ($My_Yeti2 + ".viewportDensity") 1;   
      }        
    break;    

    case 5 :
    string $My_Yeti3 =`textField -q -tx YetiNode`;
      $chakeValue = `getAttr ($My_Yeti + ".displayOutput")`;
      if ($chakeValue == 1)
      {
      setAttr ($My_Yeti3 + ".displayOutput") 0;       
      }
      else 
      {
          setAttr ($My_Yeti3 + ".displayOutput") 1;   
      } 
    break;      
  }   
}





