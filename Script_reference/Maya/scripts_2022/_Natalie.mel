global proc StoneColdKiller (int $cn)
{
string $Target1="*:defaultRenderLayer";
string $Target2="*:*:defaultRenderLayer";
string $Target3="*:*:*:defaultRenderLayer";

switch ( $cn) {

		case 1 :

			select -r $Target1; select -add $Target2;
			delete; 
			break;

		case 2:
			select -r $Target3;
			delete;
			break;
		}
}

///////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////
global proc xsiviva()
{
$rememberSelection=`ls -sl`;
string $obj;
int $hidden=1;		// assume all object are hidden
for ( $obj in $rememberSelection ) {
		// loops through all selected objects, if one is visible, break out
	string $myattrib=$obj+".visibility";
	int $objvis=`getAttr $myattrib`;
	if ($objvis==1) {
		$hidden=0;
		break;
	}
}
if ($hidden==0) {
	hide $rememberSelection;
}
else {
	showHidden $rememberSelection;
}
select $rememberSelection;
}

///////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////

global proc snap_cmd_X()
{
//position smap
string $sel_trA[] = `ls -sl`;
float $trA[] = `xform -q -ws -t $sel_trA[0]`;
float $rpA[] = `xform -q -rp $sel_trA[1]`;
float $rpB[] = `xform -q -rp $sel_trA[0]`;

xform -ws -t 
($trA[0] + $rpA[0] - $rpB[0]) 
($trA[1] + $rpA[1] - $rpB[1]) 
($trA[2] + $rpA[2] - $rpB[2]) $sel_trA[1];

//rotate snap
string $sel_rpA[] = `ls -sl`;
float $rpA_r[] = `xform -q -ro $sel_rpA[0]`;
float $rpB_r[] = `xform -q -ro $sel_rpA[1]`;

xform -ro 
($rpB_r[0] - $rpB_r[0] + $rpA_r[0]) 
($rpB_r[1] - $rpB_r[1] + $rpA_r[1]) 
($rpB_r[2] - $rpB_r[2] + $rpA_r[2]) $sel_rpA[1];
}

global proc snap_cmd()
{
//position smap
string $sel_position[] = `ls -sl`;
float $trA_ps[] = `xform -q -ws -t $sel_position[1]`;
float $rpA_ps[] = `xform -q -rp $sel_position[1]`;
float $rpB_ps[] = `xform -q -rp $sel_position[0]`;

xform -ws -t 
($trA_ps[0] + $rpA_ps[0] - $rpB_ps[0]) 
($trA_ps[1] + $rpA_ps[1] - $rpB_ps[1]) 
($trA_ps[2] + $rpA_ps[2] - $rpB_ps[2]) $sel_position[0];

//rotate snap
string $sel_rotate[] = `ls -sl`;
float $rpA_rs[] = `xform -q -ro $sel_rotate[1]`;
float $rpB_rs[] = `xform -q -ro $sel_rotate[0]`;

xform -ro 
($rpB_rs[0] - $rpB_rs[0] + $rpA_rs[0]) 
($rpB_rs[1] - $rpB_rs[1] + $rpA_rs[1]) 
($rpB_rs[2] - $rpB_rs[2] + $rpA_rs[2]) $sel_rotate[0];
}


