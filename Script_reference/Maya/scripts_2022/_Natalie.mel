global proc lazyCmd()

{


string $renderLayers[] = { 

			"Matte",
			"Passes", 
 			"OL",
			"Cha",
			"Bg_Depth",
			"Bg_Occ",
			"Bg"

		};

int $tasks[], $i = 0 ;

string $listAll[] = `lsType "renderLayer"`;

for ( $renderLayer in $renderLayers ) $tasks[$i++] = 1;

$i = 0;

for ( $renderLayer in $renderLayers ) {

	for ( $chk in $listAll ) if ( $renderLayer == $chk ) $tasks[$i] = 0;

	$i++;

}
print ("이미 다 만들었습니다 :D\n");
$i = 0;

for ( $apply in $tasks ) {

	$i++;

	if ( $apply == 1 ) startMakeRenderLayer $i;

}

}


global proc startMakeRenderLayer ( int $commandNumbers ) {

////Give Custom Name to 
string $ma = "OL";
string $mb = "Cha";
string $mc = "Bg";
string $md = "Bg_Occ";
string $me = "Bg_Depth"; 
string $mf = "Matte";
string $mg = "Passes";
 
switch ( $commandNumbers ) {

		case 1 :
		
		createRenderLayer -name $ma  -noRecurse `ls -selection`;

		break;


		case 2 :
		createRenderLayer -name $mb -noRecurse `ls -selection`;

		break;


		case 3 :
		createRenderLayer -name $mc -noRecurse `ls -selection`;

		break;

		case 4 :

		createRenderLayer -name $md -noRecurse `ls -selection`;
		
		break;



		case 5 :

		createRenderLayer -name $me -noRecurse `ls -selection`;
		break;


		case 6 :

		createRenderLayer -name $mf -noRecurse `ls -selection`;
		break;


		case 7 :

		createRenderLayer -name $mg -noRecurse `ls -selection`;
		renderLayerEditorRenderable RenderLayerTab "defaultRenderLayer" 0;
		break;
		
		

}

}

