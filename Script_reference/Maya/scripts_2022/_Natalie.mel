global proc RenderStats(int $type)
{


switch ($type)

{
	case 1:
	string $sel_RenderStats_1[] = `ls -sl -dag`;
	for ($each in $sel_RenderStats_1)
	{
		if (`attributeQuery -node $each -exists "primaryVisibility"`)
		{
			setAttr ($each + ".primaryVisibility") 0;
			//setAttr ($each + ".receiveShadows") 0;
        		}
    	}
	break;

	case 2:
	string $sel_RenderStats_2[] = `ls -sl -dag`;
	for ($each in $sel_RenderStats_2)
	{
		if (`attributeQuery -node $each -exists "primaryVisibility"`)
		{
			setAttr ($each + ".primaryVisibility") 1;
			//setAttr ($each + ".receiveShadows") 1;
        		}
    	}
	break;


	case 3:
	string $sel_RenderStats_3[] = `ls -sl -dag`;
	for ($each in $sel_RenderStats_3)
	{
		if (`attributeQuery -node $each -exists "primaryVisibility"`)
		{
			setAttr ($each + ".castsShadows") 0;
        		}
    	}
	break;

	case 4:
	string $sel_RenderStats_4[] = `ls -sl -dag`;
	for ($each in $sel_RenderStats_4)
	{
		if (`attributeQuery -node $each -exists "primaryVisibility"`)
		{
			setAttr ($each + ".castsShadows") 1;
        		}
    	}
	break;




}

}


