global proc ILY_Natalie_attachCommands()
{

    $ILY_NatalieOps = ls("defaultRenderGlobals");

    if (size($ILY_NatalieOps) == 1 && $ILY_NatalieOps[0] == "defaultRenderGlobals")
    {
        if ( `attributeQuery -node defaultRenderGlobals -exists "endFrame"` )
        {

		connectControl sc_play_SF "defaultRenderGlobals.startFrame";
		connectControl sc_play_EF "defaultRenderGlobals.endFrame";		


        }
    }
	else
    {
warning "\n";
    }

}

