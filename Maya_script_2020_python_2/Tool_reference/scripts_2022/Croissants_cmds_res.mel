////////////////////////////////////////////////Call Tools


   
global proc Toggle_Natalie()
{
      string $winNatalie = "ILY_Natalie_UI";
      int $getVis_Natalie = `window -q -ex $winNatalie`;
   
      if ($getVis_Natalie == 0) 
      {
      source "_Natalie.mel"; ILY_Natalie();
      }

      else 
      {
         int $getWin_Natalie =`window  -q -vis  $winNatalie`;
         if ($getWin_Natalie == 0)
          {window  -e -vis 1  $winNatalie;}
         else
          {window  -e -vis 0  $winNatalie;} 	 
      } 

      $cPostion =`window -q -tlc  Croissants`; 
      int $iloveu_natalie = $cPostion[1] +465;
      window -e -tlc $cPostion[0] $iloveu_natalie ILY_Natalie_UI;
}  


/////Deadline CMD
global proc DL_submitJob()
{

  string $Lib_Path =`textField -q -tx  textField_Rule_02`;
  $DL_submitJobPath = `workspace -q -fn`;
  string $DL_submitJobMelPath = $DL_submitJobPath+"/"+ $Lib_Path + "/Scripts/submitJob.mel";
  string $DL_submitJobpath = "source " + "\""+$DL_submitJobMelPath+"\"";
  eval($DL_submitJobpath);  
}


global proc PipeLine_Call()
{
  $ppPath = `workspace -q -fn`;
  string $Lib_Path =`textField -q -tx  textField_Rule_02`;
  string $callMelPath = $ppPath+"/" +  $Lib_Path + "/Scripts/PipeLine.mel";
  string $fpath = "source " + "\""+$callMelPath+"\"";
  eval($fpath);
}

