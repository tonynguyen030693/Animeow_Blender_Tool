global int $pInitTimes;

proc int VERBOSE()
{
	return 1;
}

proc int RUNTIME()
{
	return 1;
}

// 開啟(關閉) MotionBlur Mode
proc int MotionBlurMode()
{
	return 1;
}

// 2009.02.18 新增：修正顯示的框框
proc AdjustCameraFrame()
{
	// 依照 Model Panel 改變 Camera
	string $ModelPane = `paneLayout -q -pane1 viewPanes`;
	string $Camera = `modelPanel -q -camera $ModelPane`;
	
	// 直接檢查檔名！
	string $FileName = basenameEx(`file -q -sn`);
		
	// ================================================
	// FOR FB USE
	if(size(`match "^FB" $FileName`))
	{
		camera -e 
			-displaySafeAction on 
			-displaySafeTitle off 
			-displayResolution on 
		$Camera;
	}
	// ================================================
}

// 這個部份還要再調整 ===========================
// 回傳 AliasName
proc string ReturnAliasName()
{
	return "AB";
}

// 取得 Episode Number
proc string CGCG_GetEpisode()
{
	string $ProjectAliasName = ReturnAliasName();	// Ex: AB
	string $Episode;
	
	string $Basename = basenameEx(`file -q -sn`);
	if($Basename != "")
	{
		// 目前適用
		// Angelina : AB001, AB001A, 
		$Episode = `match ($ProjectAliasName+"[0-9]+[^\-]*") $Basename`;
	}
	if($Episode == "") $Episode = "UNKNOWN";
	return $Episode;
}

