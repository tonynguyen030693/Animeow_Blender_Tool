  textScrollList  -e -bgc 0.4 0.5 0.2 Croissants_Ani_List;    
  textScrollList  -e -bgc 0.32 0.15 0.35 Croissants_Lit_List;

  textScrollList  -e -bgc 0.1 0.22 0.33 Croissants_Assets_List_1;
      
  optionMenu -e -bgc 0.4 0.5 0.2 Croissants_Assets;
  optionMenu -e -bgc 0.32 0.15 0.35 Croissants_Assets_2;
  optionMenu -e -bgc 0.1 0.22 0.33 Croissants_Assets_3;  
}

global  proc UI_dc_CC(int $case)
{
  switch($case)
      {
        case 1 :
          textScrollList -e -da Croissants_Lit_List;
        break;
        
        case 2 :
          textScrollList -e -da Croissants_Ani_List;
        break;
      }    
}
  
global proc get_CurrUnit_CC()
{
  string $xxx =`currentUnit -q -time`;
  if($xxx == "ntsc")
    {textField -e -tx  "30-FPS"  Croissants_msg;   }
    else if($xxx == "pal")
    {textField -e -tx  "25-FPS"  Croissants_msg;   }
    else if($xxx == "ntscf")
    {textField -e -tx  "60-FPS"  Croissants_msg;   }
    else if($xxx == "film")
    {textField -e -tx  "24-FPS"  Croissants_msg;   }
    else
    {textField -e -tx  "Others-FPS"  Croissants_msg;   }         
}

global proc UI_ReFrash_CC(int $case)
{
  switch($case)
  {
  case 1 :     
   catchQuiet(Croissants_get_EPs(3));
   //catchQuiet(Croissants_get_EPs(4));
   catchQuiet(Croissants_Check_Z_Source());
   catchQuiet(Croissants_logStats(5));
   catchQuiet(Croissants_logStats(6));
 
  break;
  
  case 2 :
   catchQuiet(Croissants_assets_OM(2));
   catchQuiet(Croissants_assets_OM(3));    
  break;
  
  case 3 :
  //catchQuiet(Croissants_Mod_OM(2));
  catchQuiet(Croissants_Mod_OM(3));

  break; 
  }
}



global proc GCAL()
{
//Episodic Type or Not
  int $EpisodicG = `checkBox -q -v Episodic`;
  if($EpisodicG == 0)
  {
    Get_Croissants_AssetsList(3);
  }
  else
  Get_Croissants_AssetsList(31);
}


global proc Croissants_get_PL(int $case)
{
//GET Project List
    string $Croissants_ProjectList = dirname(`pluginInfo -query -path "Croissants"`)+"/../scripts/_Project_List.ini";
    $Croissants_fileId = `fopen $Croissants_ProjectList "r"` ;  
    string $Croissants_data = `fread $Croissants_fileId $Croissants_data` ; 

    //get all data
    string $Croissants_dataArray[] ;  
    $Croissants_dataArray = stringToStringArray($Croissants_data, ","); 

    //Add custom Project from Field
    string $newPL=`textField -q -tx  Croissants_wks`;
    string $MelStylePL = substituteAllString($newPL, "\\", "/");  
    

  switch($case)
  {
  //UI
  case 1 :
        if(`window -q -ex "PR_list_UI"`)deleteUI("PR_list_UI");
        window -rtf true -w 304 -t "Project List" -h 30 -tb true -s false -bgc  0.1 0.1 0.1 -tlb true -mb true "PR_list_UI";
        gridLayout -cw 304 -w 304 -nc 1 -h 32 -ch 32;
        optionMenu -cc "Croissants_get_PL(2);" "Croissants_PL";
        showWindow "PR_list_UI";

        $crPostion =`window -q -tlc  Croissants`; 
        int $mag_cr = $crPostion[0] -100;
        window -e -tlc $mag_cr $crPostion[1] -vis 1 PR_list_UI;  
    
        $menuItems_Croissants = `optionMenu -q -itemListLong Croissants_PL`;
          if(size($menuItems_Croissants) != 0)
          {deleteUI($menuItems_Croissants);}
        
          string $pree_list_sort[];
          $pree_list_sort=sort($Croissants_dataArray);

          for ($i = 1; $i < size($pree_list_sort); $i++)
          {           
          menuItem -l $pree_list_sort[$i] -p Croissants_PL;
          }
  break;
  
  //SET Project 
  case 2 :      
        string $ProjectName=`optionMenu -q -v Croissants_PL`;  

        int $Project_checkFolder =`file -q -exists $ProjectName`;
        if($Project_checkFolder != 0)
        {
        setProject $ProjectName;
        Croissants_reUI();

        deleteUI PR_list_UI;
        get_CurrUnit_CC;
        }
        else
        {
            string $msg = "The project folder is not in the path. Do you want to create a folder and set it up?";
            $response_OKSet = `confirmDialog -t "Nonexistent Directory" -m $msg -ma "left" -b "Yes" -b "No" -db "Yes" -cb "No" -ds "No" `;  
            if( $response_OKSet == "Yes" ) 
              {
              sysFile -makeDir $ProjectName;
              setProject $ProjectName;
              Croissants_reUI();
             
              deleteUI PR_list_UI;               
              }
             else
             {
                 print "Cancle...";
             }        
        }
        Croissants_get_EPs(100);
        Croissants_get_EPs(101);
  break; 


 //Add project to List file
  case 3 :
          string $samsam =`match $MelStylePL $Croissants_data`; 
          int $mat =`gmatch $samsam $MelStylePL`;
          if ($mat == 1)
          {
             textField -e -tx "Already in the list." Croissants_msg;
          }
          else
          {    
          string $combine = $MelStylePL + "," +$Croissants_data;
          $Croissants_fileId = `fopen $Croissants_ProjectList "w"` ;  
          fprint $Croissants_fileId $combine;
          fclose $Croissants_fileId;
          }
          textField -e -tx "..." Croissants_wks;
          Croissants_get_PL(1);       
  break;
  
  //remove project of List file
  case 4 :
          string $samsam4 =`match $MelStylePL $Croissants_data`; 
          int $mat4 =`gmatch $samsam4 $MelStylePL`;
          if ($mat4 == 1)
          {
            string $remove = $MelStylePL+",";  
            string $substitute = substituteAllString($Croissants_data, $remove, "");   
            $Croissants_fileId = `fopen $Croissants_ProjectList "w"` ;  
            fprint $Croissants_fileId $substitute;
            fclose $Croissants_fileId; 
            textField -e -tx "..." Croissants_wks;
            Croissants_get_PL(1); 
          }
          else
          {    
            textField -e -tx "Not on the list." Croissants_msg; 
          }     
  break;      
  }
  
  Croissant_setWorkspace;
}  


global proc FrameUTIL_CC(int $case)
{
  switch($case)
  {
    case 1 :
      projectCamReN();
    break;
    
    case 2 :
      Croissants_PlayBlastFrame(1);
      Croissants_PlayBlastFrame(2);
    break;  
  }

}

global proc GET_Croissants_TIME()
{
  int $Croissants_pMin = `playbackOptions -q -min`;
  int $Croissants_pMax = `playbackOptions -q -max`;
  intField -e -v $Croissants_pMax  Croissants_A02_ef; 
  intField -e -v $Croissants_pMin  Croissants_A01_sf; 
}

global proc Croissants_PlayBlastFrame(int $case)
{
    switch ($case)
    {    
    case 1 :    
      $EndFrame = `intField  -q -v Croissants_A02_ef`;
      setAttr "defaultRenderGlobals.endFrame" $EndFrame;
      playbackOptions -aet $EndFrame;
      playbackOptions -min `getAttr "defaultRenderGlobals.startFrame"` -max $EndFrame;    
    break;
    
    case 2 :
      $StartFrame = `intField  -q -v Croissants_A01_sf`;
      setAttr "defaultRenderGlobals.startFrame" $StartFrame;
      playbackOptions -ast $StartFrame;
      playbackOptions -max `getAttr "defaultRenderGlobals.endFrame"` -min $StartFrame;    
    break;
    }
}  

global proc Croissants_Prefix()
{
  string $EPs=`optionMenu -q -v Croissants_EP`;
  string $CUTs=`optionMenu -q -v Croissants_CUT`;
  string $Croissants_scinfo = `file -q -namespace`;

  string $RenVersion = "R001";        
  string $scene_D_Label = $EPs + "/" + $CUTs; 
  string $scene_F_Label = $EPs + "_" + $CUTs;

  $maya_versionLabel = "defaultRenderGlobals.renderVersion";            
  $maya_fileNamePreFix = "defaultRenderGlobals.imageFilePrefix";

  string $c_renderer = currentRenderer();
    if( $c_renderer != "vray" )
    {
      string $_preFix = $scene_D_Label + "/" + "<Version>" + "/" + "<RenderLayer>" + "/" +$scene_F_Label + "_" + "<RenderLayer>";
      setAttr -type "string"  $maya_versionLabel $RenVersion;
      setAttr -type "string"  $maya_fileNamePreFix $_preFix;
    }
    else
    {  
      $vray_fileNamePreFix = "vraySettings.fileNamePrefix";
      string $_preFix_VRay = $scene_D_Label + "/" + "<Version>" + "/" + "<Layer>" + "/" +$scene_F_Label + "_" + "<Layer>";
      setAttr -type "string"  $vray_fileNamePreFix $_preFix_VRay;
      setAttr -type "string"  $maya_versionLabel $RenVersion;
    }

  Croissants_PlayBlastFrame(1);
  Croissants_PlayBlastFrame(2);

}

global proc copyTime()
{
  int $S_time = `intField -q -v Croissants_A01_sf`;
  intField -e -v $S_time Croissants_A02_ef;  
}

global proc projectCamReN()
{
string $gets[] =`ls -sl`;

$Path = `workspace -q -fn`;
string $init[]= `getFileList -folder $Path -filespec "*.ini"`;
string $ini_gets = $init[0]; 
string $G_I[] = stringToStringArray($ini_gets, ".");


string $EP_N=`optionMenu -q -v Croissants_EP`;
string $Cut_N = `optionMenu -q -v Croissants_CUT`;
string $prEF =`intField -q -v Croissants_A02_ef`; 
string $prSF =`intField -q -v Croissants_A01_sf`; 
string $camName = $G_I[0] +"_" + $Cut_N + "_" + $prSF + "_" + $prEF +"_Cam";
rename $gets[0] $camName;

}  


global proc read_python()
{
  //string $cmd_1 = "import _Chocolat\nreload(_Chocolat)";
  string $cmd_1 = "import _Chocolat";
  python($cmd_1);
}



global proc Croissants_Check_Z_Source()
{
    string $Croissants_check_Z = `textScrollList -q -ni Croissants_src_List`;
    int $valueZ = $Croissants_check_Z;
      if ($valueZ == 0)
      {
        button -e -bgc 0.5 0.5 0.5 checksource_Btt;                                      
      } 
      else 
      {
        button -e -bgc 0.9 0.3 0.11 checksource_Btt;          
      }   
}    

