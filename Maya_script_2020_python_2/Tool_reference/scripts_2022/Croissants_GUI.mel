////////////////////////////////////////////
//Start UI Command 

global proc Start_CMZ()
{
 
  int $CMZ_PM = `checkBox -q -v CMZ_P`;
  if($CMZ_PM == 0)
  {
    checkBox -e -v 1 CMZ_P;
    iconTextButton -e -i "Croissants.ico" -c "Croissants_get_PL(1);" "Croissants_get_PL_Btt";
    CMZ_Wire(); 
    get_CurrUnit_CC();
    Croissants_reUI();
    Croissants_DA_CMD();    
    //Croissants_get_PL(1);
  }
  else 
  {
    Croissants_get_PL(1);
  }
}
  
global proc Croissants_reUI()
{  
    cycleCheck - e off;  
    eval ( "source \"init.mel\"" );
    
    $Curr_project = `Croi_C_workspace`;
    textField -e -tx $Curr_project Croissants_wks;  
    
    Croissant_setWorkspace;
    
    catchQuiet(Get_Croissants_ABCList());    
    catchQuiet(Croissants_get_EPs(1));
    catchQuiet(OpenGetInfo(1));
    catchQuiet(OpenGetInfo(2));
    
    int $checkRoot=`optionMenu -q -ni Croissants_EP`;    
    if($checkRoot == 0)
    {
      textField -e -tx "Empty Trees :D" Croissants_msg;
    }
    else
    {
        int $checkSub=`optionMenu -q  -ni Croissants_CUT`;  
        if($checkSub == 0)
        {
          textField -e -tx "Empty Trees :D" Croissants_msg;
        } 
        else
        {
        optionMenu -e  -sl 1 Croissants_EP;
        optionMenu -e  -sl 1 Croissants_CUT; 
        catchQuiet(UI_ReFrash_CC(1));
        }
    }

    Croissants_get_EPs(100);  
     
    
    Croissants_BakeSet_List_PM(1);

    //read_python(); 
}    

global proc Croissants_DA_CMD()
{
  textScrollList -e -da Croissants_Ani_List;
  textScrollList -e -da Croissants_Lit_List;
  textScrollList -e -da Croissants_src_List;
  textScrollList -e -da Croissants_HIs_List;
  textScrollList -e -da Croissants_ABC_List;
  textScrollList -e -da Croissants_Assets_List_1;
  textScrollList -e -da Croissants_Assets_List_His;
  textScrollList -e -da Croissants_Model_List_1;
  //textScrollList -e -da Croissants_Mod_List_His;
}
  
