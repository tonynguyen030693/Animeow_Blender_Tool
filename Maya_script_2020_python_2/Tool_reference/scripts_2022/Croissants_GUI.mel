global proc Croissants_FrameCtrl(int $case)
{          

int $f_value_s =`intField -q -v "Croissants_A01_sf"`;
int $f_value_e =`intField -q -v "Croissants_A02_ef"`;

  switch($case)
  {
  case  1 :
  int $Nf_value_s_A = ($f_value_s + 1);
  intField -e -v $Nf_value_s_A "Croissants_A01_sf";
  break;
  
  case 2 :
  int $Nf_value_s_B = ($f_value_s - 1);
  intField -e -v $Nf_value_s_B "Croissants_A01_sf";  
  break;

  case 3 :
  int $Nf_value_e_A = ($f_value_e + 1);
  intField -e -v $Nf_value_e_A "Croissants_A02_ef";  
  break;
  
  case 4 :
  int $Nf_value_e_B = ($f_value_e - 1);
  intField -e -v $Nf_value_e_B "Croissants_A02_ef";    
  break;

  }
}  

global proc CMZ_view_Helper()
{

  optionMenu -e -bgc 0.4 0.5 0.2 Croissants_EP;
