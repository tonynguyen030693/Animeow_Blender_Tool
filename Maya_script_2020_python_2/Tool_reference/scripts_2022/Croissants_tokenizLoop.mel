global proc Croissants_macro_fileBuild_D()
{
  int $GetInof_count =`optionMenu -q -ni Croissants_CUT`;  
  for ($i=0; $i<($GetInof_count); $i++)
      {                     
        int $litfiles =`textScrollList -q -ni Croissants_Lit_List`;
        textScrollList -e -sii $litfiles Croissants_Lit_List;
        OPEN_Croissants_files(2);
        Croissants_logStats(92);

        Deadline_Auto_submitJOB();
        deleteUI -window DeadlineSubmitWindow; 
        file -f -new;
        ogs -pause;                                            
        Croissants_Pageing(3);

      }                    
}
  

global proc int dwin()
{
    int $waitd =`window -q -exists DeadlineSubmitWindow`;
    return $waitd;
}

global proc Deadline_Auto_submitJOB()
{
  SubmitJobToDeadline;

   global int $waitd;   
   if (`dwin`)
   {

      optionMenuGrp -e -select (5) frw_deadlinePool;
      optionMenuGrp -e -select (2) frw_Group;
      
      optionMenuGrp -e -select (2) frw_camera;
      checkBox -e -v 1 frw_submitMayaScene;
      checkBox -e -v 0 frw_overrideLayerSettings;
      checkBox -e -v 1 frw_submitEachRenderLayer;
      checkBox -e -v 1 frw_localRendering;
      checkBox -e -v 1 frw_submitAsSuspended;
      
      intSliderGrp  -e -v 100  frw_JobPriority;
      intSliderGrp -e -v 1  frw_FrameGroup;
      SetJobName; 
      //SetupSubmission; 
      DeadlineSubmitterOnOk;  
  }
  else
  {

  }

}
//////////////////////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////////////////////
//Vray Only now...
global proc Croissants_STILLRender()
{
  $cams=`ls -typ "camera"`;  
  string $myCam[] = `listRelatives -p $cams[0]`;
  if($myCam[0] == "_ShotCam")
  {
  string $now_cam = "_ShotCam";  
  ____stillRender($now_cam);
  }
  else
  {      
    string $Ques = "No Exist Correct Camera in this Scenes \nDo You Want Render with Select Camera?";
    $response_CamOrder = `confirmDialog -t "Wrong Camera" -m $Ques -ma "left" -b "Yes" -b "No" -db "Yes" -cb "No" -ds "No" `;  
        if( $response_CamOrder == "Yes" ) 
          {
              string $selCam[] = `ls -sl`;
              if(size($selCam) != 0)
              {                            
              string $now_cam = $selCam[0];  
              ____stillRender($now_cam);
              select -cl;
              }
              else
              {
                  confirmDialog -t "!!!" -m "No Camera Selected";
              }
          }
       else
       {
           print "Cancle...";
       }
  } 
}

global proc ____stillRender(string $now_cam)
{  
  //string $now_cam = "_ShotCam";  
  int $keep_SF = `getAttr "defaultRenderGlobals.startFrame"`;
  int $keep_EF = `getAttr "defaultRenderGlobals.endFrame"`;
  int $REN_frame = `currentTime -q`;
  int $Check_EF =`getAttr "defaultRenderGlobals.endFrame"`;
    vray showVFB;
    if ($Check_EF == 101)
    {
      setAttr "vraySettings.animBatchOnly" 0;     
      renderWindowRenderCamera render renderView $now_cam ;
      setAttr "vraySettings.animBatchOnly" 1;
    }
    else
    {
      setAttr "vraySettings.animBatchOnly" 0;
      setAttr "defaultRenderGlobals.startFrame" $REN_frame;
      setAttr "defaultRenderGlobals.endFrame" $REN_frame;
      renderWindowRenderCamera render renderView $now_cam ;
      setAttr "defaultRenderGlobals.startFrame" $keep_SF;
      setAttr "defaultRenderGlobals.endFrame" $keep_EF;
      setAttr "vraySettings.animBatchOnly" 1;
    }

  currentTime -e $REN_frame;
}  



global proc Croissants_AlembicBatch(int $case)
{  
  string $AlembicBatch_UI1 ="Croissants_Ani_List";
  string $AlembicBatch_UI2 ="Croissants_CUT";
  string $AlembicBatch_UI3 ="Croissants_EP";
  string $AlembicBatch_project = `workspace -q -fn`;
  string $AlembicBatch_EP=`optionMenu -q -v $AlembicBatch_UI3`;
  string $AlembicBatch_CUT=`optionMenu -q -v $AlembicBatch_UI2`;
  string $AlembicBatch_AniFile_Path = $AlembicBatch_project + "/02_Scenes/03_Animation/"  + "3_KEY" + "/" + $AlembicBatch_EP + "/" + $AlembicBatch_CUT + "/";
  string $bakeMSG = "Do you want to Bake All Ani Files? if You Run This Command \nMaya is Looks Like Dead ... But please wait for a moment \nUntil the progress bar Reaches 100% \nAnyway, If you Want Stop, Continue to press the \"ESC\" key several times...\nOr TaskKill Maya";

      switch($case)
      {
      case 1 :
         $response_ABCBatch = `confirmDialog -t "Confirm" -m $bakeMSG -ma "left" -b "Yes" -b "No" -db "Yes" -cb "No" -ds "No" `;
          //timer -s;	
          // check response_ABCBatch            
          if( $response_ABCBatch == "Yes" ) 
          {
              
              if (`window -ex Bake_Batch_WIN`) deleteUI Bake_Batch_WIN;
              window -t "Bake Result Viewer" -widthHeight 230 500  -mnb 0 -tb 1 -toolbox 1 -s 1 -rtf 1 Bake_Batch_WIN;
              columnLayout;		
              scrollField -w 230 -h 460 -tx "" getDir;
              textField -w 230 -h 20 -fn "boldLabelFont" getCount;
              textField -w 230 -h 20 -fn "boldLabelFont" timeCount;
              showWindow Bake_Batch_WIN;

              $c_1Postion =`window -q -tlc  GetInof_win`; 
              int $mag_c1 = $c_1Postion[1] -235;
              window -e -tlc $c_1Postion[0] $mag_c1 Bake_Batch_WIN;    
   
              Croissants_tokenizLoop(4);                                  
           }

          else if( $response_ABCBatch == "No" ) 
          {
           
            print("Cancel");
          }
          int $CountLine =`scrollField -q -nl getDir`;
          int $Result = $CountLine -1;
          float $elapsedTime  =`timer -e`;
          int $elapsedTimeM =($elapsedTime/60);
          textField -e -tx ("Bake of "+$Result+" files is complete.") getCount;
          textField -e -tx ("ElapsedTime : "+$elapsedTimeM+"\nMinute") timeCount;                    
          
          
      break;

      case 2 :
              //make folder via _AlembicBatch.mel
                
              int $Croissants_aniList = `textScrollList -q -ni $AlembicBatch_UI1`;
                if($Croissants_aniList == 0)
                {
                    print "pass";
                }
                else
                {
                    string $myMaya ="C:/Progra~1/Autodesk/Maya2019/bin/mayabatch.exe -proj " + $AlembicBatch_project +" -file ";   
                    string $myMel  =" -script "+"_AlembicBatch.mel";       
                    string $myCamMel  =" -script "+"_InfoCollection.mel";            
                    
                    textScrollList -e -sii $Croissants_aniList $AlembicBatch_UI1;
                    string $Croissants_bakeSource[] = `textScrollList -q -si $AlembicBatch_UI1`;


                        int $camRun =`checkBox -q -v Alembic_camRun`;
                        if ($camRun == 0)
                        {                    
                            int $preRun =`checkBox -q -v Alembic_preRun`;
                            if ($preRun == 0)
                            {
                              for ($j=0; $j<size($Croissants_bakeSource); $j++)
                              {                               
                                string $source_AniFile = $AlembicBatch_AniFile_Path+$Croissants_bakeSource[$j];
                                string $ABC_command = $myMaya+$source_AniFile+$myMel;
                                string $ABC_command_win = substituteAllString($ABC_command, "/", "\\\\");                                        
                                system( $ABC_command_win );
                                ////////////////////////////////////////////////////////////////////                                 
                                                             
                                  string $Otx =`scrollField -q -tx  getDir`;
                                  string $Ntx = $Otx +"\n"+ $Croissants_bakeSource[$j];
                                  scrollField -e -tx $Ntx  getDir;
                                                    
                              }
                            }
                            else
                            {
                              for ($j=0; $j<size($Croissants_bakeSource); $j++)
                              {  
                                ////////////////////////////////////////////////////////////////////                                                  
                                                               
                                  string $Otx =`scrollField -q -tx  getDir`;
                                  string $Ntx = $Otx +"\n"+ $Croissants_bakeSource[$j];
                                  scrollField -e -tx $Ntx  getDir;

                              }                    
                            }
                        }
                        else 
                        {
                              for ($i=0; $i<size($Croissants_bakeSource); $i++)
                              {
                              string $source_AniFile = $AlembicBatch_AniFile_Path+$Croissants_bakeSource[$i];
                              string $Otx =`scrollField -q -tx  getDir`;
                              string $Ntx = $Otx +"\n"+ $Croissants_bakeSource[$i];
                              scrollField -e -tx $Ntx  getDir;                                                    
                              string $ABC_command = $myMaya+$source_AniFile+$myCamMel;
                              string $ABC_command_win = substituteAllString($ABC_command, "/", "\\\\");                                        
                              system( $ABC_command_win );
                              }                        
                        
                        }                            
                }                                
      break; 
      }       
}


global proc Get_Animation_FrameInfo()
{
  int $Croissants_FrameInfo_CBIF = `checkBox -q -v Croissants_FrameInfo_CB`; 
    if($Croissants_FrameInfo_CBIF == 0)
    {
    Get_Animation_FrameInfo_UI(2);
    } 
    else
    {
    Get_Animation_FrameInfo_UI(1);
    }
}
global proc Get_Animation_FrameInfo_UI(int $case)
{
    if (`window -ex GetInof_win`) deleteUI GetInof_win;
    window -t "Get Info" -widthHeight 150 500  -mnb 0 -tb 1 -toolbox 1 -s 0 -rtf 1 GetInof_win;
    columnLayout;		
    scrollField -w 150 -h 500 -tx "" GetCI;
    showWindow GetInof_win;
    
    $c_0Postion =`window -q -tlc  Croissants`; 
    int $mag_c0 = $c_0Postion[1] -153;
    window -e -tlc $c_0Postion[0] $mag_c0 GetInof_win;    
    
    int $GetInof_count =`optionMenu -q -ni Croissants_CUT`;             
    optionMenu -e -sl 1 Croissants_CUT;
    string $C000 = `optionMenu -q -v Croissants_CUT`;             
    scrollField -e -cl GetCI;

    switch($case)
    {
        case 1:
                if ($C000 == "C000")
                {
                    Croissants_Pageing(3);
                    
                    for ($i=0; $i<($GetInof_count-1); $i++)
                    { 
                        string $Old_info =`scrollField -q -tx GetCI`;
                        string $CN = `optionMenu -q -v Croissants_CUT`;  
                        string $SF = `intField -q -v Croissants_A01_sf`;
                        string $EF = `intField -q -v Croissants_A02_ef`;
                        string $MergeVari = $CN + ":" + $SF +":" +$EF;                                        
                        if($i == 0)
                        {
                          string $New_info = $MergeVari;    
                          scrollField -e -tx $New_info  GetCI;  
                        }
                        else
                        {
                          string $New_info = $Old_info +"\n"+ $MergeVari;
                          scrollField -e -tx $New_info  GetCI;  
                        }
                      Croissants_Pageing(3);
                    }         
                }
                else
                {
                    for ($i=0; $i<$GetInof_count; $i++)
                    {
                        string $Old_info =`scrollField -q -tx GetCI`;
                        string $CN = `optionMenu -q -v Croissants_CUT`;  
                        string $SF = `intField -q -v Croissants_A01_sf`;
                        string $EF = `intField -q -v Croissants_A02_ef`;
                        string $MergeVari = $CN + ":" + $SF +":" +$EF;                                                
                        if($i == 0)
                        {
                          string $New_info = $MergeVari;    
                          scrollField -e -tx $New_info  GetCI;  
                        }
                        else
                        {
                          string $New_info = $Old_info +"\n"+ $MergeVari;
                          scrollField -e -tx $New_info  GetCI;  
                        }
                      Croissants_Pageing(3);
                    }  
                }
        break;
        
        case 2:
                if ($C000 == "C000")
                {
                    Croissants_Pageing(3);
                    
                    for ($i=0; $i<($GetInof_count-1); $i++)
                    {  
                        string $Old_info =`scrollField -q -tx GetCI`;
                        string $CN = `optionMenu -q -v Croissants_CUT`;  
                                        
                        if($i == 0)
                        {
                          string $New_info = $CN;    
                          scrollField -e -tx $New_info  GetCI;  
                        }
                        else
                        {
                          string $New_info = $Old_info +"\n"+ $CN;
                          scrollField -e -tx $New_info  GetCI;  
                        }
                      Croissants_Pageing(3);
                    }         
                }
                else
                {
                    for ($i=0; $i<$GetInof_count; $i++)
                    { 
                        string $Old_info =`scrollField -q -tx GetCI`;
                        string $CN = `optionMenu -q -v Croissants_CUT`;  
                                                                
                        if($i == 0)
                        {
                          string $New_info = $CN;    
                          scrollField -e -tx $New_info  GetCI;  
                        }
                        else
                        {
                          string $New_info = $Old_info +"\n"+ $CN;
                          scrollField -e -tx $New_info  GetCI;  
                        }
                      Croissants_Pageing(3);
                    }  
                }
        break;        
    }
    optionMenu -e -sl 1 Croissants_CUT;
                
}
