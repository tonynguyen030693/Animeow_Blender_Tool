//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////




global proc Croissants_tokenizLoop(int $case)
{
  string $cutlist= `scrollField -q -tx GetCI`;
  string $tokenized[];
  tokenize $cutlist "\n" $tokenized;
  switch($case)
  {

    case 0:
          for ($i=0; $i<size($tokenized); $i++)
          {                     
          optionMenu -e -v $tokenized[$i] Croissants_CUT;
          OpenGetInfo(2);
          Croissants_tokenizeAniOPEN();
          Croissants_logStats(8);             
          }
    break;
    
    case 1:
          for ($i=0; $i<size($tokenized); $i++)
          {                     
          optionMenu -e -v $tokenized[$i] Croissants_CUT;
          OpenGetInfo(2); 
          Croissants_macro_fileBuild_A;            
          }
    break;

    case 2:
          for ($i=0; $i<size($tokenized); $i++)
          {                     
          optionMenu -e -v $tokenized[$i] Croissants_CUT;
          OpenGetInfo(2); 
          Croissants_macro_fileBuild_B;            
          }
    break;

    case 3:
          for ($i=0; $i<size($tokenized); $i++)
          {                     
          optionMenu -e -v $tokenized[$i] Croissants_CUT;
          OpenGetInfo(2); 
          Croissants_macro_RenderCheck;            
          }
    break;
    case 4:         
          global string $gMainProgressBar;
          int $full = size($tokenized);
          for ($i=0; $i<size($tokenized); $i++)
          {                     
          optionMenu -e -v $tokenized[$i] Croissants_CUT;
          OpenGetInfo(2); 
               
          progressBar -edit -beginProgress -isInterruptable true -status "Baking ..." -maxValue $full $gMainProgressBar;
          if(`progressBar -query -isCancelled $gMainProgressBar`)
          break;                                                        
          progressBar -edit -step 1 $gMainProgressBar;          
          Croissants_AlembicBatch(2);             
          }
          progressBar -edit -endProgress $gMainProgressBar;

    break;   

    case 5:      
            for ($i=0; $i<size($tokenized); $i++)
            {                     
            optionMenu -e -v $tokenized[$i] Croissants_CUT;          
            OpenGetInfo(2); 
            Croissants_tokenizeAniOPEN();
            Croissants_Playblast;         
            }
    break;  
    case 6:      
            for ($i=0; $i<size($tokenized); $i++)
            {                     
            optionMenu -e -v $tokenized[$i] Croissants_CUT;          
            OpenGetInfo(2); 
            Croissants_tokenizeAniOPEN();
            Croissants_logStats(8); 
            
            setAttr "persp.translateX" 0;
            setAttr "persp.translateY" 0;
            setAttr "persp.translateZ" 0;
            setAttr "persp.rotateX" 0;
            setAttr "persp.rotateY" 0;
            setAttr "persp.rotateZ" 0;
            SaveScene;        
            }
    break;    
  }
}

global proc Croissants_Playblast_UI()
{
          int $ckMode = `checkBox -q -v Croissants_PBD_batch`;   
          if($ckMode == 1)   
          {      
            Croissants_tokenizLoop(5);
          }
          else
          {
            Croissants_Playblast;
          }  

}


global proc Croissants_AniFilesPreCheck()
{
          int $ckMode = `checkBox -q -v Croissants_countKey_Op`;   
          if($ckMode == 1)   
          {      
            Croissants_tokenizLoop(6);
          }
          else
          {
            Croissants_tokenizLoop(0);
          }  

}


