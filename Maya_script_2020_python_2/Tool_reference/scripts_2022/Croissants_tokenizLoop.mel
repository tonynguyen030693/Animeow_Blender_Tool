//Macro Pack Command
global proc Croissants_tokenizeAniOPEN()
{
  int $Croissants_aniList = `textScrollList -q -ni Croissants_Ani_List`;
  if($Croissants_aniList == 0)
  {
      print "pass";
  }
  else
  {
  textScrollList -e -sii $Croissants_aniList Croissants_Ani_List;
  OPEN_Croissants_files(1);
  }
}

global proc Croissants_macro_fileBuild_A()
{                   
  //Croissants_Pageing(3);
  Get_Croissants_ABCList();                  
  Croissants_macro_attach(); 
  Croissants_Prefix();       
  Croissants_Duplicate(1);                       
}

global proc Croissants_macro_fileBuild_B()
{                  
  int $litfiles =`textScrollList -q -ni Croissants_Lit_List`;
  textScrollList -e -sii $litfiles Croissants_Lit_List;
  OPEN_Croissants_files(2);
  Get_Croissants_ABCList();  
  Croissants_logStats(92);
  Croissants_macro_fileArray();
  file -save;
  textScrollList -e -da Croissants_Lit_List;
  //Croissants_Pageing(3);                    
}


global proc Croissants_macro_RenderCheck()
{

  int $litfiles =`textScrollList -q -ni Croissants_Lit_List`;
  textScrollList -e -sii $litfiles Croissants_Lit_List;
  OPEN_Croissants_files(2);
  Croissants_logStats(92);
           
  Deadline_submitChoo(1);
  Croissants_STILLRender;
  Deadline_submitChoo(2);
  Croissants_STILLRender;
  Deadline_submitChoo(3);
  Croissants_STILLRender;
  
  //Croissants_Pageing(3); 
}

////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////
//Macro Each Command

global proc Croissants_macro_fileArray()
{
  string $AL[] =`textScrollList -q -ai Croissants_ABC_List`;
    for ($i=0; $i<size($AL); $i++)
        {
          string $name = substituteAllString($AL[$i], ".abc", "");        
          if ($name == "_cam")
          {
           print "end"; 
          }
          else
          {
          string $Tpye = `substring $name 1 3`;	
          string $abcAsset = substituteAllString($name, $Tpye, "");              

          setAttr ("Assets_DL."+$abcAsset) 1;          
          }
         }
}


global proc Croissants_macro_attach()
{
  int $abclist =`textScrollList -q -ni Croissants_ABC_List`;
  for ($i=1; $i<($abclist+1); $i++)
      {
          textScrollList -e -da Croissants_ABC_List;
          textScrollList -e -sii $i Croissants_ABC_List;
          Import_Croissants_Cache(2);
          textScrollList -e -da Croissants_ABC_List;
      }
}



global proc Deadline_submitChoo(int $preRen)
{
int $rSF = `textField -q -tx Croissants_A01_sf`;
int $rEF = `textField -q -tx Croissants_A02_ef`;
int $rMF = ((($rEF - $rSF)/2)+100); 

  switch($preRen)
  {
    case 1:
          setAttr "defaultRenderGlobals.startFrame" $rSF;
          setAttr "defaultRenderGlobals.endFrame" $rSF;
    break;
    case 2:
          setAttr "defaultRenderGlobals.startFrame" $rMF;
          setAttr "defaultRenderGlobals.endFrame" $rMF;
    break;
    case 3:
          setAttr "defaultRenderGlobals.startFrame" $rEF;
          setAttr "defaultRenderGlobals.endFrame" $rEF;
    break;        
  }

}

