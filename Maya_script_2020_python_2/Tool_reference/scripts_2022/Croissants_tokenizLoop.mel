//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//
//이 스크립트는 오로지 프로젝트에 제한되어 있음
//
//1. 컷 리스트 를  구한다.
//2. 미리 만들어둔 메크로들을 조합하여 구한 리스트대로 적용한다.
////////////////////////////////////////////메뉴 1
//=====================================================================================================================
//Croissants_tokenizLoop(int $case) = > 아래의 나열된 명령을 정해진 컷 넘버만큼만 진행해라
//=====================================================================================================================
//Croissants_tokenizLoop(1) = > 구해진 씬 만큼 씬 만들기

  //Croissants_macro_fileBuild_A =>   
    //Croissants_Pageing(3); 페이지를 넘긴다. == 토크나이즈에선 작동 꺼져 있음
    //Get_Croissants_ABCList(); 알렘빅 리스트를 구한다.                  
    //Croissants_macro_attach(); 알렘빅을 어태치 한다.
    //Croissants_Prefix();       렌더셋팅을 적용시킨다.
    //Croissants_Duplicate(1);   적용시킨 씬 파일을 지정된 컷 번로호 저장한다.
//=====================================================================================================================
//=====================================================================================================================
//Croissants_tokenizLoop(2) = > 구해진 씬 만큼 알렘빅 어태치 하고 씬 구성하기
//
  //Croissants_macro_fileBuild_B =>  
    //int $litfiles =`textScrollList -q -ni Croissants_Lit_List`;  라이트 파일 전체 갯수를 확인
    //textScrollList -e -sii $litfiles Croissants_Lit_List; // 그중에 마지막 버전을 선택
    //OPEN_Croissants_files(2); 선택한 파일을 오픈
    //Get_Croissants_ABCList();  알렘빅 리스트를 구하고
    //Croissants_logStats(92); 씬정보를 로드한다. (애니메이션베이크할때 만들어진 .log의 정보)
    //Croissants_macro_fileArray(); Assets_DL_[에셋이름]의 디스플레이 레어어가 있을때만 작동 (on/off)
    //file -save; 파일 저장
    //textScrollList -e -da Croissants_Lit_List; 선택한 모든 리스트를 초기화
    //Croissants_Pageing(3);  == 토크나이즈에선 작동 꺼져 있음
//=====================================================================================================================
//=====================================================================================================================
//Croissants_tokenizLoop(1) && Croissants_tokenizLoop(2) 는 별도로 수행해서 씬을 만들고 다 만들어지면
// 캐쉬를 붙이는 과정을 나눠놓음
//=====================================================================================================================
//=====================================================================================================================
//Croissants_tokenizLoop(3) = > 구해진 리스트만큼 씬을 열어서 앞뒤 중간으로 스틸을 렌더하는 레이지 커맨드
    //Croissants_macro_RenderCheck  // 처음,중간,끝 프레임 스틸 렌더 (tmp)경로가 아닌 / Vray에 한정된 커맨드
//=====================================================================================================================
//=====================================================================================================================
//Croissants_tokenizLoop(4) = > 구해진 리스트만큼 알렘빅 베이크 하기
    //Croissants_AlembicBatch(2);  //UI는 마야를 사용하지만 마야밖에서 마야배치를 사용하는 윈도우 전용 커멘드
    //Croissants_AlembicBatch(1); //커맨드 전용 UI 를 빌드하고 Croissants_tokenizLoop(4)로 리턴해서 Croissants_AlembicBatch(2)를 실행한다.
    //Croissants_AlembicBatch(2)는 디버그 모드와 본 모드가 따로 있고 카메라 전용 베이크가 별도로 있다. 실행하기전 디버그 모드로 한번확인이 필요하다.
//
//////////////////////////////Kill UI
    //button -e -c "Croissants_tokenizLoop(1);" Croissants_tokenizLoop_1;
    //button -e -c "Croissants_tokenizLoop(2);" Croissants_tokenizLoop_2;
    //button -e -c "Croissants_macro_attach();Croissants_macro_fileArray();Croissants_logStats(92);Croissants_Prefix();" Croissants_tokenizLoop_3;
    //button -e -c "Croissants_tokenizLoop(3);" Croissants_tokenizLoop_4;
    //
    //button -e -c "Croissants_countKey(1);Croissants_countKey(2);" Croissants_countKey_BTT;



//button -e -vis 0 Croissants_tokenizLoop_1;
//button -e -vis 0 Croissants_tokenizLoop_2;
//button -e -vis 0 Croissants_tokenizLoop_3;
//button -e -vis 0 Croissants_tokenizLoop_4;

iconTextButton -e -c "Croissants_AniFilesPreCheck();" Croissants_countKey_BTT;

//=====================================================================================================================
//=====================================================================================================================
//Croissants_tokenizLoop(5) = > 구해진 리스트만큼 씬을 열어서 플레이 블라스트 만들기
          //Croissants_tokenizeAniOPEN();
          //Croissants_Playblast;   
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
