//Command 
global proc waffle_FL_CLL_Func(int $case)
{

  string $waffle_FL_List= "waffle_FL_Array,waffle_FL_Tools,waffle_FL_VisCtrl";
  string $waffle_FL_tokenized[];
  tokenize $waffle_FL_List "," $waffle_FL_tokenized;
  

              for ($i=0; $i<size($waffle_FL_tokenized); $i++)
              {                     
                int $waffle_FLCL=`frameLayout -q -cl $waffle_FL_tokenized[$i]`;
                if($waffle_FLCL==0)
                  {
                    frameLayout -e -cl 1 $waffle_FL_tokenized[$i];    
                  }
              }

                string $waffle_LFName=`frameLayout -q -l $waffle_FL_tokenized[$case]`;   
                frameLayout -e -cl 0 ("waffle_FL_"+$waffle_LFName);
           
}     



global proc waffle_cam_rename()
{
  $List =`ls -sl`;
  rename $List "_ShotCam";
}


global proc waffle_GCAL()
{
    int $EpisodicG = `checkBox -q -v waffle_Episodic`;
    if($EpisodicG == 0)
    {
    Get_waffle_AssetsList(3);
    }
    else
    Get_waffle_AssetsList(31);
}


global proc croffle_Rule(int $case)
{
    switch($case)
    {
      case 1 :
        string $xxx =`currentUnit -q -time`;
        if($xxx == "ntsc")
          {
           textField -e -tx  "30-FPS"  waffle_msg_2;   
          }
          else if($xxx == "pal")
          {
           textField -e -tx  "25-FPS"  waffle_msg_2;   
          }
          else if($xxx == "ntscf")
          {
           textField -e -tx  "60-FPS"  waffle_msg_2;   
          }
          else if($xxx == "film")
          {
           textField -e -tx  "24-FPS"  waffle_msg_2;   
          }
          else
          {
           textField -e -tx  "Others-FPS"  waffle_msg_2;   
          }   
      break;

      case 2 :
          publish_SUPER;
      break;
      
      case 3 :
      string $rule_password = `textField -q -tx waffle_msg_2`; 
      if($rule_password == "king")
      {
      croffle_Rule(2);      
      }
      else
      {
      croffle_Rule(1); 
      }
      break;

    }
}


global proc waffle_reUI()
{  
    cycleCheck - e off;  
    
    eval ( "source \"waffle_Ani.mel\"" );
    eval ( "source \"_Utility.mel\"" );
    eval ( "source \"waffle_HUD.mel\"" );
    catchQuiet(waffle_Epsodic());
    catchQuiet(waffle_get_EPs(1));
    catchQuiet(waffle_get_EPs(2));
    catchQuiet(waffle_get_EPs(3));
    catchQuiet(waffle_get_EPs(4));
      
    $cur=`optionMenu -q  -ni waffle_EP`;
    int $choo = $cur;
    if($choo == 0)
    {
      print ("Empty Trees :D\n");
    }
    else
    {
    optionMenu -e -sl $choo waffle_EP; 
    }

    catchQuiet(waffle_get_EPs(1));
    catchQuiet(waffle_get_EPs(2));
    catchQuiet(waffle_get_EPs(3));
    catchQuiet(waffle_get_EPs(4));

 
}    


global proc waffle_UI_ReFrash_CC(int $case)
{
  switch($case)
  {
  case 1 :     
   catchQuiet(waffle_get_EPs(3));
   catchQuiet(waffle_get_EPs(4));

  
  break;
  
  case 2 :
   catchQuiet(waffle_assets_OM(2));
   catchQuiet(waffle_assets_OM(3));    
  break;
  

  }
}

global proc waffle_Epsodic()
{
    string $now_project = `workspace -q -fn`;
    $now_RootPath = stringToStringArray($now_project, "/");
    $now_project_c = $now_RootPath[0] + "\\" + $now_RootPath[1]+ "\\" + $now_RootPath[2];

    string $ProjectType[]= `getFileList -folder $now_project -filespec "*.ini"`;
    string $ProjectNote = $now_project_c + $ProjectType[0];
           $noteId = `fopen $ProjectNote "r"` ;  
    string $note_info = `fread $noteId $note_info` ; 
                         fclose $noteId;         

    string $note_infos[];  
           $note_infos = stringToStringArray($note_info, "/"); 
    int $value = $note_infos[0];
    checkBox -e -v $value waffle_Episodic; 
           
}



global proc publish_SUPER()
{
iconTextButton -e -en 1 waffle_PUB_Super;
}  

global proc waffle_RemoveREF()
{

    string $objs[] = `ls -sl`;
  for($i=0;$i < size($objs); $i++)
  {
          string $rNode = $objs[$i];
    $referenceNode = `referenceQuery -rfn $rNode`;
          file -removeReference -referenceNode $referenceNode;   
  }
}



global proc FrameUTIL_CC(int $case)
{
    switch($case)
    {
    case 1 :
    waffle_projectCamReN();
    break;
    
    case 2 :
    
    waffle_PlayBlastFrame(1);
    waffle_PlayBlastFrame(2);
    break;
    
    }

}

global proc GET_waffle_TIME()
{
  int $waffle_pMin = `playbackOptions -q -min`;
  int $waffle_pMax = `playbackOptions -q -max`;
  intField -e -v $waffle_pMax  waffle_A02_ef; 
  intField -e -v $waffle_pMin  waffle_A01_sf; 
}

global proc waffle_PlayBlastFrame(int $case)
{

    switch ($case)
    {
    
    case 1 :
    
    $re_EndFrame = `intField  -q -v waffle_A02_ef`;
    setAttr "defaultRenderGlobals.endFrame" $re_EndFrame;
    playbackOptions -aet $re_EndFrame;
    playbackOptions -min `getAttr "defaultRenderGlobals.startFrame"` -max $re_EndFrame;
    
    break;
    
    case 2 :
    $re_StartFrame = `intField  -q -v waffle_A01_sf`;
    setAttr "defaultRenderGlobals.startFrame" $re_StartFrame;
    playbackOptions -ast $re_StartFrame;
    playbackOptions -max `getAttr "defaultRenderGlobals.endFrame"` -min $re_StartFrame;
    
    break;

    }
}  


global proc waffle_copyTime()
{
    int $ftime = `intField -q -v waffle_A01_sf`;
     intField -e -v $ftime waffle_A02_ef;  
}



global proc waffle_projectCamReN()
{
string $gets[] =`ls -sl`;

$Path = `workspace -q -fn`;
string $init[]= `getFileList -folder $Path -filespec "*.ini"`;
string $ini_gets = $init[0]; 
string $G_I[] = stringToStringArray($ini_gets, ".");


string $EP_N=`optionMenu -q -v waffle_EP`;
string $Cut_N = `optionMenu -q -v waffle_CUT`;
string $prEF =`intField -q -v waffle_A02_ef`; 
string $prSF =`intField -q -v waffle_A01_sf`; 
string $camName = $G_I[0] +"_" + $Cut_N + "_" + $prSF + "_" + $prEF +"_Cam";
rename $gets[0] $camName;

}   
   

global proc waffle_Pageing(int $num)
{
  switch($num)
  {
  //next
  case 1:
  $cur=`optionMenu -q  -sl waffle_EP`;
  int $choo_1 = $cur + 1;
  optionMenu -e  -sl $choo_1 waffle_EP; waffle_UI_ReFrash_CC(1);
  waffle_get_EPs(2);
  
  break;

  //back
  case 2:
  $cur=`optionMenu -q  -sl waffle_EP`;
  int $choo_2 = $cur - 1;
  optionMenu -e  -sl $choo_2 waffle_EP; waffle_UI_ReFrash_CC(1);
  waffle_get_EPs(2);
  
  break;

  //next
  case 3:
  $cur=`optionMenu -q  -sl waffle_CUT`;
  int $choo_3 = $cur + 1;
  $c_limited=`optionMenu -q -ni waffle_CUT`;
  if($choo_3 > $c_limited)
  {  
  print "No more...";
  }
  else
  {
      optionMenu -e  -sl $choo_3 waffle_CUT;waffle_UI_ReFrash_CC(1);
  }
  break;

  //back
  case 4:
  $cur=`optionMenu -q  -sl waffle_CUT`;
  int $choo_4 = $cur - 1;
  optionMenu -e  -sl $choo_4 waffle_CUT;waffle_UI_ReFrash_CC(1);
  break;
  }
}
  
