        }  
      break;
      
   }
 }
 

global proc waffle_UI_dc_CC(int $case)
{
  switch($case)
      {
        case 1 :
        //textScrollList -e -da waffle_Ani_List;
        textScrollList -e -da waffle_Ani_List_2;
        textScrollList -e -da waffle_Ani_List_3;
        textScrollList -e -da waffle_Ani_List_4;
        break;

        case 2 :
        textScrollList -e -da waffle_Ani_List;
        //textScrollList -e -da waffle_Ani_List_2;
        textScrollList -e -da waffle_Ani_List_3;
        textScrollList -e -da waffle_Ani_List_4;
        break;

        case 3 :
        textScrollList -e -da waffle_Ani_List;
        textScrollList -e -da waffle_Ani_List_2;
        //textScrollList -e -da waffle_Ani_List_3;
        textScrollList -e -da waffle_Ani_List_4;
        break;
                        
        case 4 :
        textScrollList -e -da waffle_Ani_List;
        textScrollList -e -da waffle_Ani_List_2;
        textScrollList -e -da waffle_Ani_List_3;
        //textScrollList -e -da waffle_Ani_List_4;
        break;                        
      }

}


  global proc waffle_assets_OM(int $case)
  {
    int $note_infos_Assets = `checkBox -q -v waffle_Episodic`;  

    switch($case)
    {
    case 1 :
          if($note_infos_Assets == 0)
          {
           Get_waffle_AssetsList(2);Get_waffle_AssetsList(3);
          }
          else if ($note_infos_Assets == 1)
          {
          Get_waffle_AssetsList(2);Get_waffle_AssetsList(21);Get_waffle_AssetsList(31);
          }    
    break;

    case 2 :
          if($note_infos_Assets == 0)
          {
           Get_waffle_AssetsList(3);
          }
          else
          {
          Get_waffle_AssetsList(21);Get_waffle_AssetsList(31);
          }       
    break;
    
    case 3 :

          Get_waffle_AssetsList(31);Get_waffle_AssetsList(33);
      
    break;  
    case 4 :
          if($note_infos_Assets == 0)
          {
           Get_waffle_AssetsList(1);Get_waffle_AssetsList(2);Get_waffle_AssetsList(3);
          }
          else
          {
          Get_waffle_AssetsList(1);Get_waffle_AssetsList(2);Get_waffle_AssetsList(21);Get_waffle_AssetsList(31);Get_waffle_AssetsList(33);
          }       
    break;      
    
    }
  
  }

  global proc Get_waffle_AssetsList(int $case)
  {
    string $c_project_Assets = `workspace -q -fn`;
    $RootPath_Assets = stringToStringArray($c_project_Assets, "/");
    $project_Assets = $RootPath_Assets[0] + "\\" + $RootPath_Assets[1]+ "\\" + $RootPath_Assets[2];
          
    string $Path_Assets = $project_Assets + "\02_Scenes\\_Assets\\";
      
    string $omA_FB=`optionMenu -q -v waffle_Assets`;
    string $omB_FB=`optionMenu -q -v waffle_Assets_2`;
    string $omC_FB=`optionMenu -q -v waffle_Assets_3`;
    string $AssetPath = $Path_Assets + $omA_FB + "\\" + $omB_FB + "\\";
    string $AssetPath_His = $Path_Assets + $omA_FB + "\\" + $omB_FB + "\\_His";
    string $AssetPath_son = $Path_Assets + $omA_FB + "\\" + $omB_FB + "\\"+ $omC_FB + "\\";
    string $AssetPath_son_His = $Path_Assets + $omA_FB + "\\" + $omB_FB +"\\" +$omC_FB+"\\_His";  


                    
  switch($case)
    {
      case 1 :        
              $menuItems = `optionMenu -q -itemListLong waffle_Assets`;
              if(size($menuItems) != 0)
              {deleteUI($menuItems);}
                         
              string $dir_list[] = `getFileList -folder $Path_Assets -filespec "*"`;
                string $dir_list_sort[];
                $dir_list_sort=sort($dir_list);

                for ($i = 0; $i < size($dir_list_sort); $i++)
                {           
                menuItem -l $dir_list_sort[$i] -p waffle_Assets;
                }              
      break;

      case 2 :
                $menuItems_sub = `optionMenu -q -itemListLong waffle_Assets_2`;
                if(size($menuItems_sub) != 0)
                {deleteUI($menuItems_sub);} 

                string $omA=`optionMenu -q -v waffle_Assets`;                              
                //string $omB=`optionMenu -q -v waffle_Assets_2`;
                string $case2Path = $Path_Assets + $omA + "\\" ; //+ $omB + "\\";
                           
                    string $dir_list_sub[] = `getFileList -folder $case2Path -filespec "*"`;
                      if (size($dir_list_sub) == 0)
                      {
                        print "There are no assets.";
                        textScrollList -edit -removeAll waffle_Assets_List_1;
                      }
                      else
                      {
                        string $dir_list_sort_sub[];
                        $dir_list_sort_sub=sort($dir_list_sub);                        
                        for ($i = 0; $i < size($dir_list_sort_sub); $i++)
                        {           
                        menuItem -l $dir_list_sort_sub[$i] -p waffle_Assets_2;
                        }
                      }               

      break;

      case 21 :  
                $menuItems_son = `optionMenu -q -itemListLong waffle_Assets_3`;
                if(size($menuItems_son) != 0)
                {deleteUI($menuItems_son);} 
                    string $omA_son=`optionMenu -q -v waffle_Assets`;
                    string $omB_son=`optionMenu -q -v waffle_Assets_2`;
                    string $case21Path = $Path_Assets + $omA_son + "\\" + $omB_son + "\\";
                           
                    string $dir_list_son[] = `getFileList -folder $case21Path -filespec "*"`;
                    if (size($dir_list_son) == 0)
                    {
                      print "There are no assets.";
                      textScrollList -edit -removeAll waffle_Assets_List_1;
                    } 
                    else
                    {             
                      string $dir_list_sort_son[];
                      $dir_list_sort_son=sort($dir_list_son);
                  
                      for ($i = 0; $i < size($dir_list_sort_son); $i++)
                      {           
                      menuItem -l $dir_list_sort_son[$i] -p waffle_Assets_3;
                      }
                    }  
       
      break;     

      case 3 :                       
                string $dir_list_subA[] = `getFileList -folder $AssetPath -filespec "*.m*"`;        
                
                if(size($dir_list_subA) == 0)
                {
                  print "There are no assets.";
                  textScrollList -edit -removeAll waffle_Assets_List_1;
                }
                else
                {                
                    string $dir_list_sort_subA[];
                    $dir_list_sort_subA=sort($dir_list_subA);        
                    textScrollList -edit -removeAll waffle_Assets_List_1;
                    for ($i = 0; $i < size($dir_list_sort_subA); $i++)
                    {           
                    textScrollList   -ams 0 -sc "" -dcc "OPEN_waffle_files(3);" -e -a $dir_list_sort_subA[$i] waffle_Assets_List_1;
                    }  
        
                    //remove .mayaSwatches Assets List
                    int $checkCount =`textScrollList -q -ni waffle_Assets_List_1`;
                    if ($checkCount == 0){print "no Items";}
                    else
                    {
                    textScrollList -e -sii 1 waffle_Assets_List_1;
                    string $mayaSwatchesX[] =`textScrollList -q -si waffle_Assets_List_1`;
                        if ($mayaSwatchesX[0] != ".mayaSwatches")
                        {
                            print "noSwatche";
                        }
                        else
                        textScrollList -e -rii 1  waffle_Assets_List_1; 
                    }
                    //Get History
                    string $dir_list_Assets_subA[] = `getFileList -folder $AssetPath_His -filespec "*.m*"`;            
                    string $dir_list_sort_Assets_subA[];
                    $dir_list_sort_Assets_subA=sort($dir_list_Assets_subA);
                    textScrollList -edit -removeAll waffle_Assets_List_His;
                        for ($i = 0; $i < size($dir_list_sort_Assets_subA); $i++)
                        {           
                        textScrollList   -ams 0 -sc "" -dcc "OPEN_waffle_files(42);" -e -a $dir_list_sort_Assets_subA[$i] waffle_Assets_List_His;
                        }                      
                }    

        break;                    
      case 31 :
                string $dir_list_subA_son[] = `getFileList -folder $AssetPath_son -filespec "*.m*"`;        

                if(size($dir_list_subA_son) == 0)
                {
                    print "There are no assets.";
                    textScrollList -edit -removeAll waffle_Assets_List_1;
                }
                else
                {
                    string $dir_list_sort_subA_son[];
                    $dir_list_sort_subA_son=sort($dir_list_subA_son);        
                    textScrollList -edit -removeAll waffle_Assets_List_1;
                    for ($i = 0; $i < size($dir_list_sort_subA_son); $i++)
                    {           
                    textScrollList   -ams 0 -sc "" -dcc "OPEN_waffle_files(3);" -e -a $dir_list_sort_subA_son[$i] waffle_Assets_List_1;
                    }  
        
                    //remove .mayaSwatches Assets List
                    int $checkCount31 =`textScrollList -q -ni waffle_Assets_List_1`;
                    if ($checkCount31 == 0){print "no Items";}
                    else
                    {
                    textScrollList -e -sii 1 waffle_Assets_List_1;
                    string $mayaSwatchesX[] =`textScrollList -q -si waffle_Assets_List_1`;
                        if ($mayaSwatchesX[0] != ".mayaSwatches")
                        {
                            print "noSwatche";
                        }
                        else
                        textScrollList -e -rii 1  waffle_Assets_List_1; 
                    }    
                        

                 }              
        break;  
  


        
        //make Assets History  
        case 4 :
        
            string $omA_H=`optionMenu -q -v waffle_Assets`;
            string $omB_H=`optionMenu -q -v waffle_Assets_2`;
            string $case4Path = $Path_Assets + $omA_H + "\\" + $omB_H + "\\";
            string $case4Path_His = $Path_Assets + $omA_H + "\\" + $omB_H + "\\_His";
            
            string $waffle_Assets_His[] = `textScrollList -q -si waffle_Assets_List_1`;

            for ($i=0; $i<size($waffle_Assets_His); $i++)
            {
            string $Assets_filename = $case4Path + $waffle_Assets_His[$i];
            string $Assets_filename_His = $case4Path_His +"\\"+"_"+ $waffle_Assets_His[$i];            
            sysFile -makeDir $case4Path_His;
            string $syscmd_Assets ="copy "+$Assets_filename+ " " + $Assets_filename_His +" /y";
            system( $syscmd_Assets );
            }

            Get_waffle_AssetsList(3);                    
       break;

        case 41 :
        
            string $omA_HB=`optionMenu -q -v waffle_Assets`;
            string $omB_HB=`optionMenu -q -v waffle_Assets_2`;
            string $omC_HB=`optionMenu -q -v waffle_Assets_3`;
            string $case41Path = $Path_Assets + $omA_HB + "\\" + $omB_HB + "\\"+ $omC_HB + "\\";
            string $case41Path_His = $Path_Assets + $omA_HB + "\\" + $omB_HB +"\\"+ $omC_HB +"\\_His";
            
            string $waffle_Assets_His_B[] = `textScrollList -q -si waffle_Assets_List_1`;

            for ($i=0; $i<size($waffle_Assets_His_B); $i++)
            {
            string $Assets_filename_His = $case4Path + $waffle_Assets_His_B[$i];
            sysFile -makeDir $case41Path_His;
            string $syscmd_Assets ="move "+$Assets_filename_His+ " " + $case41Path_His;
            system( $syscmd_Assets );
            }

            Get_waffle_AssetsList(31);                    
       break;
   
        case 5 :     
          $response = `confirmDialog -title "Confirm" 
                          -message "ŔĚ żˇĽÂŔ» ÁřÂĄ·Î ĆÄŔĎŔ» Áöżď°Ç°ˇżä?"
                          -button "Yes" 
                          -button "No"
                          -defaultButton "Yes"
                          -cancelButton "No"
                          -dismissString "No"`;
          
          // check response	  
          if( $response == "Yes" ) 
          {
              string $waffle_Del_Assets[] = `textScrollList -q -si waffle_Assets_List_1`;

            string $omA_5=`optionMenu -q -v waffle_Assets`;
            string $omB_5=`optionMenu -q -v waffle_Assets_2`;
            string $omC_5=`optionMenu -q -v waffle_Assets_3`;

            int $EpisodicA = `checkBox -q -v waffle_Episodic`; 
            
              if($EpisodicA == 0)
              {
                string $case5Path = $Path_Assets + $omA_5 + "\\" + $omB_5 + "\\";
                    for ($i=0; $i<size($waffle_Del_Assets); $i++)
                    {
                    string $waffle_Del_Assets_filename = $case5Path + $waffle_Del_Assets[$i];
                    sysFile -delete $waffle_Del_Assets_filename;    

                    }
                    Get_waffle_AssetsList(3);
              }      
              else
              {
                string $case5Path = $Path_Assets + $omA_5 + "\\" + $omB_5 + "\\" + $omC_5 + "\\";
                    for ($i=0; $i<size($waffle_Del_Assets); $i++)
                    {
                    string $waffle_Del_Assets_filename = $case5Path + $waffle_Del_Assets[$i];
                    sysFile -delete $waffle_Del_Assets_filename;    
                    }
                    Get_waffle_AssetsList(31);
              }                
              
              print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
          } 
          else if( $response == "No" ) 
          {
            print("ČŢ~~~ ^^;\n");
          }
        break;

        case 6 :     
          $response = `confirmDialog -title "Confirm" 
                          -message "ŔĚ żˇĽÂŔş żĎŔüČ÷ ÁöżöÁý´Ď´Ů."
                          -button "Yes" 
                          -button "No"
                          -defaultButton "Yes"
                          -cancelButton "No"
                          -dismissString "No"`;
          
          // check response	  
          if( $response == "Yes" ) 
          {

            string $omA_6=`optionMenu -q -v waffle_Assets`;
            string $omB_6=`optionMenu -q -v waffle_Assets_2`;
            string $case6Path = $Path_Assets + $omA_6 + "\\" + $omB_6 + "\\";
          
              string $cmd = "RD "+$case6Path + " /s /q";
              system ($cmd);  
              
              Get_waffle_AssetsList(2);
              Get_waffle_AssetsList(3);
              print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
          } 
          else if( $response == "No" ) 
          {
            print("ČŢ~~~ ^^;\n");
          }
        break;
    }
 }

 
///////////////////////////////////////////////////////////
//File Opne Scripts
//////////////////////////////////////////////////////////

global proc OPEN_waffle_files(int $case)
{
  $Curr_project = `workspace -q -fn`;
  $RootPath = stringToStringArray($Curr_project, "/");
  $project = $RootPath[0] + "\\" + $RootPath[1]+ "\\" + $RootPath[2];  
 

  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  //Ani&Light
  string $EPs_op_1=`optionMenu -q -v waffle_EP`;
  string $CUTs_OP_1=`optionMenu -q -v waffle_CUT`;
  string $Ani_Path = $project + "\\02_Scenes\\03_Animation\\"  + "3_KEY" + "\\" + $EPs_op_1 + "\\" + $CUTs_OP_1 + "\\";
  string $Ani_Path_2 = $project + "\\02_Scenes\\03_Animation\\"  + "3_KEY" + "\\" + $EPs_op_1 + "\\" + $CUTs_OP_1 + "\\_ALY\\";
  string $Ani_Path_3 = $project + "\\02_Scenes\\03_Animation\\"  + "3_KEY" + "\\" + $EPs_op_1 + "\\" + $CUTs_OP_1 + "\\_BLK\\";
  string $Ani_Path_4 = $project + "\\02_Scenes\\03_Animation\\"  + "3_KEY" + "\\" + $EPs_op_1 + "\\" + $CUTs_OP_1 + "\\_DTL\\";


  

  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  //Assets
  string $BigFolder_OP_3=`optionMenu -q -v waffle_Assets`;
  string $SubFolder=`optionMenu -q -v waffle_Assets_2`;
  string $SonFolder=`optionMenu -q -v waffle_Assets_3`;
  
  string $AssetsFile_C3 = $project + "\\02_Scenes\\_Assets\\" + $BigFolder_OP_3 + "\\" + $SubFolder + "\\";
  string $AssetsFile_C4 = $AssetsFile_C3 + "_His\\";
  string $AssetsFile_C4_pub = $AssetsFile_C3 + "pub\\";

  string $AssetsFile_C3_son = $project + "\\02_Scenes\\_Assets\\" + $BigFolder_OP_3 + "\\" + $SubFolder + "\\" + $SonFolder + "\\";
  string $AssetsFile_C4_son = $AssetsFile_C3_son + "_His\\";
  string $AssetsFile_C4_son_pub = $AssetsFile_C3_son + "pub\\";

  
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


  
  
  int $valueRefname =`checkBox -q -v waffle_ref_namerule`; 
  int $note_infos_Assets = `checkBox -q -v waffle_Episodic`;
  
  switch($case)
  {
      case 1 :

              string $waffle_Ani[] = `textScrollList -q -si waffle_Ani_List`;

                  for ($i=0; $i<size($waffle_Ani); $i++)
                  {
                  string $Ani_filename = $Ani_Path+$waffle_Ani[$i];
                  file -f  -ignoreVersion  -o $Ani_filename; //-typ "mayaAscii" 
                  GET_waffle_TIME();
                  }
                    croffle_Rule(1);
                    //textField -e -tx  "The Ani file has been opened."  waffle_msg_2;
          
      break;                  
   

      case 12 :

              string $waffle_Ani_2[] = `textScrollList -q -si waffle_Ani_List_2`;

                  for ($i=0; $i<size($waffle_Ani_2); $i++)
                  {
                  string $Ani_filename_2 = $Ani_Path_2+$waffle_Ani_2[$i];
                  file -f  -ignoreVersion  -o $Ani_filename_2;
                  GET_waffle_TIME();
                  }
                    croffle_Rule(1);
                    textField -e -tx  "The Layout file has been opened."  waffle_msg_2;
          
      break;   


      case 13 :

              string $waffle_Ani_3[] = `textScrollList -q -si waffle_Ani_List_3`;

                  for ($i=0; $i<size($waffle_Ani_3); $i++)
                  {
                  string $Ani_filename_3 = $Ani_Path_3+$waffle_Ani_3[$i];
                  file -f  -ignoreVersion  -o $Ani_filename_3;
                  GET_waffle_TIME();
                  }
                    croffle_Rule(1);
                    textField -e -tx  "The Block file has been opened."  waffle_msg_2;
          
      break;   


      case 14 :

              string $waffle_Ani_4[] = `textScrollList -q -si waffle_Ani_List_4`;

                  for ($i=0; $i<size($waffle_Ani_4); $i++)
                  {
                  string $Ani_filename_4 = $Ani_Path_4+$waffle_Ani_4[$i];
                  file -f  -ignoreVersion  -o $Ani_filename_4;
                  GET_waffle_TIME();
                  }
                    croffle_Rule(1);
                    textField -e -tx  "The Detail file has been opened."  waffle_msg_2;
          
      break;   

      case 3 :
              //Open          
              string $waffle_List[] = `textScrollList -q -si waffle_Assets_List_1`;

                  for ($i=0; $i<size($waffle_List); $i++)
                  {
                      if($note_infos_Assets == 0)
                      {
                      string $Lit_filename = $AssetsFile_C3+$waffle_List[$i];
                      file -f  -ignoreVersion   -o $Lit_filename; //-typ "mayaAscii"  
                      }
                      else
                      {
                      string $Lit_filename = $AssetsFile_C3_son+$waffle_List[$i];
                      file -f  -ignoreVersion   -o $Lit_filename;                      
                      }
                  croffle_Rule(1);
                  textField -e -tx  "The Assets has been opened."  waffle_msg_2;
                  }     
      break;   
  
      case 4 : 
               //Reference     
              string $waffle_List_Case4[] = `textScrollList -q -si waffle_Assets_List_1`;

              
                  for ($i=0; $i<size($waffle_List_Case4); $i++)
                  {
                      if($note_infos_Assets == 0)       
                      {                  
                      string $Lit_filename = $AssetsFile_C3+$waffle_List_Case4[$i];
                      $getName = stringToStringArray($waffle_List_Case4[$i], ".");
                      $AssetName = $SubFolder;                                           
                        if ($valueRefname == 1)
                        {
                        file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $AssetName -options "v=0" $Lit_filename; 
                        }
                        else
                        file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                      }
                      else
                      {
                      string $Lit_filename = $AssetsFile_C3_son+$waffle_List_Case4[$i];
                      $getName = stringToStringArray($waffle_List_Case4[$i], ".");
                      $AssetName = $SonFolder; 
                        if ($valueRefname == 1)
                        {                      
                        file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $AssetName -options "v=0" $Lit_filename; 
                        }
                        else
                        file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                      } 
                  }                         
                  croffle_Rule(1);
                    
      break;  
                    
 

      case 41 :              
              //Import
              string $waffle_List_Case41[] = `textScrollList -q -si waffle_Assets_List_1`;

                  for ($i=0; $i<size($waffle_List_Case41); $i++)
                  {
                      if($note_infos_Assets == 0)
                      {                  
                      string $Assets_filename41 = $AssetsFile_C3 + $waffle_List_Case41[$i];                
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $Assets_filename41; //-typ "mayaAscii"
                      }
                      else
                      {
                      string $Assets_filename41 = $AssetsFile_C3_son + $waffle_List_Case41[$i];                
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $Assets_filename41; //-typ "mayaAscii"                      
                      }
                  }
                  croffle_Rule(1);
                    
      break;  


  }

}



//Make Folder

global proc waffle_MakeDir(int $case)
{
  $Curr_project = `workspace -q -fn`;
  $RootPath = stringToStringArray($Curr_project, "/");
  $project = $RootPath[0] + "\\" + $RootPath[1]+ "\\" + $RootPath[2];
      string $EPs_MakeDir=`optionMenu -q -v waffle_EP`;
      string $Path = $project+"\\02_Scenes\\03_Animation\\"  + "3_KEY" + "\\" + $EPs_MakeDir + "\\";  
      string $Path_EP = $project+"\\02_Scenes\\03_Animation\\"  + "3_KEY" + "\\";  
      
      string $waffle_folderName =`textField -q -tx waffle_MakeDir_FLD`;
  switch($case)
  {
    //Animation Folder
    case 1 :    
      string $dir_list[] = `getFileList -folder $Path -filespec "*.*"`;
      string $dir_list_sort[];
       $dir_list_sort=sort($dir_list);

        for ($i = 0; $i < size($dir_list_sort); $i++)
        {           

          string $AFile = $Path + $dir_list_sort[$i];
          $array_names = stringToStringArray($dir_list_sort[$i], "_");
          string $Tk1=$array_names[2];
          string $PathA = $Path + $Tk1;

          sysFile -makeDir $PathA;
          string $syscmd ="move "+$AFile+ " " + $PathA;
          system( $syscmd );
        }
        textField -e -tx  ""  waffle_msg_2;
    break;

    case 2 :    

          
          string $yo_PathB = $Path + $waffle_folderName;
          sysFile -makeDir $yo_PathB;
          catchQuiet(waffle_get_EPs(2));
          textField -e -tx  "Make Folder Completed."  waffle_msg_2;
          optionMenu -e -v $waffle_folderName waffle_CUT;
          catchQuiet(waffle_get_EPs(3));
     
    break;

    case 3 :    
          string $yo_PathC = $Path_EP + $waffle_folderName;
          sysFile -makeDir $yo_PathC;
          catchQuiet(waffle_get_EPs(1));
          optionMenu -e -v $waffle_folderName waffle_EP;
          catchQuiet(waffle_get_EPs(2));
     
    break;

        
  }
}


