global proc waffle_sort_PL()
{
waffle_get_PL(1);
}

global proc waffle_Set_PL()
{
    waffle_get_PL(2);waffle_reUI();
}

global proc waffle_get_PL(int $case)
{
    string $waffle_ProjectList = dirname(`pluginInfo -query -path "Croissants"`)+"/../scripts/_Project_List.ini";
    $yp_fileId = `fopen $waffle_ProjectList "r"` ;  
    string $yp_data = `fread $yp_fileId $yp_data` ; 

    //get all data
    string $yp_dataArray[] ;  
    $yp_dataArray = stringToStringArray($yp_data, ","); 


  switch($case)
  {
  
  case 1 :
    $menuItems_pr = `optionMenu -q -itemListLong waffle_PL`;
    if(size($menuItems_pr) != 0)
    {deleteUI($menuItems_pr);}
    
    string $pr_list_sort[];
    $pr_list_sort=sort($yp_dataArray);

    for ($i = 1; $i < size($pr_list_sort); $i++)
    {           
    menuItem -l $pr_list_sort[$i] -p waffle_PL;
    }
  break;
  
  case 2 :      
    string $ProjectName=`optionMenu -q -v waffle_PL`;  
    setProject $ProjectName;
  break; 
  
  }
}  


