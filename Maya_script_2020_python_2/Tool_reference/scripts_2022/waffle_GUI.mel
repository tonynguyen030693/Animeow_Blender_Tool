global proc waffle_Playblast()
{
  select -cl;
  //RS_HUD;
  _zShotMask_cmd(1);  
  string $wip_project = `workspace -q -fn`;
  string $wip_file_name =`file -q -sn -shn`;

  string $init[] = stringToStringArray($wip_file_name, ".");
  string $preEP[]= stringToStringArray($init[0], "_");

  int $eF =`intField -q -v waffle_A02_ef`; 
  int $sF =`intField -q -v waffle_A01_sf`; 

	string $dateDir = `date -shortDate`;
	string $arrayDir[];
	$arrayDir = stringToStringArray($dateDir, "/");
	string $arrayDirSort = $arrayDir[0]+$arrayDir[1];
  string $audio[] = `ls -type "audio"`;
  int $wiS = 1280;
  int $heS = 720;
  int $ckDate = `checkBox -q -v waffle_PBD`;   
  if($ckDate != 1)   
  {
    string $playblastPath = "04_Renderimages/_Previz/"+$preEP[1] ;

    int $checkFolder =`file -q -exists $playblastPath`;
    if($checkFolder != 0)
    {

    }
    else
    {
    sysFile -makeDir $playblastPath;
    }
    string $playblastFile_n = $init[0] + "." + $init[1] + ".mov";
    string $playblastFile = $playblastPath + "/" + $playblastFile_n;

    playblast  -format qt -sound $audio[0] -filename $playblastFile -forceOverwrite  -sequenceTime 0 -clearCache 1 -viewer 1 -showOrnaments 1 -fp 4 -percent 100 -compression "H.264" -quality 100 -widthHeight $wiS $heS;
    textField -e -tx  "complete."  waffle_msg_2;
  }
  else
  {
    string $playblastPath_D = "04_Renderimages/_Previz/"+$preEP[1] +"/"+ $arrayDirSort ;

    int $checkFolder =`file -q -exists $playblastPath_D`;
    if($checkFolder != 0)
    {

    }
    else
    {
    sysFile -makeDir $playblastPath_D;
    }
    string $playblastFile_n = $init[0] + "." + $init[1] + ".mov";
    string $playblastFile = $playblastPath_D + "/" + $playblastFile_n;

    playblast  -format qt -sound $audio[0] -filename $playblastFile -forceOverwrite  -sequenceTime 0 -clearCache 1 -viewer 1 -showOrnaments 1 -fp 4 -percent 100 -compression "H.264" -quality 100 -widthHeight $wiS $heS;
    textField -e -tx  "complete."  waffle_msg_2;  
  }
  //RS_HUD;
  select -cl;
  select -r _Shotmask ;
  doDelete;
}



global proc Publishing_AniF(int $case)
{  
	string $publish_dateDir = `date -shortDate`;
	string $publish_arrayDir[];
	$publish_arrayDir = stringToStringArray($publish_dateDir, "/");
	string $publish_arrayDirSort = $publish_arrayDir[0]+$publish_arrayDir[1];

  string $publish_UI ="waffle_Ani_List";
  string $publish_UI2 ="waffle_CUT";
  string $publish_project = `workspace -q -fn`;
  string $publish_EP=`optionMenu -q -v waffle_EP`;
  string $publish_CUT=`optionMenu -q -v waffle_CUT`;
  string $AniFile_Path = $publish_project + "/02_Scenes/03_Animation/"  + "3_KEY" + "/" + $publish_EP + "/" + $publish_CUT + "/";
  string $publish_Path = $publish_project + "/_publish/" + $publish_arrayDirSort + "/";


      switch($case)
      {
      case 1 :
      
         $response_publish = `confirmDialog -title "Confirm" 
                          -message "Collect Final Files?"
                          -button "Yes" 
                          -button "No"
                          -defaultButton "Yes"
                          -cancelButton "No"
                          -dismissString "No"`;
          
          // check response_publish	  
          if( $response_publish == "Yes" ) 
          {
              int $pcount =`optionMenu -q -ni $publish_UI2`;
              optionMenu -e -sl 1 $publish_UI2;
              string $checkC000 = `optionMenu -q -v $publish_UI2`;
              if($checkC000 == "C000")
              {
                waffle_Pageing(3);
                global string $gMainProgressBar; 
                
                  for ($i = 0; $i < $pcount; $i++)
                  {                           
                    
                    Publishing_AniF(2);
                    
                    progressBar -edit -beginProgress -isInterruptable true -status "Copy Ani Files ..." -maxValue $pcount $gMainProgressBar;
                    if(`progressBar -query -isCancelled $gMainProgressBar`)
                    break;                                                        
                    progressBar -edit -step 1 $gMainProgressBar;
                    waffle_Pageing(3);
                  }  
                  progressBar -edit -endProgress $gMainProgressBar; 
              }
              else
              {
              global string $gMainProgressBar; 
              
                for ($i = 0; $i < $pcount; $i++)
                {                           
                  
                  Publishing_AniF(2);
                  
                  progressBar -edit -beginProgress -isInterruptable true -status "Copy Ani Files ..." -maxValue $pcount $gMainProgressBar;
                  if(`progressBar -query -isCancelled $gMainProgressBar`)
                  break;                                                    
                  progressBar -edit -step 1 $gMainProgressBar;
                  waffle_Pageing(3);
                }  
              progressBar -edit -endProgress $gMainProgressBar;  
              }          
          }
          
          else if( $response_publish == "No" ) 
          {
            print("Cancel");
          }      
          textField -e -tx  "Collect Complete."  waffle_msg_2;
      break;
      
      case 2 :
              int $checkFolder =`file -q -exists $publish_Path`;
              if($checkFolder != 0)
              {
              }
              else
              {
                sysFile -makeDir $publish_Path;
              }

              int $waffle_aniList = `textScrollList -q -ni $publish_UI`;
                if($waffle_aniList == 0)
                {
                }
                else
                {
                    textScrollList -e -sii $waffle_aniList $publish_UI;
                    string $waffle_PSource[] = `textScrollList -q -si $publish_UI`;

                    for ($i=0; $i<size($waffle_PSource); $i++)
                    {
                    string $Publish_s = $AniFile_Path+$waffle_PSource[$i];
                    string $Publish_s_filename = substituteAllString($Publish_s, "/", "\\\\");
                    string $Publish_t = $publish_Path+$waffle_PSource[$i];
                    string $Publish_t_filename = substituteAllString($Publish_t, "/", "\\\\");
                    string $Publish_copy ="copy "+$Publish_s_filename+ " " + $Publish_t_filename +" /y";
                    system( $Publish_copy );
                    }
                }
            textField -e -tx  "Publish Complete.(project_Root\_publish)"  waffle_msg_2;
      break; 

      }       
}

