global proc waffle_OpenGetInfo(int $case)
{
    switch($case)
    {
        case 1 :
        waffle_get_EPs(2);waffle_get_EPs(3);waffle_get_EPs(4);waffle_get_EPs(5);waffle_get_EPs(6);
            
        break;
        
        case 2 :
        waffle_get_EPs(3);waffle_get_EPs(4);waffle_get_EPs(5);waffle_get_EPs(6);
            
        break;

    }
        
}


global proc waffle_Filter(int $case)
{
      string $N_Filter=`textField -q -tx waffle_Filter`;
      
      switch($case)
      {
      case 1 :
        string $Filter_Conw1 = $N_Filter+"*";
        textField -e -tx $Filter_Conw1 waffle_Filter;
        waffle_get_EPs(1);        
      break;

      case 2 :
        string $Filter_Conw2 = $N_Filter+"*";
        textField -e -tx $Filter_Conw2 waffle_Filter;
        waffle_get_EPs(2);
      break;
      }

}      



global proc waffle_get_EPs(int $case)
{
$Curr_project = `workspace -q -fn`;
$RootPath = stringToStringArray($Curr_project, "/");
$project = $RootPath[0] + "\\" + $RootPath[1] + "\\" + $RootPath[2];
    string $Path = $project + "\\02_Scenes\\03_Animation\\";
        string $EPs_3=`optionMenu -q -v waffle_EP`;
        string $CUTs_3=`optionMenu -q -v waffle_CUT`;    


string $wwFilter=`textField -q -tx waffle_Filter`; 
    
  switch($case)
  {
      case 1 :
        string $Token_Ani =  $Path + "3_KEY" + "\\";    
        $menuItems = `optionMenu -q -itemListLong waffle_EP`;
        if(size($menuItems) != 0)
        {deleteUI($menuItems);}
        string $dir_list[] = `getFileList -folder $Token_Ani -filespec $wwFilter`;
        string $dir_list_sort[];
        $dir_list_sort=sort($dir_list);

        for ($i = 0; $i < size($dir_list_sort); $i++)
        {           
        menuItem -l $dir_list_sort[$i] -p waffle_EP;
        }
      break;

      case 2 :
        string $EPs_2=`optionMenu -q -v waffle_EP`;
        $menuItems = `optionMenu -q -itemListLong waffle_CUT`;
        if(size($menuItems) != 0)
        {deleteUI($menuItems);}
        string $token = $Path + "3_KEY" + "\\" + $EPs_2 + "\\";
        string $dir_list_sub[] = `getFileList -folder $token -filespec $wwFilter`;
        string $subdirectories[];
            string $dir_list_sort_sub[];
            $dir_list_sort_sub=sort($dir_list_sub);
        
        for ($i = 0; $i < size($dir_list_sort_sub); $i++)
        {           
        menuItem -l $dir_list_sort_sub[$i] -p waffle_CUT;
        }  
      break;

      case 3 :        
        //Get Ani
        string $tokenA = $Path + "3_KEY" + "\\" + $EPs_3 + "\\" + $CUTs_3 + "\\";
        string $dir_list_subA[] = `getFileList -folder $tokenA -filespec "*.m*"`;        
        
        string $dir_list_sort_subA[];
        $dir_list_sort_subA=sort($dir_list_subA);
        
        textScrollList -edit -removeAll waffle_Ani_List;
        for ($i = 0; $i < size($dir_list_sort_subA); $i++)
        {           
        textScrollList   -ams 1 -sc "catchQuiet(waffle_UI_dc_CC(1));" -dcc "OPEN_waffle_files(1);" -e -a $dir_list_sort_subA[$i] waffle_Ani_List;
        }  
      break;  

      case 4 :        
        //Get Layout
        string $tokenA_L = $Path + "3_KEY" + "\\" + $EPs_3 + "\\" + $CUTs_3 + "\\_ALY\\";
        string $dir_list_subA_L[] = `getFileList -folder $tokenA_L -filespec "*.m*"`;        
        
        string $dir_list_sort_subA_L[];
        $dir_list_sort_subA_L=sort($dir_list_subA_L);
        
        textScrollList -edit -removeAll waffle_Ani_List_2;
        for ($i = 0; $i < size($dir_list_sort_subA_L); $i++)
        {           
        textScrollList   -ams 1 -sc "catchQuiet(waffle_UI_dc_CC(2));" -dcc "OPEN_waffle_files(12);" -e -a $dir_list_sort_subA_L[$i] waffle_Ani_List_2;
        }  
      break;

      case 5 :        
        //Get Layout
        string $tokenA_B = $Path + "3_KEY" + "\\" + $EPs_3 + "\\" + $CUTs_3 + "\\_BLK\\";
        string $dir_list_subA_B[] = `getFileList -folder $tokenA_B -filespec "*.m*"`;        
        
        string $dir_list_sort_subA_B[];
        $dir_list_sort_subA_B=sort($dir_list_subA_B);
        
        textScrollList -edit -removeAll waffle_Ani_List_3;
        for ($i = 0; $i < size($dir_list_sort_subA_B); $i++)
        {           
        textScrollList   -ams 1 -sc "catchQuiet(waffle_UI_dc_CC(3));" -dcc "OPEN_waffle_files(13);" -e -a $dir_list_sort_subA_B[$i] waffle_Ani_List_3;
        }  
      break;

      case 6 :        
        //Get Layout
        string $tokenA_D = $Path + "3_KEY" + "\\" + $EPs_3 + "\\" + $CUTs_3 + "\\_DTL\\";
        string $dir_list_subA_D[] = `getFileList -folder $tokenA_D -filespec "*.m*"`;        
        
        string $dir_list_sort_subA_D[];
        $dir_list_sort_subA_D=sort($dir_list_subA_D);
        
        textScrollList -edit -removeAll waffle_Ani_List_4;
        for ($i = 0; $i < size($dir_list_sort_subA_D); $i++)
