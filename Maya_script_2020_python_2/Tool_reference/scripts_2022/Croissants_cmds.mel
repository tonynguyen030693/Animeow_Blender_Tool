        break;
  
    }

}  
global proc Croi_Thumbs_HUD(int $case)
{
    switch($case)
    {
    case 1 :
        setObjectDetailsVisibility(!`optionVar -ex objectDetailsVisibility`);
        headsUpDisplay -e -vis 0 HUDViewAxis;
        headsUpDisplay -e -vis 0 HUDCurrentFrame;
        headsUpDisplay -e -vis 0 HUDCameraNames;   
        int $block0 = `headsUpDisplay -nextFreeBlock 0`;
        headsUpDisplay -section 0 -block $block0 -label "scInfo : " -attachToRefresh -dataFontSize "large" -labelFontSize "large" -command "Croi_Thumbs_HUD_CMD" Croi_Thumbs_HUD_UI;		
    break;
    
    case 2 :
        headsUpDisplay -rem Croi_Thumbs_HUD_UI;
        headsUpDisplay -e -vis 1 HUDViewAxis;
        headsUpDisplay -e -vis 0 HUDCurrentFrame;
        headsUpDisplay -e -vis 1 HUDCameraNames;   
              
    break;    
    }
}

global proc string Croi_Thumbs_HUD_CMD()
{
    string $filename = `file -q -sceneName -shortName`; 
    string $date = `about -currentDate`;
    string $infoA = $filename +" ( " +$date+" ) ";
    return $infoA;
}


global proc Croi_Mill_Note()
{
    string $G_Croi_Scenes_04=`textField -q -tx croissants_TokenJ`;

    string $MIll_loc = (`Croi_C_workspace`) +"/" + $G_Croi_Scenes_04 + "/" + (`Croi_MOD_Root`) + "/" + (`Croi_MOD_Sub`) + "/";
    string $MIll_stuff = $MIll_loc + (`Croi_MOD_Name`) + "/";
