          {
            print("ČŢ~~~ ^^;\n");
          }
        break;

        case 6 :     
          $response = `confirmDialog -title "Confirm" 
                          -message "ŔĚ żˇĽÂŔş żĎŔüČ÷ ÁöżöÁý´Ď´Ů."
                          -button "Yes" 
