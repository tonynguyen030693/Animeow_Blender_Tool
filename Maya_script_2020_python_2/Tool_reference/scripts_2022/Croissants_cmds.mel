          if($note_infos_Mod == 0)
          {
           Get_Croissants_MOD_List(3);Get_Croissants_MOD_List(8); 
          }
          else
          {
          Get_Croissants_MOD_List(21);Get_Croissants_MOD_List(31);Get_Croissants_MOD_List(8); 
          }       
    break;
    
    case 3 :

          Get_Croissants_MOD_List(31);Get_Croissants_MOD_List(8);Croi_Mill_Note();catchQuiet(Croi_Thumbs(2));
      
    break;  
    case 4 :
          if($note_infos_Mod == 0)
          {
           Get_Croissants_MOD_List(1);Get_Croissants_MOD_List(2);Get_Croissants_MOD_List(3);Get_Croissants_MOD_List(8); 
          }
          else
          {
          Get_Croissants_MOD_List(1);Get_Croissants_MOD_List(2);Get_Croissants_MOD_List(21);Get_Croissants_MOD_List(31);Get_Croissants_MOD_List(8); 
          }       
    break;      
    
    }
  
  }
  

  
  global proc Get_Croissants_MOD_List(int $case)
  {
    string $G_Croi_C_WS =`Croi_C_workspace`;
    string $G_Croi_Root=`Croi_Root`;
    string $G_Croi_Sub=`Croi_Sub`;    
    string $G_Croi_Scenes_01=`textField -q -tx croissants_TokenD`;
    string $G_Croi_Scenes_04=`textField -q -tx croissants_TokenJ`;

    //Modeling Path
    string $Path_Mod = $G_Croi_C_WS + "/" + $G_Croi_Scenes_04 + "/";

    //Asset_Path
    string $Path_AssetM = $G_Croi_C_WS + "/" + (`textField -q -tx croissants_TokenI`) + "/";    
    int $note_infos_ = `checkBox -q -v Episodic`; 

    
    string $Mod_case3 = $Path_Mod + (`Croi_MOD_Root`) + "/" + (`Croi_MOD_Sub`) + "/";
    string $Mod_case3Path = $Mod_case3 + (`Croi_MOD_Name`) + "/";
    string $Mod_case3Path_Crosswalk = $Mod_case3Path +"_Crosswalk";
    string $Mod_case3Path_His = $Mod_case3Path +"_His";


    string $PUBType_A=`optionMenu -q -v Croissants_PUBType_A`;
    string $PUBType_B=`optionMenu -q -v Croissants_PUBType_B`;   

    string $MD_Filter=`textField -q -tx Croissants_Filter_MOd`;  
    
    string $Modlog = $Mod_case3 + (`Croi_MOD_Name`) + "/" +(`Croi_MOD_Name`)+".log";  
      
    switch($case)
      {

          case 1 :            
                  $menuItems = `optionMenu -q -itemListLong Croissants_MOD`;
                  if(size($menuItems) != 0)
                  {deleteUI($menuItems);}
                  string $dir_list[] = `getFileList -folder $Path_Mod -filespec "*"`;
                  string $dir_list_sort[];
                  $dir_list_sort=sort($dir_list);

                  for ($i = 0; $i < size($dir_list_sort); $i++)
                  {           
                  menuItem -l $dir_list_sort[$i] -p Croissants_MOD;
                  }
          break;

          case 2 :
                $Mod_menuItems_sub = `optionMenu -q -itemListLong Croissants_MOD_2`;
                if(size($Mod_menuItems_sub) != 0)
                {deleteUI($Mod_menuItems_sub);} 
                
                string $Mod_omA=`optionMenu -q -v Croissants_MOD`;
                //string $Mod_omB=`optionMenu -q -v Croissants_MOD_2`;
                string $Mod_case2Path = $Path_Mod + $Mod_omA + "/";
                       
                string $Mod_dir_list_sub[] = `getFileList -folder $Mod_case2Path -filespec $MD_Filter`;
                      if (size($Mod_dir_list_sub) == 0)
                      {
                        print "There are no assets.";
                        textScrollList -edit -removeAll Croissants_Model_List_1;
                      }
                      else                
                      {
                        string $Mod_dir_list_sort_sub[];
                        $Mod_dir_list_sort_sub=sort($Mod_dir_list_sub);                
                        for ($i = 0; $i < size($Mod_dir_list_sort_sub); $i++)
                        {           
                          menuItem -l $Mod_dir_list_sort_sub[$i] -p Croissants_MOD_2;
                        }
                      }
                                                  
          break; 
                
          case 21 :
                $Mod_menuItems_son = `optionMenu -q -itemListLong Croissants_MOD_3`;
                if(size($Mod_menuItems_son) != 0)
                {deleteUI($Mod_menuItems_son);} 

                string $Mod_omA_son=`optionMenu -q -v Croissants_MOD`;
                string $Mod_omB_son=`optionMenu -q -v Croissants_MOD_2`;
                string $Mod_case21Path = $Path_Mod + $Mod_omA_son + "/" + $Mod_omB_son + "/";
                       
                string $Mod_dir_list_son[] = `getFileList -folder $Mod_case21Path -filespec $MD_Filter`;
                      if (size($Mod_dir_list_son) == 0)
                      {
                        print "There are no assets.";
                        textScrollList -edit -removeAll Croissants_Model_List_1;
                      }
                      else                
                      {                
                        string $Mod_dir_list_sort_son[];
                        $Mod_dir_list_sort_son=sort($Mod_dir_list_son);
                    
                        for ($i = 0; $i < size($Mod_dir_list_sort_son); $i++)
                        {           
                        menuItem -l $Mod_dir_list_sort_son[$i] -p Croissants_MOD_3;
                        } 
                      }  
          break;  

      case 3 :          
                string $Mod_dir_list_subA[] = `getFileList -folder $Mod_case3 -filespec "*.m*"`;              
                if(size($Mod_dir_list_subA) == 0)       
                {
                  print "There are no Modeling Files.";
                  textScrollList -edit -removeAll Croissants_Model_List_1;
                }
                else
                {
                        string $Mod_dir_list_sort_subA[];
                        $Mod_dir_list_sort_subA=sort($Mod_dir_list_subA);        
                        textScrollList -edit -removeAll Croissants_Model_List_1;
                        for ($i = 0; $i < size($Mod_dir_list_sort_subA); $i++)
                        {           
                        textScrollList   -ams 0 -sc "" -dcc "OPEN_Croissants_files(6);" -e -a $Mod_dir_list_sort_subA[$i] Croissants_Model_List_1;
                        }  
            
                        //remove .mayaSwatches Model List
                        int $checkCount =`textScrollList -q -ni Croissants_Model_List_1`;
                        if ($checkCount == 0){print "";}
                        else
                        {
                        textScrollList -e -sii 1 Croissants_Model_List_1;
                        string $mayaSwatchesX[] =`textScrollList -q -si Croissants_Model_List_1`;
                            if ($mayaSwatchesX[0] != ".mayaSwatches")
                            {
                                print "noSwatche \n";
                            }
                            else
                            textScrollList -e -rii 1  Croissants_Model_List_1; 
                        } 
                    //Get _Crosswalk
                    string $Mod_dir_list_Model_subA[] = `getFileList -folder $Mod_case3Path_Crosswalk -filespec "*.*"`;            
                    string $dir_list_sort_Model_subA[];
                    $dir_list_sort_Model_subA=sort($Mod_dir_list_Model_subA);
                    textScrollList -edit -removeAll Croissants_Model_List_2;
                        for ($i = 0; $i < size($dir_list_sort_Model_subA); $i++)
                        {           
                        textScrollList   -ams 0 -sc "" -dcc "" -e -a $dir_list_sort_Model_subA[$i] Croissants_Model_List_2;
                        }                           
                    }        
        break;     
                       
      case 31 :          
                string $Mod_dir_list_subA_son[] = `getFileList -folder $Mod_case3Path -filespec "*.m*"`;                
                if(size($Mod_dir_list_subA_son) == 0)       
                {
                  print "There are no Modeling Files.";
                  textScrollList -edit -removeAll Croissants_Model_List_1;
                }
                else
                {                        
                      string $Mod_dir_list_sort_subA_son[];
                      $Mod_dir_list_sort_subA_son=sort($Mod_dir_list_subA_son);        
                      textScrollList -edit -removeAll Croissants_Model_List_1;
                      for ($i = 0; $i < size($Mod_dir_list_sort_subA_son); $i++)
                      {           
                      textScrollList   -ams 1 -sc "" -dcc "OPEN_Croissants_files(6);" -e -a $Mod_dir_list_sort_subA_son[$i] Croissants_Model_List_1;
                      }  
          
                        //remove .mayaSwatches Model List
                        int $checkCount31 =`textScrollList -q -ni Croissants_Model_List_1`;
                        if ($checkCount31 == 0){print "";}
                        else
                        {
                        textScrollList -e -sii 1 Croissants_Model_List_1;
                        string $mayaSwatchesX[] =`textScrollList -q -si Croissants_Model_List_1`;
                            if ($mayaSwatchesX[0] != ".mayaSwatches")
                            {
                                print "noSwatche \n";
                            }
                            else
                            textScrollList -e -rii 1  Croissants_Model_List_1; 
                        }    
               }
               
              //Get _Crosswalk
              string $Mod_dir_list_Model_subA[] = `getFileList -folder $Mod_case3Path_Crosswalk -filespec "*.*"`;            
              string $dir_list_sort_Model_subA[];
              $dir_list_sort_Model_subA=sort($Mod_dir_list_Model_subA);
              textScrollList -edit -removeAll Croissants_Model_List_2;
                  for ($i = 0; $i < size($dir_list_sort_Model_subA); $i++)
                  {           
                  textScrollList   -ams 0 -sc "" -dcc "" -e -a $dir_list_sort_Model_subA[$i] Croissants_Model_List_2;
                  }

              //Get _History
              string $Mod_dir_list_Model_His[] = `getFileList -folder $Mod_case3Path_His -filespec "*.*"`;            
              string $dir_list_sort_Model_His[];
              $dir_list_sort_Model_His=sort($Mod_dir_list_Model_His);
              textScrollList -edit -removeAll Croissants_Model_List_3;
                  for ($i = 0; $i < size($dir_list_sort_Model_His); $i++)
                  {           
                  textScrollList   -ams 0 -sc "" -dcc "OPEN_Croissants_files(61);" -e -a $dir_list_sort_Model_His[$i] Croissants_Model_List_3;
                  }               
        break;  
        
        
        case 32 :
                    string $selObjects[] = `ls -sl`;
                    //string $getObjectN = $selObjects[0];
                    //textField -e -tx $getObjectN MakeDir_Mod;
                    string $AssetsType=`optionMenu -q -v Croissants_MOD_Type`;

                    if($note_infos_ == 0)
                    {              
                        string $AssetsPath = $Path_AssetM + $AssetsType + "/";
                        string $AssetsName = `Croi_MOD_Name`; 
                        string $Croissants_aDM_Path =  $AssetsPath + $AssetsName ;
                        string $Croissants_aTX_Path =  $AssetsPath + $AssetsName +"/tex";
                        string $Croissants_aDM_Token =  $Croissants_aDM_Path +"/" +$AssetsName+ $PUBType_A+$PUBType_B;
                        
                        sysFile -makeDir $Croissants_aDM_Path;
                        sysFile -makeDir $Croissants_aTX_Path;


                          if($PUBType_B == ".mb")
                          {
                            string $exportType="mayaBinary";
                            //$EXselection =`rename $AssetsName "CH_SET"`;
                            
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_aDM_Token;
                          }
                          else if($PUBType_B == ".ma")
                          {
                            string $exportType="mayaAscii";
                            //$EXselection =`rename $AssetsName "CH_SET"`;
                            
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_aDM_Token;                           
                          }
                        

                        
                        Croissants_assets_OM(4);
                        Croissants_assets_OM(1);
                        optionMenu -e -v $AssetsType Croissants_Assets;
                        Croissants_assets_OM(2);
                        optionMenu -e -v $AssetsName Croissants_Assets_2;
                        Croissants_assets_OM(3);
                    }
                    else
                    {
                        string $AssetsPath_ep = $Path_AssetM + $AssetsType + "/";
                        string $AssetsName_ep = `Croi_MOD_Name`;
                        string $Episod=toupper(strip(`textField -q -tx MakeDir_Epi`)); 
                        string $Croissants_eDM_Path =  $AssetsPath_ep + $Episod +"/"+ $AssetsName_ep ;
                        string $Croissants_eTX_Path =  $AssetsPath_ep + $Episod +"/"+ $AssetsName_ep +"/tex";
                        string $Croissants_eDM_Token =  $Croissants_eDM_Path +"/" +$AssetsName_ep+ $PUBType_A+$PUBType_B;
                        
                        sysFile -makeDir $Croissants_eDM_Path;
                        sysFile -makeDir $Croissants_eTX_Path;
                        
                        //string $NN =$AssetsType+"_SET";
                        //$EXselection2 =`rename $AssetsName_ep $NN`;


                          if($PUBType_B == ".mb")
                          {
                            string $exportType="mayaBinary";
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_eDM_Token;
                          }
                          else if($PUBType_B == ".ma")
                          {
                            string $exportType="mayaAscii";
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_eDM_Token;
                          }


                        

                        Croissants_assets_OM(4);
                        Croissants_assets_OM(1);
                        optionMenu -e -v $AssetsType Croissants_Assets;
                        Croissants_assets_OM(1);
                        Croissants_assets_OM(2);
                        optionMenu -e -v $Episod Croissants_Assets_2;
                        Croissants_assets_OM(3);                    
                        optionMenu -e -v $AssetsName_ep Croissants_Assets_3;
                        Croissants_assets_OM(3);  
                        
                    }
                    confirmDialog -title "Confirm Window" -message "Export Complete" -button "OK" -defaultButton "OK";
            break;
            case 33 :
                    string $selObjects32[] = `ls -sl`;
                    string $getObjectN32 = $selObjects32[0];
                    textField -e -tx $getObjectN32 MakeDir_Mod;
                    string $ModType=`optionMenu -q -v Croissants_MOD_Type`;

                    if($note_infos_ == 0)
                    {                       
                        string $Mod_Path2 = $Path_Mod + $ModType + "/";
                        string $Mod_Name = `textField -q -tx MakeDir_Mod`; 
                        string $Croissants_DM_Path =  $Mod_Path2 + $Mod_Name ;
                        string $Croissants_TX_Path =  $Mod_Path2 + $Mod_Name +"/tex";
                        string $Croissants_DM_Token =  $Croissants_DM_Path +"/" +$Mod_Name+ "_MOD.0001"+$PUBType_B;
                        
                        sysFile -makeDir $Croissants_DM_Path;
                        sysFile -makeDir $Croissants_TX_Path;
                                            
                        $EXselectionM1 =`rename $Mod_Name "CH_SET"`;
                        
                          if($PUBType_B == ".mb")
                          {
                            $exportType="mayaBinary";
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_DM_Token;
                          }
                          else if($PUBType_B == ".ma")
                          {
                            $exportType="mayaAscii";
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_DM_Token;
                          }                        

                        
                        Croissants_Mod_OM(4);
                        Croissants_Mod_OM(1);
                        optionMenu -e -v $ModType Croissants_MOD;
                        Croissants_Mod_OM(2);
                        optionMenu -e -v $Mod_Name Croissants_MOD_2;
                        Croissants_Mod_OM(3);
                        Croissants_Mod_OM(3);
                    }
                    else
                    {
                        string $Mod_Path2 = $Path_Mod + $ModType + "/";
                        string $Mod_Name = `textField -q -tx MakeDir_Mod`; 
                        string $Mod_Episod=toupper(strip(`textField -q -tx MakeDir_Epi`)); 
                        string $Croissants_DM_Path =  $Mod_Path2 + $Mod_Episod + "/"+ $Mod_Name ;
                        string $Croissants_TX_Path =  $Mod_Path2 + $Mod_Episod + "/"+ $Mod_Name +"/tex";
                        string $Croissants_Zbrush_Path =  $Mod_Path2 + $Mod_Episod + "/"+ $Mod_Name +"/_Sculpting";
                        string $Croissants_Substance_Path =  $Mod_Path2 + $Mod_Episod + "/"+ $Mod_Name +"/_Painting";
                        string $Croissants_Alembic_Path =  $Mod_Path2 + $Mod_Episod + "/"+ $Mod_Name +"/_Crosswalk";
                        string $Croissants_DM_Token =  $Croissants_DM_Path +"/" +$Mod_Name+ "_MOD.0001"+$PUBType_B;
                        
                        sysFile -makeDir $Croissants_DM_Path;
                        sysFile -makeDir $Croissants_TX_Path;
                        sysFile -makeDir $Croissants_Zbrush_Path;
                        sysFile -makeDir $Croissants_Substance_Path;
                        sysFile -makeDir $Croissants_Alembic_Path;

                        string $NNm =$ModType+"_SET";                        
                        $EXselectionM2 =`rename $Mod_Name $NNm`;

                          if($PUBType_B == ".mb")
                          {
                            $exportType="mayaBinary";
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_DM_Token;
                          }
                          else if($PUBType_B == ".ma")
                          {
                            $exportType="mayaAscii";
                            file -force -options "v=0;" -typ $exportType -pr -es $Croissants_DM_Token;
                          }

                        
                        Croissants_Mod_OM(4);
                        Croissants_Mod_OM(1);
                        optionMenu -e -v $ModType Croissants_MOD;
                        Croissants_Mod_OM(1);
                        Croissants_Mod_OM(2);
                        optionMenu -e -v $Mod_Episod Croissants_MOD_2;
                        Croissants_Mod_OM(3);
                        optionMenu -e -v $Mod_Name Croissants_MOD_3;       
                        Croissants_Mod_OM(3);                
                    }
                   confirmDialog -title "Confirm Window" -message "Export Complete" -button "OK" -defaultButton "OK";
            break;      
              
            //make Modeling History  
            case 4 : 
            string $Croissants_MOD_his[] = `textScrollList -q -si Croissants_Model_List_1`;
                for ($i=0; $i<size($Croissants_MOD_his); $i++)
                {
                  string $MOD_filename_his = $Mod_case3Path+$Croissants_MOD_his[$i];
                  sysFile -makeDir $Mod_case3Path_His;
                  string $syscmd ="move "+$MOD_filename_his+ " " + $Mod_case3Path_His;
                  string $syscmd_win = substituteAllString($syscmd, "/", "\\\\"); 
                  system( $syscmd_win );
                }
            Get_Croissants_MOD_List(31);           

           break;    
            
           case 5 :     
              $response = `confirmDialog -title "Confirm" 
                              -message "ÁřÂĄ·Î ĆÄŔĎŔ» Áöżď°Ç°ˇżä?"
                              -button "Yes" 
                              -button "No"
                              -defaultButton "Yes"
                              -cancelButton "No"
                              -dismissString "No"`;
              
              // check response	  
              if( $response == "Yes" ) 
              {
                  string $Croissants_Del_Mod[] = `textScrollList -q -si Croissants_Model_List_1`;

            string $Mod_omA_5=`optionMenu -q -v Croissants_MOD`;
            string $Mod_omB_5=`optionMenu -q -v Croissants_MOD_2`;
            string $Mod_omC_5=`optionMenu -q -v Croissants_MOD_3`;
            string $Mod_case5Path = $Path_Mod + $Mod_omA_5 + "/" + $Mod_omB_5 + "/" + $Mod_omC_5 + "/";


                      for ($i=0; $i<size($Croissants_Del_Mod); $i++)
                      {
                      string $Croissants_Del_Mod_filename = $Mod_case5Path+$Croissants_Del_Mod[$i];
                      sysFile -delete $Croissants_Del_Mod_filename;    

                      }
                  Get_Croissants_MOD_List(3);
                  print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
              } 
              else if( $response == "No" ) 
              {
                print("ČŢ~~~ ^^;\n");
              }
            break;
           case 6 :     
              $response = `confirmDialog -title "Confirm" 
                              -message "ÁřÂĄ·Î ĆÄŔĎŔ» Áöżď°Ç°ˇżä?"
                              -button "Yes" 
                              -button "No"
                              -defaultButton "Yes"
                              -cancelButton "No"
                              -dismissString "No"`;
              
              // check response	  
              if( $response == "Yes" ) 
              {

            string $Mod_omA_5=`optionMenu -q -v Croissants_MOD`;
            string $Mod_omB_5=`optionMenu -q -v Croissants_MOD_2`;
            string $Mod_case5Path = $Path_Mod + $Mod_omA_5 + "/" + $Mod_omB_5 + "/";
            string $Mod_case5Path_His = $Path_Mod + $Mod_omA_5 + "/" + $Mod_omB_5 + "/His";
              
                  string $Croissants_Del_Mod_His[] = `textScrollList -q -si Croissants_Mod_List_His`;

                      for ($i=0; $i<size($Croissants_Del_Mod_His); $i++)
                      {
                      string $Croissants_Del_Mod_His_filename = $Mod_case5Path_His+$Croissants_Del_Mod_His[$i];
                      sysFile -delete $Croissants_Del_Mod_His_filename;    

                      }
                  Get_Croissants_MOD_List(3);
                  print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
              } 
              else if( $response == "No" ) 
              {
                print("ČŢ~~~ ^^;\n");
              }
            break;   
                                  
                                  
           case 7 :
              //Write Note
              string $q_Croi_Modlog =`scrollField -q -tx Croissants_Model_List_4`;  
              string $ModlogStats = $q_Croi_Modlog+"\n"+`date`;
              $fileId=`fopen $Modlog "w"`;
              fprint $fileId $ModlogStats;
              fclose $fileId;   
              Get_Croissants_MOD_List(8);
              Croissants_Mod_OM(3);  
            break;  
                                         
            case 8 :
              string $Modlog_File=(`Croi_MOD_Name`)+".log";                                                          
              string $Modlog_list[] = `getFileList -folder $Mod_case3Path -filespec $Modlog_File`;
              if (size($Modlog_list) != 0)
              {
                $fileId_log = `fopen $Modlog "r"` ;  
                string $data = `fread $fileId_log $data` ; 
                fclose $fileId_log;     
                scrollField -e -tx $data Croissants_Model_List_4; 
              } 
              else  scrollField -e -tx "" Croissants_Model_List_4;    
            break;

       }
 }
 
