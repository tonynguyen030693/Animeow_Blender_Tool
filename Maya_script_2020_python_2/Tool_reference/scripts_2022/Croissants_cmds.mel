}

global proc Croissants_Pageing(int $num)
{
    switch($num)
    {
      //next
      case 1:
          $cur=`optionMenu -q  -sl Croissants_EP`;
          int $choo_1 = $cur + 1;
          $_limited_E=`optionMenu -q  -ni Croissants_EP`;
          if($choo_1 > $_limited_E)
          {   
            print "No more...";
          }
          else
          {          
          optionMenu -e  -sl $choo_1 Croissants_EP; UI_ReFrash_CC(1);
          Croissants_get_EPs(2);
          }
      
      break;

      //back
      case 2:
          $cur=`optionMenu -q  -sl Croissants_EP`;
          int $choo_2 = $cur - 1;
          if($choo_2 < 1)
          {   
            print "No more...";
          }
          else   
          {       
          optionMenu -e  -sl $choo_2 Croissants_EP; UI_ReFrash_CC(1);
          Croissants_get_EPs(2);
          }
          
      break;

      //next
      case 3:
          $cur=`optionMenu -q  -sl Croissants_CUT`;
          int $choo_3 = $cur + 1;
          $_limited=`optionMenu -q  -ni Croissants_CUT`;
          if($choo_3 > $_limited)
          {   
            print "No more...";
          }
          else
          {
            optionMenu -e  -sl $choo_3 Croissants_CUT;UI_ReFrash_CC(1);Croissants_logStats(2);Croissants_logStats(4);catchQuiet(Croissants_logStats(92)); 
          }
      break;

      //back
      case 4:
          $cur=`optionMenu -q  -sl Croissants_CUT`;
          int $choo_4 = $cur - 1;          
          if($choo_4 < 1)
          {   
            print "No more...";
          }
          else
          {
            optionMenu -e  -sl $choo_4 Croissants_CUT;UI_ReFrash_CC(1);Croissants_logStats(2);Croissants_logStats(4);catchQuiet(Croissants_logStats(92)); 
          }
      break;
    }
}
  

