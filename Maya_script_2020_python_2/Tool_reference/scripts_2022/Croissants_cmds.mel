                        }
                 }              
        break;  
  

//Get LookDev Pub file //line1246
      case 33 :
                string $LookdevPub = $Path_Assets +"/"+ (`Croi_Assets_Root`) + "/" + (`Croi_Assets_Sub`) + "/"+ (`Croi_Assets_Name`) + "/pub/";
            
                string $dir_list_pubList[] = `getFileList -folder $LookdevPub -filespec "*.m*"`;        

                if(size($dir_list_pubList) == 0)
                {
                    print "There are no assets.";
                    textScrollList -edit -removeAll Croissants_LookDevPub_List;
                }
                else
                {
                    string $dir_list_pubList_sort[];
                    $dir_list_pubList_sort=sort($dir_list_pubList);        
                    textScrollList -edit -removeAll Croissants_LookDevPub_List;
                    for ($i = 0; $i < size($dir_list_pubList_sort); $i++)
                    {           
                    textScrollList   -ams 0 -sc "" -dcc "OPEN_Croissants_files(33);" -e -a $dir_list_pubList_sort[$i] Croissants_LookDevPub_List;
                    }  
        
                    //remove .mayaSwatches Assets List
                    int $checkCount33 =`textScrollList -q -ni Croissants_LookDevPub_List`;
                    if ($checkCount33 == 0){print "";}
                    else
                    {
                    textScrollList -e -sii 1 Croissants_LookDevPub_List;
                    string $mayaSwatchesX33[] =`textScrollList -q -si Croissants_LookDevPub_List`;
                        if ($mayaSwatchesX33[0] != ".mayaSwatches")
                        {
                            print "noSwatche \n";
                        }
                        else
                        textScrollList -e -rii 1  Croissants_LookDevPub_List; 
                    }          

                 }              
        break; 
  
        //make Assets History  
        case 4 :
        
            string $Croissants_Assets_His[] = `textScrollList -q -si Croissants_Assets_List_1`;
            for ($i=0; $i<size($Croissants_Assets_His); $i++)
            {
            string $Assets_filename = $AssetPath + $Croissants_Assets_His[$i]; 
            sysFile -makeDir $AssetPath_His;
            string $AHN = `textField -q -tx Croissants_AssetsHisV`;
                   $Assets_His_V = stringToStringArray($Croissants_Assets_His[$i], ".");
            string $Assets_filename_His = $AssetPath_His +"\\"+"_"+ $Assets_His_V[0] + "." + $AHN + "." + $Assets_His_V[2];
            string $syscmd_Assets ="copy "+$Assets_filename+ " " + $Assets_filename_His +" /y";
            system( $syscmd_Assets );
            }

            Get_Croissants_AssetsList(3);                    
       break;


        //Move
        case 41 :                          
            for ($i=0; $i<size($Croissants_Assets_son_His); $i++)
            {
            string $Assets_son_filename = $AssetPath_son + $Croissants_Assets_son_His[$i]; 
            sysFile -makeDir $AssetPath_son_His;
            string $AHN = `textField -q -tx Croissants_AssetsHisV`;
                   $Assets_son_His_V = stringToStringArray($Croissants_Assets_son_His[$i], ".");
                   int $checker = size($Assets_son_His_V[1]);                    
                   if($checker == 2)
                   {
                        string $Assets_son_filename_ver = "_"+ $Assets_son_His_V[0] + "." + $AHN + "." + $Assets_son_His_V[1];
                    
                        string $syscmd_Assets41 ="move "+$Assets_son_filename+ " " + $AssetPath_son_His;
                        string $syscmd_for_win = substituteAllString($syscmd_Assets41, "/", "\\");  
                        system( $syscmd_for_win);
                        
                        string $backup_set_ver ="ren "+$AssetPath_son_His+ "/" + $Croissants_Assets_son_His[$i] + " " + $Assets_son_filename_ver;
                        string $syscmd_for_win_2 = substituteAllString($backup_set_ver, "/", "\\");  
                        system( $syscmd_for_win_2);
                   }

                   else
                   {
                        string $Assets_son_filename_ver = "_"+ $Assets_son_His_V[0] + "." + $AHN + "." + $Assets_son_His_V[2];
                    
                        string $syscmd_Assets41 ="move "+$Assets_son_filename+ " " + $AssetPath_son_His;
                        string $syscmd_for_win = substituteAllString($syscmd_Assets41, "/", "\\");  
                        system( $syscmd_for_win);
                        
                        string $backup_set_ver ="ren "+$AssetPath_son_His+ "/" + $Croissants_Assets_son_His[$i] + " " + $Assets_son_filename_ver;
                        string $syscmd_for_win_2 = substituteAllString($backup_set_ver, "/", "\\");  
                        system( $syscmd_for_win_2);
                   }


             }
              Get_Croissants_AssetsList(3);                  
       break;
       
       //Copy
       case 42 :

            for ($i=0; $i<size($Croissants_Assets_son_His); $i++)
            {
            string $Assets_son_filename = $AssetPath_son + $Croissants_Assets_son_His[$i]; 
            sysFile -makeDir $AssetPath_son_His;
            string $AHN = `textField -q -tx Croissants_AssetsHisV`;
                   $Assets_son_His_V = stringToStringArray($Croissants_Assets_son_His[$i], ".");
                   int $checker = size($Assets_son_His_V[1]);                    
                   if($checker == 2)
                   {                   
                    string $Assets_son_filename_His = $AssetPath_son_His +"/"+"_"+ $Assets_son_His_V[0] + "." + $AHN + "." + $Assets_son_His_V[1];
                    string $syscmd_Assets41c ="copy "+$Assets_son_filename+ " " + $Assets_son_filename_His;
                    string $syscmd_cvt_41 = substituteAllString($syscmd_Assets41c, "/", "\\"); 
