global proc OpenGetInfo(int $case)
{
    switch($case)
    {
        case 1 :
        Croissants_get_EPs(2);Croissants_get_EPs(3);Croissants_get_EPs(4);Croissants_Check_Z_Source;
          
        break;
        
        case 2 :
        Croissants_get_EPs(3);Croissants_get_EPs(4);Get_Croissants_ABCList();Croissants_Check_Z_Source;
        Croissants_logStats(5);Croissants_logStats(6);
        Croissants_logStats(2);Croissants_logStats(4);    
        break;

    }
        
}

global proc Croissants_logStats(int $case)
{

  string $G_Croi_C_WS = `Croi_C_workspace`;
  string $G_Croi_Root=`Croi_Root`;
  string $G_Croi_Sub=`Croi_Sub`;
  string $G_Croi_log =`Croi_log`;
  string $G_Croi_note =`Croi_note`;

  string $G_Croi_Scenes_01=`textField -q -tx croissants_TokenD`;
  string $G_Croi_Scenes_03=`textField -q -tx croissants_TokenE`;

  string $Croi_log_path = $G_Croi_C_WS  + "/" + $G_Croi_Scenes_01 + "/" +$G_Croi_Scenes_03 + "/" + $G_Croi_Root + "/" + $G_Croi_Sub + "/.log";
  string $Croi_ABC_path = $G_Croi_C_WS  + "/" + $G_Croi_Scenes_01 + "/" +$G_Croi_Scenes_03 + "/" + $G_Croi_Root + "/" + $G_Croi_Sub + "/ABC";;

  string $wipStats_path = $Croi_log_path + "/wip.ini";
  string $wipNote_path = $Croi_log_path + "/note.ini";
  string $wipInfo_path = $Croi_log_path + "/info.txt";

  string $Increment = `intField -q -v Croissants_Increment_Tag`;
  string $wipInfo_path_Inc = $Croi_log_path + "/info_" + $Increment + ".txt";

  int $Croissants_pMin = `playbackOptions -q -min`;
  int $Croissants_pMax = `playbackOptions -q -max`;
  string $FPS =`currentUnit -q -time`;

  switch($case)
  {
    //log Write
    //////////////////////////////////////////////////////////////////////////////////////////////////
    case 1 :
              sysFile -makeDir $Croi_log_path;
              string $logStats = $G_Croi_log+"\n"+`date`;
              $fileId=`fopen $wipStats_path "w"`;
              fprint $fileId $logStats;
              fclose $fileId;   
              Croissants_logStats(5);    
    break;


    case 11 :  
              string $logStats11 = "ŔŰľ÷ ÁřÇŕ ÁßŔÔ´Ď´Ů.";
              scrollField -e -tx $logStats11  Croissants_log_textEdit; 
    break;

    case 12 : 
              string $logStats12 = "¸®Ĺ×ŔĚĹ© żäĂ»ŔĚ ŔÖ˝Ŕ´Ď´Ů.";
              scrollField -e -tx $logStats12 Croissants_log_textEdit; 
    break;

    case 13 :  
              string $logStats13 = "ŔŰľ÷ŔĚ żĎ·áµÇľú˝Ŕ´Ď´Ů.";
              scrollField -e -tx $logStats13 Croissants_log_textEdit; 
    break;
    
    case 14 :
              sysFile -delete $wipStats_path;
              Croissants_logStats(2);
              Croissants_logStats(5);
    break;
    
    case 15 :
              sysFile -delete $wipNote_path;
              Croissants_logStats(4);
              Croissants_logStats(6);
    break;
    
    //log Read
    //////////////////////////////////////////////////////////////////////////////////////////////////
    case 2 :    
              string $log_list[] = `getFileList -folder $Croi_log_path -filespec "wip.ini"`;
              if (size($log_list) != 0)
              {
                $fileId_log = `fopen $wipStats_path "r"` ;  
                string $data = `fread $fileId_log $data` ; 
                fclose $fileId_log;     
                scrollField -e -tx $data Croissants_log_textEdit; 
              } 
              else  scrollField -e -tx "" Croissants_log_textEdit;   

    break;


    //Note Write
    //////////////////////////////////////////////////////////////////////////////////////////////////
    case 3 :  
              Croissants_logStats(88);
              string $NoteStats = $G_Croi_note+"\n";
              $fileId_Note=`fopen $wipNote_path "w"`;
              fprint $fileId_Note $NoteStats;
              fclose $fileId_Note;   
              Croissants_logStats(6);//Sign Info     
    break;
    
    //Note Read
    //////////////////////////////////////////////////////////////////////////////////////////////////
    case 4 :
              string $Note_list[] = `getFileList -folder $Croi_log_path -filespec "note.ini"`;
              if (size($Note_list) != 0)
              {      
                $fileId_Note_R = `fopen $wipNote_path "r"` ;  
                string $data4 = `fread $fileId_Note_R $data4` ; 
                fclose $fileId_Note_R;     
                scrollField -e -tx $data4 Croissants_note_textEdit; 
              } 
              else scrollField -e -tx "" Croissants_note_textEdit;               
    break;


    case 5 :
            string $log_qrr[] = `getFileList -folder $Croi_log_path -filespec "wip.ini"`;
            if (size($log_qrr) != 0)
            {
              button -e -bgc 0.35 0.634 0.419 checkLog_Btt;
            } 
            else 
            {
              button -e -bgc 0.35 0.35 0.35 checkLog_Btt;                                                
            }   
    break;            

    case 6 :
            string $note_qrr[] = `getFileList -folder $Croi_log_path -filespec "note.ini"`;
            if (size($note_qrr) != 0)
            {
              button -e -bgc 0.939 0.730 0.223 checkNote_Btt;
            } 
            else 
            {
              button -e -bgc 0.35 0.35 0.35 checkNote_Btt;                                                
            }   
    break;  

   ////////////////////////Make Folder ///////////////////////////////////////
   
    case 7 :
        int $pre_checkFolder =`file -q -exists $Croi_log_path`;
        if($pre_checkFolder != 0)
        {
        }
        else
        {    
        sysFile -makeDir $Croi_ABC_path;
        }      
 
    break;    
    case 71 :    
      string $attribcmd2 ="attrib -h -s ";
      string $attrib2 =$attribcmd2 + "\"" + $Croi_log_path +"\"";
      system( $attrib2 );
    break;    

    case 72 :    
      string $attribcmd3 ="attrib +h +s ";
      string $attrib3 =$attribcmd3 + "\"" + $Croi_log_path +"\"";
      system( $attrib3 );
    break;  
     
   ////////////////////////W_n_R_infoNOTE///////////////////////////////////////   
    //Write
    case 8 :
              Croissants_logStats(88);
              string $Croissants_info_w = "/" + $Croissants_pMin + "/" + $Croissants_pMax + "/" + $FPS;
              $fileId=`fopen $wipInfo_path "w"`;
              fprint $fileId $Croissants_info_w;
              fclose $fileId;       
    break;   

    case 88 :
        string $pre_checklogini[] =`getFileList -folder $Croi_log_path -filespec "*.ini"`;
        if(size($pre_checklogini) != 0)
        {
        }
        else
        {    
        sysFile -makeDir $Croi_log_path;
        }      
        string $attribcmd ="attrib +h +s ";
        string $attrib =$attribcmd + "\"" + $Croi_log_path +"\"";
        system( $attrib );              
    break;  
     
    //Read
    case 9 :
              $fileId = `fopen $wipInfo_path "r"` ;  
              string $data_R = `fread $fileId $data_R` ; 
              fclose $fileId;         

              string $infos[] ;  
              $infos = stringToStringArray($data_R, "/");         
              int $SF = $infos[0];
              int $EF = $infos[1];

              intField -e -v $SF Croissants_A01_sf;
              intField -e -v  $EF Croissants_A02_ef;
              currentUnit -time $infos[2];
              Croissants_PlayBlastFrame(1);Croissants_PlayBlastFrame(2);
              currentTime -e 101;
    break;  
    //Write with Increment Tag
    //////////////////////////////////////////////////////////////////////////////////////////////////
    case 81 :
              string $Croissants_info_w3 = "/" + $Croissants_pMin + "/" + $Croissants_pMax + "/";
              $fileId=`fopen $wipInfo_path_Inc "w"`;
              fprint $fileId $Croissants_info_w3;
              fclose $fileId;       
    break;
    //Read  with Increment Tag
    //////////////////////////////////////////////////////////////////////////////////////////////////
    case 91 :  
              $fileId = `fopen $wipInfo_path_Inc "r"` ;  
              string $data_91 = `fread $fileId $data_91` ; 
              fclose $fileId;         

              string $infos_91[] ;  
              $infos_91 = stringToStringArray($data_91, "/");         


              string $strVal_0a = $infos_91[0];
              string $strVal_1a = $infos_91[1];
              
              int $intVal_0a = (int)$strVal_0a;
              int $intVal_1a = (int)$strVal_1a;
              
              if($intVal_0a == 0)
              {                      
              intField -e -v 101 Croissants_A01_sf;
              intField -e -v 101 Croissants_A02_ef;
              }
              else
              {         
              intField -e -v $intVal_0a  Croissants_A01_sf;
              intField -e -v $intVal_1a  Croissants_A02_ef;
              }
    break;    
    case 92 :
              $fileId = `fopen $wipInfo_path "r"` ;  
              string $data_R_92 = `fread $fileId $data_R_92` ; 
              fclose $fileId;         

              string $infos_92[] ;  
              $infos_92 = stringToStringArray($data_R_92, "/"); 
              
              string $strVal_0 = $infos_92[0];
              string $strVal_1 = $infos_92[1];
              
              int $intVal_0 = (int)$strVal_0;
              int $intVal_1 = (int)$strVal_1;
              
              if($intVal_0 == 0)
              {                      
              intField -e -v 101 Croissants_A01_sf;
              intField -e -v 101 Croissants_A02_ef;
              }
              else
              {         
              intField -e -v $intVal_0  Croissants_A01_sf;
              intField -e -v $intVal_1  Croissants_A02_ef;
              }
    break;
  }
}  


  global proc Get_Croissants_AssetsList(int $case)
  {
    string $G_Croi_C_WS = `Croi_C_workspace`;
    string $G_Cori_Assets=`textField -q -tx croissants_TokenI`;
    string $omA_FB=`optionMenu -q -v Croissants_Assets`;
    string $omB_FB=`optionMenu -q -v Croissants_Assets_2`;
    string $omC_FB=`optionMenu -q -v Croissants_Assets_3`;
    
    string $AssetPath = $G_Croi_C_WS +"/"+ $G_Cori_Assets +"/"+ (`Croi_Assets_Root`) + "/" + (`Croi_Assets_Sub`) + "/";
    string $AssetPath_His = $AssetPath + "_His";
    string $AssetPath_son = $G_Croi_C_WS +"/"+ $G_Cori_Assets + "/" + (`Croi_Assets_Root`) + "/" + (`Croi_Assets_Sub`) + "/"+ (`Croi_Assets_Name`) + "/";
    string $AssetPath_son_His = $AssetPath_son +"_His";  
    
    string $Path_Assets = $G_Croi_C_WS +"/"+ $G_Cori_Assets;
    
    string $Croissants_Assets_son_His[] = `textScrollList -q -si Croissants_Assets_List_1`;

    string $ac_Filter=`textField -q -tx Croissants_Filter_Asset`; 
                    
  switch($case)
    {
      case 1 :        
              $menuItems = `optionMenu -q -itemListLong Croissants_Assets`;
              if(size($menuItems) != 0)
              {deleteUI($menuItems);}
                         
              string $dir_list[] = `getFileList -folder $Path_Assets -filespec "*"`;
                string $dir_list_sort[];
                $dir_list_sort=sort($dir_list);

                for ($i = 0; $i < size($dir_list_sort); $i++)
                {           
                menuItem -l $dir_list_sort[$i] -p Croissants_Assets;
                }              
      break;

      case 2 :
                $menuItems_sub = `optionMenu -q -itemListLong Croissants_Assets_2`;
                if(size($menuItems_sub) != 0)
                {deleteUI($menuItems_sub);} 

  
                string $case2Path = $Path_Assets +"/"+ (`Croi_Assets_Root`) + "/" ;
                           
                    string $dir_list_sub[] = `getFileList -folder $case2Path -filespec $ac_Filter`;
                      if (size($dir_list_sub) == 0)
                      {
                        print "There are no assets.";
                        textScrollList -edit -removeAll Croissants_Assets_List_1;
                      }
                      else
                      {
                        string $dir_list_sort_sub[];
                        $dir_list_sort_sub=sort($dir_list_sub);                        
                        for ($i = 0; $i < size($dir_list_sort_sub); $i++)
                        {           
                        menuItem -l $dir_list_sort_sub[$i] -p Croissants_Assets_2;
                        }
                      }               

      break;

      case 21 :  
                $menuItems_son = `optionMenu -q -itemListLong Croissants_Assets_3`;
                if(size($menuItems_son) != 0)
                {deleteUI($menuItems_son);} 

                    string $case21Path = $Path_Assets +"/"+ (`Croi_Assets_Root`) + "/" + (`Croi_Assets_Sub`) + "/";
                           
                    string $dir_list_son[] = `getFileList -folder $case21Path -filespec $ac_Filter`;
                    if (size($dir_list_son) == 0)
                    {
                      print "There are no assets.";
                      textScrollList -edit -removeAll Croissants_Assets_List_1;
                    } 
                    else
                    {             
                      string $dir_list_sort_son[];
                      $dir_list_sort_son=sort($dir_list_son);
                  
                      for ($i = 0; $i < size($dir_list_sort_son); $i++)
                      {           
                      menuItem -l $dir_list_sort_son[$i] -p Croissants_Assets_3;
                      }
                    }  
       
      break;     

      case 3 :                       
                string $dir_list_subA[] = `getFileList -folder $AssetPath -filespec "*.m*"`;        
                
                if(size($dir_list_subA) == 0)
                {
                  print "There are no assets.";
                  textScrollList -edit -removeAll Croissants_Assets_List_1;
                }
                else
                {                
                    string $dir_list_sort_subA[];
                    $dir_list_sort_subA=sort($dir_list_subA);        
                    textScrollList -edit -removeAll Croissants_Assets_List_1;
                    for ($i = 0; $i < size($dir_list_sort_subA); $i++)
                    {           
                    textScrollList   -ams 0 -sc "" -dcc "OPEN_Croissants_files(3);" -e -a $dir_list_sort_subA[$i] Croissants_Assets_List_1;
                    }  
        
                    //remove .mayaSwatches Assets List
                    int $checkCount =`textScrollList -q -ni Croissants_Assets_List_1`;
                    if ($checkCount == 0){print "";}
                    else
                    {
                    textScrollList -e -sii 1 Croissants_Assets_List_1;
                    string $mayaSwatchesX[] =`textScrollList -q -si Croissants_Assets_List_1`;
                        if ($mayaSwatchesX[0] != ".mayaSwatches")
                        {
                            print "noSwatche \n";
                        }
                        else
                        textScrollList -e -rii 1  Croissants_Assets_List_1; 
                    }
                    //Get History
                    string $dir_list_Assets_subA[] = `getFileList -folder $AssetPath_His -filespec "*.m*"`;            
                    string $dir_list_sort_Assets_subA[];
                    $dir_list_sort_Assets_subA=sort($dir_list_Assets_subA);
                    textScrollList -edit -removeAll Croissants_Assets_List_His;
                        for ($i = 0; $i < size($dir_list_sort_Assets_subA); $i++)
                        {           
                        textScrollList   -ams 0 -sc "" -dcc "OPEN_Croissants_files(42);" -e -a $dir_list_sort_Assets_subA[$i] Croissants_Assets_List_His;
                        }                      
                }    

        break;                    
      case 31 :
                string $dir_list_subA_son[] = `getFileList -folder $AssetPath_son -filespec "*.m*"`;        

                if(size($dir_list_subA_son) == 0)
                {
                    print "There are no assets.";
                    textScrollList -edit -removeAll Croissants_Assets_List_1;
                }
                else
                {
                    string $dir_list_sort_subA_son[];
                    $dir_list_sort_subA_son=sort($dir_list_subA_son);        
                    textScrollList -edit -removeAll Croissants_Assets_List_1;
                    for ($i = 0; $i < size($dir_list_sort_subA_son); $i++)
                    {           
                    textScrollList   -ams 0 -sc "" -dcc "OPEN_Croissants_files(3);" -e -a $dir_list_sort_subA_son[$i] Croissants_Assets_List_1;
                    }  
        
                    //remove .mayaSwatches Assets List
                    int $checkCount31 =`textScrollList -q -ni Croissants_Assets_List_1`;
                    if ($checkCount31 == 0){print "";}
                    else
                    {
                    textScrollList -e -sii 1 Croissants_Assets_List_1;
                    string $mayaSwatchesX[] =`textScrollList -q -si Croissants_Assets_List_1`;
                        if ($mayaSwatchesX[0] != ".mayaSwatches")
                        {
                            print "noSwatche \n";
                        }
                        else
                        textScrollList -e -rii 1  Croissants_Assets_List_1; 
