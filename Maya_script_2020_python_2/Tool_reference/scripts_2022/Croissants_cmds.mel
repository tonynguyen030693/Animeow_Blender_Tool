          if($note_infos_Mod == 0)
          {
           Get_Croissants_MOD_List(2);Get_Croissants_MOD_List(3);Get_Croissants_MOD_List(8); 
          }
          else if ($note_infos_Mod == 1)
          {
          Get_Croissants_MOD_List(2);Get_Croissants_MOD_List(21);Get_Croissants_MOD_List(31);Get_Croissants_MOD_List(8); 
          }    
    break;

