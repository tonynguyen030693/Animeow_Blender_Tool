    }
 }


global proc Croissants_get_EPs(int $case)
{
    string $G_Croi_C_WS =`Croi_C_workspace`;
    string $G_Croi_Root=`Croi_Root`;
    string $G_Croi_Sub=`Croi_Sub`;    
    string $G_Croi_Scenes_01=`textField -q -tx croissants_TokenD`;
    string $G_Croi_Scenes_02=`textField -q -tx croissants_TokenF`;
    string $G_Croi_Scenes_03=`textField -q -tx croissants_TokenE`;
    
    string $G_Croi_Scenes_subB=`textField -q -tx croissants_TokenH`;
    
    string $Animation_Path = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" +$G_Croi_Scenes_02;
    string $Lighting_Path = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" +$G_Croi_Scenes_03;

    
    //ÇÁ·ÎÁ§Ć®żˇ µű¶ó ĽöÁ¤ ÇĘżä
    string $TokenRlue=`textField -q -tx croissants_TokenP`;
    
    
    string $cFilter=`textField -q -tx Croissants_Filter`;   
    
  switch($case)
  {

      case 100 :
      //Croissants_Epsodic
        string $TokenA = `textField -q -tx croissants_TokenA`;
        int $value = (string)$TokenA;
        checkBox -e -v $value Episodic; 
      break;
      
      case 101 :
      //Croissants_Project_Title
        string $G_Croi_Title = `textField -q -tx croissants_TokenC`;
        inViewMessage -smg $G_Croi_Title -pos topRight -bkc 0x00000000 -fade;
      break;
  

      //GET path for Root
      ////////////////////////////////////////////////////////////////////////      
      case 1 :
        string $Token_Ani =  $Animation_Path ;    
        $menuItems = `optionMenu -q -itemListLong Croissants_EP`;
        if(size($menuItems) != 0)
        {deleteUI($menuItems);}
        string $dir_list[] = `getFileList -folder $Token_Ani -filespec $cFilter`;
        string $dir_list_sort[];
        $dir_list_sort=sort($dir_list);

        for ($i = 0; $i < size($dir_list_sort); $i++)
        {           
        menuItem -l $dir_list_sort[$i] -p Croissants_EP;
        }
      break;

      //GET path for sub
      //////////////////////////////////////////////////////////////////////// 
      case 2 :     
        string $get_reEPs=`Croi_Root`;
        $menuItems = `optionMenu -q -itemListLong Croissants_CUT`;
        if(size($menuItems) != 0)
        {deleteUI($menuItems);}

            if($TokenRlue == "0")
            {           
            string $token = $Animation_Path + "/" + $get_reEPs ;
            string $dir_list_sub[] = `getFileList -folder $token -filespec $cFilter`;
            string $subdirectories[];
            string $dir_list_sort_sub[];
            $dir_list_sort_sub=sort($dir_list_sub);
              for ($i = 0; $i < size($dir_list_sort_sub); $i++)
              {           
              menuItem -l $dir_list_sort_sub[$i] -p Croissants_CUT;
              }              
            }
            else if($TokenRlue == "1")    
            {
            string $token = $Animation_Path + "/" + $get_reEPs + "/" + $G_Croi_Scenes_subB;
            string $dir_list_sub[] = `getFileList -folder $token -filespec $cFilter`;
            string $subdirectories[];
            string $dir_list_sort_sub[];
            $dir_list_sort_sub=sort($dir_list_sub);
              for ($i = 0; $i < size($dir_list_sort_sub); $i++)
              {           
              menuItem -l $dir_list_sort_sub[$i] -p Croissants_CUT;
              }              
            
            }            
      break;

      ///////////////////////////Get Work Files
      ////////////////////////////////////////////////////////////////////////////
      //////////////////////////////////////////////////////////////////////////// 
      case 3 :        
      
          if($TokenRlue == "0")
          {           
            string $tokenA = $Animation_Path + "/" + $G_Croi_Root + "/" + $G_Croi_Sub + "/" + $G_Croi_Scenes_subB;
            string $dir_list_subA[] = `getFileList -folder $tokenA -filespec "*.m*"`;        
            
            string $dir_list_sort_subA[];
            $dir_list_sort_subA=sort($dir_list_subA);
            
            textScrollList -edit -removeAll Croissants_Ani_List;
            for ($i = 0; $i < size($dir_list_sort_subA); $i++)
            {           
            textScrollList   -ams 0 -sc "catchQuiet(UI_dc_CC(1));" -dcc "OPEN_Croissants_files(1);" -e -a $dir_list_sort_subA[$i] Croissants_Ani_List;
            }              
          }
          else if($TokenRlue == "1")    
          {
            string $tokenA = $Animation_Path + "/" + $G_Croi_Root + "/" +$G_Croi_Scenes_subB + "/" +$G_Croi_Sub;
            string $dir_list_subA[] = `getFileList -folder $tokenA -filespec "*.m*"`;        
            
            string $dir_list_sort_subA[];
            $dir_list_sort_subA=sort($dir_list_subA);
            
            textScrollList -edit -removeAll Croissants_Ani_List;
            for ($i = 0; $i < size($dir_list_sort_subA); $i++)
            {           
            textScrollList   -ams 0 -sc "catchQuiet(UI_dc_CC(1));Croi_Playback_sel();" -dcc "OPEN_Croissants_files(1);"  -e -a $dir_list_sort_subA[$i] Croissants_Ani_List;
            }              

          }             
          

        
        ///////////////////////////Get Lit
        ////////////////////////////////////////////////////////////////////////////
        ////////////////////////////////////////////////////////////////////////////        
          string $tokenB = $Lighting_Path + "/" + $G_Croi_Root + "/" + $G_Croi_Sub;
          string $dir_list_subB[] = `getFileList -folder $tokenB -filespec "*.m*"`;
                  
          string $dir_list_sort_subB[];
          $dir_list_sort_subB=sort($dir_list_subB);

          
          textScrollList -edit -removeAll Croissants_Lit_List;
          for ($i = 0; $i < size($dir_list_sort_subB); $i++)
          {           
          textScrollList   -ams 0 -sc "catchQuiet(UI_dc_CC(2));" -dcc "OPEN_Croissants_files(2);" -e -a $dir_list_sort_subB[$i] Croissants_Lit_List;
          }          
        
        //remove .mayaSwatches Lighing List
        ////////////////////////////////////////////////////////////////////////////
        ////////////////////////////////////////////////////////////////////////////
          int $checkCount =`textScrollList -q -ni Croissants_Lit_List`;
          if ($checkCount == 0)
          {
              print "";    
          }
          else
          {
              textScrollList -e -sii 1 Croissants_Lit_List;
              string $mayaSwatchesX[] =`textScrollList -q -si Croissants_Lit_List`;
              if ($mayaSwatchesX[0] != ".mayaSwatches")
              {
                  print "noSwatche \n";
              }
              else
              textScrollList -e -rii 1  Croissants_Lit_List; 
          }
          textScrollList -e -da Croissants_Lit_List;  
            
        ////////////////////////////////////////////////////////////////////////////
        ////////////////////////////////////////////////////////////////////////////
        //Get Source
          string $tokenC = $Lighting_Path + "/" + $G_Croi_Root + "/" + $G_Croi_Sub + "/" + "Z_Source/";
          string $dir_list_subC[] = `getFileList -folder $tokenC -filespec "*.m*"`;
                  
          string $dir_list_sort_subC[];
          $dir_list_sort_subC=sort($dir_list_subC);
          
          textScrollList -edit -removeAll Croissants_src_List;
          for ($i = 0; $i < size($dir_list_sort_subC); $i++)
          {           
          textScrollList   -ams 0 -sc "" -dcc "OPEN_Croissants_files(5);" -e -a $dir_list_sort_subC[$i] Croissants_src_List;
          }   
        

        //remove .mayaSwatches Source List
        ////////////////////////////////////////////////////////////////////////////
        ////////////////////////////////////////////////////////////////////////////
          int $checkCount2 =`textScrollList -q -ni Croissants_src_List`;
          if ($checkCount2 == 0)
          {
              print "";    
          }
          else
          {
              textScrollList -e -sii 1 Croissants_src_List;
              string $mayaSwatchesX[] =`textScrollList -q -si Croissants_src_List`;
              if ($mayaSwatchesX[0] != ".mayaSwatches")
              {
                  print "noSwatche \n";
              }
              else
              textScrollList -e -rii 1  Croissants_src_List; 
          }    
        ////////////////////////////////////////////////////////////////////////////
        ////////////////////////////////////////////////////////////////////////////

          //Get History folder
          string $tokenD = $Lighting_Path + "/" + $G_Croi_Root + "/" + $G_Croi_Sub + "/" + "_His/";
          string $dir_list_subHis[] = `getFileList -folder $tokenD -filespec "*.m*"`;
                  
          string $dir_list_sort_subHis[];
          $dir_list_sort_subHis=sort($dir_list_subHis);
          
          textScrollList -edit -removeAll Croissants_HIs_List;
          for ($i = 0; $i < size($dir_list_sort_subHis); $i++)
          {           
          textScrollList   -ams 0 -sc "" -dcc "" -e -a $dir_list_sort_subHis[$i] Croissants_HIs_List;
          }      
      break;

        ////////////////////////////////////////////////////////////////////////////
        ////////////////////////////////////////////////////////////////////////////
        /// Open Command

      case 4 :

              string $Croissants_Ani[] = `textScrollList -q -si Croissants_Ani_List`;

                  for ($i=0; $i<size($Croissants_Ani); $i++)
                  {
                  string $Ani_filename = $Animation_Path  + "/" +  $G_Croi_Root + "/" + $G_Croi_Sub + "/" + $Croissants_Ani[$i];
                  file -f  -ignoreVersion  -o $Ani_filename; //-typ "mayaAscii" 
                  GET_Croissants_TIME();
                  }
                    get_CurrUnit_CC();
                    Get_Croissants_ABCList();
                    //string $qmss=`textField -q -tx Croissants_msg`;
                    //textField -e -tx ("File is Open | " + $qmss) Croissants_msg;
      break;                  

      case 5 :
              
              string $Croissants_Lit[] = `textScrollList -q -si Croissants_Lit_List`;

                  for ($i=0; $i<size($Croissants_Lit); $i++)
                  {
                  string $Lit_filename = $Lighting_Path + "/" +  $G_Croi_Root + "/" + $G_Croi_Sub + "/" + $Croissants_Lit[$i];
                  file -f  -ignoreVersion   -o $Lit_filename; //-typ "mayaAscii"
                  
                  }
                    get_CurrUnit_CC();
                    Get_Croissants_ABCList();
                    string $qmss_L=`textField -q -tx Croissants_msg`;
                    textField -e -tx ("File is Open | " + $qmss_L) Croissants_msg;                    
       
      break;  

      case 6 :  
              //Opne Source Files
                string $Croissants_src[] = `textScrollList -q -si Croissants_src_List`;

                  for ($i=0; $i<size($Croissants_src); $i++)
                  {
                  string $src_filename = $Lighting_Path + "/" +  $G_Croi_Root + "/" + $G_Croi_Sub + "/Z_Source/" + $Croissants_src[$i];
                  file -f  -ignoreVersion   -o $src_filename; //-typ "mayaAscii"
                  
                  }
                    get_CurrUnit_CC();
               
      break; 

   }
 }

global proc Croissants_MakeDir(int $case)
{
    string $G_Croi_C_WS =`Croi_C_workspace`;
    string $G_Croi_Root=`Croi_Root`;
    string $G_Croi_Sub=`Croi_Sub`;    
    string $G_Croi_Scenes_01=`textField -q -tx croissants_TokenD`;
    string $G_Croi_Scenes_02=`textField -q -tx croissants_TokenF`;
    string $G_Croi_Scenes_03=`textField -q -tx croissants_TokenE`;

    string $Path_E = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" +$G_Croi_Scenes_02 + "/";
    string $Path_C = $Path_E + $G_Croi_Root + "/";
    string $folderName =`textField -q -tx Croissants_MakeDir_FLD`;

    int $TokenRlue=`textField -q -tx croissants_TokenP`;  
    
    string $TkoenRlue_shot = `textField -q -tx croissants_TokenQ`;   
    
    string $Ani_SubDir=`textField -q -tx croissants_TokenH`;
    
  switch($case)
  {
    //Animation Folder
    case 1 :    
      string $dir_list[] = `getFileList -folder $Path_C -filespec "*.*"`;
      string $dir_list_sort[];
       $dir_list_sort=sort($dir_list);

      if($TkoenRlue_shot == 1)
      {           
        for ($i = 0; $i < size($dir_list_sort); $i++)
        {           

          string $AFile = $Path_C + $dir_list_sort[$i];
          $array_names = stringToStringArray($dir_list_sort[$i], "_");
          string $Tk1=$array_names[2];
          string $PathA = $Path_C + $Tk1;

          sysFile -makeDir $PathA;
          string $syscmd ="move "+$AFile+ " " + $PathA;
          string $syscmd_win_a = substituteAllString($syscmd, "/", "\\\\"); 
          system( $syscmd_win_a );
        }
      }
      else if($TkoenRlue_shot == 2)
      {   
        for ($i = 0; $i < size($dir_list_sort); $i++)
        {           
          string $AFile = $Path_C + $dir_list_sort[$i];
          $array_names = stringToStringArray($dir_list_sort[$i], "_");
          string $Tk1=$array_names[2];
          string $Tk2=$array_names[3];
          string $Tk3=$array_names[4];
          string $PathA = $Path_C + $Tk1+"_"+$Tk2+"_"+$Tk3;

          sysFile -makeDir $PathA;
          string $syscmd ="move "+$AFile+ " " + $PathA;
          string $syscmd_win_a = substituteAllString($syscmd, "/", "\\\\"); 
          system( $syscmd_win_a );
        }
      }
      else
      {
        textField -e -tx  "Rule is Wrong.."  Croissants_msg; 
      }
    
        OpenGetInfo(1);
        textField -e -tx  "Array Complete.!!!"  Croissants_msg; 
        
    break;

    case 2 :
    //Make Sub    

            if($TokenRlue == 0)
            {           
              string $PathB = $Path_C + $folderName + "/" + $Ani_SubDir;
              sysFile -makeDir $PathB;
            }
            else if($TokenRlue == 1)    
            {
              string $PathB = $Path_C + $Ani_SubDir + "/" + $folderName;
              sysFile -makeDir $PathB;          
            }            

          catchQuiet(Croissants_get_EPs(2));
          optionMenu -e -v $folderName Croissants_CUT;
          catchQuiet(Croissants_get_EPs(3));
    break;

    case 3 : 
    //Make Root   
          string $PathC = $Path_E + $folderName;
          sysFile -makeDir $PathC;
          catchQuiet(Croissants_get_EPs(1));
          optionMenu -e -v $folderName Croissants_EP;
          catchQuiet(Croissants_get_EPs(2));
     
    break;
        
  }
}


global proc Croissants_MakeDir_Preset(int $case)
{
  switch($case)
  {
    case 0 :
    textField -e -tx "LookDev" Croissants_MakeDir_FLD;
    break;    
    case 1 :
    textField -e -tx "EP100" Croissants_MakeDir_FLD;
    break;    
    case 2 :
    textField -e -tx "EP101" Croissants_MakeDir_FLD;
    break;
    case 3 :
    textField -e -tx "C000" Croissants_MakeDir_FLD;
    break;    
    case 4 :
    textField -e -tx "S001_001_0" Croissants_MakeDir_FLD;
    break;
    case 5 :
    textField -e -tx "002-010" Croissants_MakeDir_FLD;
    break;   
    }
}
global proc Croissants_MakeGrpName(int $case)
{
  switch($case)
  {
