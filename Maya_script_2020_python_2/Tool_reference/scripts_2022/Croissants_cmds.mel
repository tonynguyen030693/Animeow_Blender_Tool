global proc Croissants_ByeByeFile(int $case)
{
    string $G_Croi_C_WS =`Croi_C_workspace`;
    string $G_Croi_Root=`Croi_Root`;
    string $G_Croi_Sub=`Croi_Sub`;    
    string $G_Croi_Scenes_01=`textField -q -tx croissants_TokenD`;
    string $G_Croi_Scenes_02=`textField -q -tx croissants_TokenF`;
    string $G_Croi_Scenes_03=`textField -q -tx croissants_TokenE`;    
    string $G_Croi_Scenes_04=`textField -q -tx croissants_TokenJ`;
    string $Ani_SubDir=`textField -q -tx croissants_TokenH`;
           
    string $EPs_GET=`optionMenu -q -v Croissants_EP`;
    string $CUTs_GET=`optionMenu -q -v Croissants_CUT`;
    
    string $byeAni_Path = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" + $G_Croi_Scenes_02 + "/" + (`optionMenu -q -v Croissants_EP`) + "/" + (`optionMenu -q -v Croissants_CUT`) + "/" + $Ani_SubDir + "/";
    string $byeZS_Path = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" + $G_Croi_Scenes_03 + "/" + (`optionMenu -q -v Croissants_EP`) + "/" + (`optionMenu -q -v Croissants_CUT`) + "/Z_Source/";
    string $byeHis_Path = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" + $G_Croi_Scenes_03 + "/" + (`optionMenu -q -v Croissants_EP`) + "/" + (`optionMenu -q -v Croissants_CUT`) + "/_His/";
    string $byeLIT_Path = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" + $G_Croi_Scenes_03 + "/" + (`optionMenu -q -v Croissants_EP`) + "/" + (`optionMenu -q -v Croissants_CUT`) + "/";
 
  switch($case)
  {
      case 1 :
          $response = `confirmDialog -title "Confirm" 
                          -message "ÁřÂĄ·Î ĆÄŔĎŔ» Áöżď°Ç°ˇżä?"
                          -button "Yes" 
                          -button "No"
                          -defaultButton "Yes"
                          -cancelButton "No"
                          -dismissString "No"`;
          
          // check response	  
          if( $response == "Yes" ) 
          {
            $response2 = `confirmDialog -title "ÁřÂĄ?" 
                            -message "´ő´Â ľČąŻ´Â´Ů Č®˝ÇÇĎÁö?"
                            -button "Yes" 
                            -button "No"
                            -defaultButton "Yes"
                            -cancelButton "No"
                            -dismissString "No"`;          
              if( $response2 == "Yes" ) 
                  {
                      string $Croissants_Lit[] = `textScrollList -q -si Croissants_Lit_List`;
                      for ($i=0; $i<size($Croissants_Lit); $i++)
                      {
                        string $Croissants_Lit_filename = $byeLIT_Path+$Croissants_Lit[$i];
                        sysFile -delete $Croissants_Lit_filename;    
                      }
                    Croissants_get_EPs(3);
                    print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
                  }
                  else if( $response2 == "No" ) 
                  {
                    print("ł»°ˇ ±×·˛ÁŮ ľËľŇÁö...\n");
                  }
          } 
          else if( $response == "No" ) 
          {
            print("ČŢ~~~ ^^;\n");
          }
      break;		

      case 2 :
          $response = `confirmDialog -title "Confirm" 
                          -message "ÁřÂĄ·Î ĆÄŔĎŔ» Áöżď°Ç°ˇżä?"
                          -button "Yes" 
                          -button "No"
                          -defaultButton "Yes"
                          -cancelButton "No"
                          -dismissString "No"`;
          
          // check response	  
          if( $response == "Yes" ) 
          {
              string $Croissants_src[] = `textScrollList -q -si Croissants_src_List`;

                  for ($i=0; $i<size($Croissants_src); $i++)
                  {
                    string $Croissants_src_filename = $byeZS_Path+$Croissants_src[$i];
                    sysFile -delete $Croissants_src_filename;    
                  }
              Croissants_get_EPs(3);
              print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
          } 
          else if( $response == "No" ) 
          {
            print("ČŢ~~~ ^^;\n");
          }
      break;	

      case 3 :
          $response = `confirmDialog -title "Confirm" 
                          -message "ÁřÂĄ·Î ĆÄŔĎŔ» Áöżď°Ç°ˇżä?"
                          -button "Yes" 
                          -button "No"
                          -defaultButton "Yes"
                          -cancelButton "No"
                          -dismissString "No"`;
          
          // check response	  
          if( $response == "Yes" ) 
          {
              string $Croissants_Ani[] = `textScrollList -q -si Croissants_Ani_List`;
                  for ($i=0; $i<size($Croissants_Ani); $i++)
                  {
                    string $Croissants_Ani_filename = $byeAni_Path+$Croissants_Ani[$i];
                    sysFile -delete $Croissants_Ani_filename;    
                  }
              Croissants_get_EPs(3);
              print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
          } 
          else if( $response == "No" ) 
          {
            print("ČŢ~~~ ^^;\n");
          }
      break;

      case 33 :
          $response = `confirmDialog -title "Confirm" 
                          -message "ÁřÂĄ·Î Ćú´ő¸¦ Áöżď°Ç°ˇżä? (şńľîŔÖ´Â Ćú´ő¸¸ ÁöżöÁý´Ď´Ů.)"
                          -button "Yes" 
                          -button "No"
                          -defaultButton "Yes"
                          -cancelButton "No"
                          -dismissString "No"`;
          
          // check response	  
          if( $response == "Yes" ) 
          {          
              sysFile -red $byeAni_Path;    
              Croissants_get_EPs(2);
              print("Ľ±ĹĂÇŃ Ćú´ő¸¦ Áöżü˝Ŕ´Ď´Ů.\n"); 
          } 
          else if( $response == "No" ) 
          {
            print("ČŢ~~~ ^^;\n");
          }
      break;

      
      case 4 :
        //Move Lit to History
        string $Croissants_Lit_his[] = `textScrollList -q -si Croissants_Lit_List`;
            for ($i=0; $i<size($Croissants_Lit_his); $i++)
            {
              string $Lit_filename_his = $byeLIT_Path+$Croissants_Lit_his[$i];
              sysFile -makeDir $byeHis_Path;
              string $syscmd ="move "+$Lit_filename_his+ " " + $byeHis_Path;
              string $syscmd_win = substituteAllString($syscmd, "/", "\\\\"); 
              system( $syscmd_win );
            }
        Croissants_get_EPs(3);           
      break;  

         	
    }

}


///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
global proc Croissants_MakeAni(int $case)
{
    string $now_project_MakeAni = `workspace -q -fn`;
    string $ProjectType_MakeAni[]= `getFileList -folder $now_project_MakeAni -filespec "*.ini"`;
    string $ProjectNote_MakeAni = $now_project_MakeAni +"/"+ $ProjectType_MakeAni[0];
           $noteId_MakeAni = `fopen $ProjectNote_MakeAni "r"` ;  
    string $note_info_MakeAni = `fread $noteId_MakeAni $note_info_MakeAni` ; 
                         fclose $noteId_MakeAni;       

    string $note_info_MakeAnis[];  
           $note_info_MakeAnis = stringToStringArray($note_info_MakeAni, "."); 
    string $meta_treeA_MakeAni = $note_info_MakeAnis[3];
           $meta_BranchA_MakeAni = stringToStringArray($meta_treeA_MakeAni, "|"); 
    string $meta_treeB_MakeAni = $note_info_MakeAnis[4];
           $meta_BranchB_MakeAni = stringToStringArray($meta_treeB_MakeAni, ","); 
           
           
    string $init_3[]= `getFileList -folder $now_project_MakeAni -filespec "*.ini"`;
    string $ini_gets_3 = $init_3[0]; 
    string $G_I_3[] = stringToStringArray($ini_gets_3, ".");
    

    string $EP_MakeAni=`optionMenu -q -v Croissants_EP`;
    string $CUT_MakeAni=`optionMenu -q -v Croissants_CUT`;

    string $PUBType_Aa=`optionMenu -q -v Croissants_PUBType_A`;
    string $PUBType_Ba=`optionMenu -q -v Croissants_PUBType_B`;
    
    string $Croissants_AniRoot = $now_project_MakeAni + "/" + $meta_BranchA_MakeAni[1] + "/" +$meta_BranchA_MakeAni[3] + "/" + $EP_MakeAni + "/" + $CUT_MakeAni + "/" + $meta_BranchA_MakeAni[5] + "/";
    string $Croissants_LAY_MA = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_Ani.0101"+$PUBType_Ba;
    string $Croissants_LAY_MB_1 = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_ly_v01"+$PUBType_Ba;
    string $Croissants_LAY_RN = $Croissants_AniRoot + $Croissants_LAY_MA;
    string $Croissants_LAY_RN_1 = $Croissants_AniRoot + $Croissants_LAY_MB_1;
    
    string $Croissants_A01_MA = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_Ani.0201"+$PUBType_Ba;
    string $Croissants_A01_MB_1 = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_de_v01"+$PUBType_Ba;
    string $Croissants_A01_RN = $Croissants_AniRoot + $Croissants_A01_MA;      
    string $Croissants_A01_RN_1 = $Croissants_AniRoot + $Croissants_A01_MB_1;      
    
    string $Croissants_A02_MA = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_Ani.0301"+$PUBType_Ba;
    string $Croissants_A02_MB_1 = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_de_v02"+$PUBType_Ba;
    string $Croissants_A02_RN = $Croissants_AniRoot + $Croissants_A02_MA;      
    string $Croissants_A02_RN_1 = $Croissants_AniRoot + $Croissants_A02_MB_1;   

    string $Croissants_A03_MA = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_Ani.0401"+$PUBType_Ba;
    string $Croissants_A03_MB_1 = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_de_v03"+$PUBType_Ba;
    string $Croissants_A03_RN = $Croissants_AniRoot + $Croissants_A03_MA;      
    string $Croissants_A03_RN_1 = $Croissants_AniRoot + $Croissants_A03_MB_1;      

    string $Croissants_A0F_MA = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_Ani.0501"+$PUBType_Ba;
    string $Croissants_A0F_MB_1 = $G_I_3[0] + "_" + $EP_MakeAni + "_" + $CUT_MakeAni + "_fn"+$PUBType_Ba;
    string $Croissants_A0F_RN = $Croissants_AniRoot + $Croissants_A0F_MA;      
    string $Croissants_A0F_RN_1 = $Croissants_AniRoot + $Croissants_A0F_MB_1;      

    string $Croissants_Bake_MA = "__CH_Bake.0001"+$PUBType_Ba;
    string $Croissants_Bake_RN_1 = $Croissants_AniRoot + $Croissants_Bake_MA;   

    string $Croissants_Bake_MB = "__PR_Bake.0001"+$PUBType_Ba;
    string $Croissants_Bake_RN_2 = $Croissants_AniRoot + $Croissants_Bake_MB;   



    int $TFR=`textField -q -tx croissants_TokenP`;
    //Type File Rule for custome client




    switch($case)
    {

        case 1 :
            if($TFR == 0)
            {            
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_LAY_RN; 
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_LAY_RN;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }       
            }
            else if($TFR == 1)    
            {
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_LAY_RN_1;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_LAY_RN_1;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }                      
            }
            Croissants_get_EPs(3);
            Get_Croissants_ABCList();
            
        break;   

        case 2 :
            if($TFR == 0)
            { 
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A01_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A01_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }                      
            }
            else if($TFR == 1)    
            {
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A01_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A01_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }             
          
            }            
            Croissants_get_EPs(3);
            Get_Croissants_ABCList();
            
        break;            

        case 3 :
            if($TFR == 0)
            {  
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A02_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A02_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }                        
            }
            else if($TFR == 1)    
            {
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A02_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A02_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }                       
            }            
            Croissants_get_EPs(3);
            Get_Croissants_ABCList();
        break;

        case 4 :
            if($TFR == 0)
            {  
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A03_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A03_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }                       
            }
            else if($TFR == 1)    
            {
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A03_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A03_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }              
        
            }            
            Croissants_get_EPs(3);
            Get_Croissants_ABCList();
        break;


        case 5 :
            if($TFR == 0)
            {  
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A0F_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A0F_RN ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }                        
            }
            else if($TFR == 1)    
            {
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_A0F_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_A0F_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }               
            }                        
            Croissants_get_EPs(3);
            Get_Croissants_ABCList();
        break;


      case 6 :
          string $Got_EPs=`optionMenu -q -v Croissants_EP`;

          string $BatchCut_Name =`textField -q -tx Croissants_MakeDir_FLD`;
                 $cutReArray = stringToStringArray($BatchCut_Name, "-");

            int $b_start = $cutReArray[0];
            int $b_end = $cutReArray[1];

        for ($i = $b_start; $i <= $b_end; $i++)
        {           

            if($i<100)
            {
                if($i<10)
                {
                $CutName = "C"+"00"+$i;    

                string $ani_nFile = $now_project_MakeAni + "/" + $meta_BranchA_MakeAni[1] + "/" + $meta_BranchA_MakeAni[3] + "/" + $Got_EPs + "/" + $CutName + "/" +$meta_BranchA_MakeAni[5] + "/";
                string $ani_BatchFiles = $G_I_3[0] + "_" + $Got_EPs + "_" + $CutName + "_Ani.0101.ma";
                string $ani_FullPathName = $ani_nFile + $ani_BatchFiles;
                sysFile -makeDir $ani_nFile;
                
                file -rn $ani_FullPathName ; 
                file -f -save  -options "v=0;" -type "mayaAscii";

                }
                else
                {
                $CutName = "C"+"0"+$i;    

                string $ani_nFile =$now_project_MakeAni + "/" + $meta_BranchA_MakeAni[1] + "/" + $meta_BranchA_MakeAni[3] + "/" + $Got_EPs + "/" + $CutName + "/" +$meta_BranchA_MakeAni[5] +  "/";
                string $ani_BatchFiles = $G_I_3[0] + "_" + $Got_EPs + "_" + $CutName + "_Ani.0101.ma";
                string $ani_FullPathName = $ani_nFile + $ani_BatchFiles;
                sysFile -makeDir $ani_nFile;

                file -rn $ani_FullPathName ; 
                file -f -save  -options "v=0;" -type "mayaAscii";
                }
            }
            else 
            {
              $CutName = "C"+$i;    

              string $ani_nFile = $now_project_MakeAni + "/" + $meta_BranchA_MakeAni[1] + "/" + $meta_BranchA_MakeAni[3] + "/" + $Got_EPs + "/" + $CutName + "/" +$meta_BranchA_MakeAni[5] + "/";
              string $ani_BatchFiles = $G_I_3[0] + "_" + $Got_EPs + "_" + $CutName + "_Ani.0101.ma";
              string $ani_FullPathName = $ani_nFile + $ani_BatchFiles;
              sysFile -makeDir $ani_nFile;

              file -rn $ani_FullPathName ; 
              file -f -save  -options "v=0;" -type "mayaAscii";
          }
            
        }
    
          Croissants_get_EPs(2);
          Croissants_get_EPs(3);
          break;      


        
        case 7 :

                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_Bake_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_Bake_RN_1 ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }          
            Croissants_get_EPs(3);
            Get_Croissants_ABCList();
        break;

        case 8 :
                if($PUBType_Ba == ".mb")
                {
                  string $exportType="mayaBinary";
                  file -rn $Croissants_Bake_RN_2 ;  
                  file -f -save  -options "v=0;" -type $exportType;                  
                }
                else if($PUBType_Ba == ".ma")
                {
                  string $exportType="mayaAscii";
                  file -rn $Croissants_Bake_RN_2 ;  
                  file -f -save  -options "v=0;" -type $exportType;                       
                }          
            Croissants_get_EPs(3);
            Get_Croissants_ABCList();
        break;



        case 9 :
               string $resultWindow_aniCustom = `promptDialog
                  -title "Save As"
                  -message "Enter the File Name\n\t"
                  -button "OK" -button "Cancel"
                  -defaultButton "OK" -cancelButton "Cancel"
                  -dismissString "Cancel"`;

                      if ($resultWindow_aniCustom == "OK")
                      {
                          string $CustomAni_N = `promptDialog -query -text`;  
                          string $Croissants_CustomAni = $CustomAni_N+".0001"+$PUBType_Ba;          
                          string $Croissants_Bake_RN_3 = $Croissants_AniRoot + $Croissants_CustomAni; 

                              if($PUBType_Ba == ".mb")
                              {
                                string $exportType="mayaBinary";
                                file -rn $Croissants_Bake_RN_3 ;  
                                file -f -save  -options "v=0;" -type $exportType;                  
                              }
                              else if($PUBType_Ba == ".ma")
                              {
                                string $exportType="mayaAscii";
                                file -rn $Croissants_Bake_RN_3 ;  
                                file -f -save  -options "v=0;" -type $exportType;                       
                              } 


                          Croissants_get_EPs(3);
                          Get_Croissants_ABCList();      

                      }
                      else error "cancled";            

        break;

    
    }
}


global proc Croissants_Playblast()
{
  select -cl;
  RS_HUD;
  string $wip_project = `workspace -q -fn`;
  string $wip_file_name =`file -q -sn -shn`;

  string $init[] = stringToStringArray($wip_file_name, ".");
  string $preEP[]= stringToStringArray($init[0], "_");

  int $eF =`intField -q -v Croissants_A02_ef`; 
  int $sF =`intField -q -v Croissants_A01_sf`; 

	string $dateDir = `date -shortDate`;
	string $arrayDir[];
	$arrayDir = stringToStringArray($dateDir, "/");
	string $arrayDirSort = $arrayDir[0]+$arrayDir[1];
  string $audio[] = `ls -type "audio"`;
  int $wiS = 1280;
  int $heS = 720;
  int $ckDate = `checkBox -q -v Croissants_PBD`;   
  if($ckDate != 1)   
  {
    string $playblastPath = "04_Renderimages/_Previz/"+$preEP[1] ;

    int $checkFolder =`file -q -exists $playblastPath`;
    if($checkFolder != 0)
    {

    }
    else
    {
    sysFile -makeDir $playblastPath;
    }
    string $playblastFile_n = $init[0] + "." + $init[1] + ".mov";
    string $playblastFile = $playblastPath + "/" + $playblastFile_n;


    lookThroughModelPanel _ShotCam modelPanel4;
    modelEditor -e -nurbsCurves false modelPanel4;
    modelEditor -e -polymeshes true modelPanel4;
    modelEditor -edit -displayAppearance "smoothShaded" -displayTextures on -displayLights "default" modelPanel4;
    
    playblast  -format qt -sound $audio[0] -filename $playblastFile -forceOverwrite  -sequenceTime 0 -clearCache 1 -viewer 0 -showOrnaments 1 -fp 4 -percent 100 -compression "PNG" -quality 100 -widthHeight $wiS $heS;
    textField -e -tx  "complete."  Croissants_msg;
  }
  else
  {
    string $playblastPath_D = "04_Renderimages/_Previz/"+$preEP[1] +"/"+ $arrayDirSort ;

    int $checkFolder =`file -q -exists $playblastPath_D`;
    if($checkFolder != 0)
    {

    }
    else
    {
    sysFile -makeDir $playblastPath_D;
    }
    string $playblastFile_n = $init[0] + "." + $init[1] + ".mov";
    string $playblastFile = $playblastPath_D + "/" + $playblastFile_n;
    
    lookThroughModelPanel _ShotCam modelPanel4;
    modelEditor -e -nurbsCurves false modelPanel4;
    modelEditor -e -polymeshes true modelPanel4;
    modelEditor -edit -displayAppearance "smoothShaded" -displayTextures on -displayLights "default" modelPanel4;

    playblast  -format qt -sound $audio[0] -filename $playblastFile -forceOverwrite  -sequenceTime 0 -clearCache 1 -viewer 0 -showOrnaments 1 -fp 4 -percent 100 -compression "PNG" -quality 100 -widthHeight $wiS $heS;
    textField -e -tx  "complete."  Croissants_msg;  
  }
  RS_HUD;
}


global proc Croissants_countKey(int $case)
{

int $DU = (`playbackOptions -q -max`)-100;
$cam =`ls "_ShotCam"`;
$sel =$cam[0];
    switch($case)
    {
        case 1 :
                currentTime -e 100;
                spaceLocator -p 0 0 0 -n "Point_Marker";
                for ($i = 0; $i < $DU; $i++)
                {    	    
                float $gVX=`getAttr ($sel+".rotateX")`;
                float $gVY=`getAttr ($sel+".rotateY")`;
                float $gVZ=`getAttr ($sel+".rotateZ")`;
                float $gRX=`getAttr ($sel+".rotateX")`;
                float $gRY=`getAttr ($sel+".rotateY")`;
                float $gRZ=`getAttr ($sel+".rotateZ")`; 
                float $gFL=`getAttr ($sel+".focalLength")`;
                float $sumA = $gVX+$gVY+$gVZ+$gRX+$gRY+$gRZ+$gFL;
                playButtonStepForward;
                float $sVX=`getAttr ($sel+".rotateX")`;
                float $sVY=`getAttr ($sel+".rotateY")`;
                float $sVZ=`getAttr ($sel+".rotateZ")`;
                float $sRX=`getAttr ($sel+".rotateX")`;
                float $sRY=`getAttr ($sel+".rotateY")`;
                float $sRZ=`getAttr ($sel+".rotateZ")`;
                float $sFL=`getAttr ($sel+".focalLength")`;
                float $sumB = $sVX+$sVY+$sVZ+$sRX+$sRY+$sRZ+$sFL;
                    if($sumA != $sumB)
                    {
                     setKeyframe "Point_Marker.tx";
                    }
                    else
                    {
                    print "Camera Hold";
                    }
                }   
        break;

        case 2 :
              float $TR[]=`keyframe -q -tc "Point_Marker"`;
              int $LT=size($TR);
              string $EndKey =$TR[$LT-1];
              string $printMarker = "M_"+$TR[0]+"_"+$EndKey;
              rename "Point_Marker" $printMarker;
        break;
    }   
    
} 




