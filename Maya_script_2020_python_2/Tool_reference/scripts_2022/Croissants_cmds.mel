global proc abc_arg_cmd(int $case) 
{
	string $argList[] = {
"abc_arg_01","abc_arg_02","abc_arg_03","abc_arg_04","abc_arg_05","abc_arg_06","abc_arg_07","abc_arg_08","abc_arg_09","abc_arg_10","abc_arg_11"
	};

    string $sel[] =`ls -sl`;
    string $abc_arguments_root =(`Croi_C_workspace`)+"/"+(`textField -q -tx croissants_TokenD`)+"/"+(`textField -q -tx croissants_TokenE`)+"/"+(`Croi_Root`)+"/"+(`Croi_Sub`)+"/"+"ABC"+"/";
    string $abc_name_cache =$abc_arguments_root+(`textField -q -tx "Croissants_ABC_name"`)+".abc ";
    string $abc_name_cam =$abc_arguments_root+ "_cam.abc ";    
    string $abc_range_Ani = "-frameRange " + (`intField -q -v"Croissants_A01_sf"`) + " " + (`intField -q -v"Croissants_A02_ef"`)+ " ";    
    string $abc_export_Typ_01 = "-root "+ $sel[0] + " "; 

	switch ($case)
	    {	
      case 0 :    
          for ($i=0; $i<size($argList); $i++ ) 
          {
              
            string $f_tokenized[];
            
            int $abc_argBX = `checkBox -q -v $argList[$i]`;
                if ($abc_argBX == 0)
                {   
                     
                }
                else
                {
                  string $abc_Flag = `checkBox -q -l $argList[$i]`;
                  string $f_tokenized = $f_tokenized + " " + $abc_Flag;
                  optionVar -iv "abc_arg_comb" 11 -sv "ff_args" $f_tokenized;               
                }
          }
          string $afix_01=substituteAllString((`optionVar -q "ff_args"`), "-dataFormat", "-dataFormat ogawa");
          string $afix_02=substituteAllString($afix_01, "-frameRange", $abc_range_Ani);
          string $afix_03=substituteAllString($afix_02, "-root", $abc_export_Typ_01);
                     
          string $abc_flags = "\"" + $afix_03 +" -file " + $abc_name_cache + "\"";	
          sysFile -makeDir $abc_arguments_root;    
          string $abc_cmd_01 = "AbcExport -j "+$abc_flags;     
          eval($abc_cmd_01);
          optionVar -remove abc_arg_comb;  
          
     break; 
     
     case 1 :
      select -hi;
      string $selected[] = `ls -sl`;
      string $shapes[] = `listRelatives -shapes -path $selected`;
      select $shapes;  
      abc_arg_cmd(0);
     break;     
     }
 
}    

global proc abc_arg_cmd_run(int $case) 
{
string $check_ExportName =`textField -q -tx Croissants_ABC_name`;
    switch($case)
    {
      case 1 :
              //command 1
              
              if(size($check_ExportName)==0)
              {
                 textField -e -tx "<<-Click | Hey! Must Set name in Here!" -bgc 0.32 0.15 0.35 Croissants_ABC_name;
              }
              else
              {
                frameLayout  -e -cl 1  Arguments_FL;
                 textField -e -bgc 0.15 0.15 0.15 Croissants_ABC_name;
                abc_arg_cmd(0);
                textField -e -tx "" Croissants_ABC_name;
                Get_Croissants_ABCList();                                  
              }
              

      break; 

      case 2 :
              //Camera OPtion
              abc_arg_cmd_run(7); 

              if(size($check_ExportName)==0)
              {
                 textField -e -tx "<<-Click | Hey! Must Set name in Here!" -bgc 0.32 0.15 0.35 Croissants_ABC_name;
              }
              else
              {
              textField -e -bgc 0.15 0.15 0.15 Croissants_ABC_name;              
              abc_arg_cmd(0);
              textField -e -tx "" Croissants_ABC_name;
              Get_Croissants_ABCList();
              Croissants_logStats(8);
              }
      break; 
      
      case 3 :
              //Set Bake (coretex Style) 
              abc_arg_cmd_run(5);             
 
              if(size($check_ExportName)==0)
              {
                 textField -e -tx "<<-Click | Hey! Must Set name in Here!" -bgc 0.32 0.15 0.35 Croissants_ABC_name;
              }
              else
              {
              textField -e -bgc 0.15 0.15 0.15 Croissants_ABC_name;                
              abc_arg_cmd(1);
              textField -e -tx "" Croissants_ABC_name;
              Get_Croissants_ABCList();
              }
      break; 

      case 31 :
              int $arg_FLOP =`frameLayout -q -cl Arguments_FL`;
              if($arg_FLOP == 1)
              {      
              frameLayout  -e -cl 0  Arguments_FL;   
              }
              else 
              {  
              frameLayout  -e -cl 1  Arguments_FL;   
              }
      break; 

      
      case 4 :              
              //preset 01 -±âş»°Ş              
              checkBox -e -v 0 "abc_arg_01";
              checkBox -e -v 1 "abc_arg_02";
              checkBox -e -v 1 "abc_arg_03";
              checkBox -e -v 1 "abc_arg_04";
              checkBox -e -v 1 "abc_arg_05";
              checkBox -e -v 1 "abc_arg_06";
              checkBox -e -v 1 "abc_arg_07";
              checkBox -e -v 1 "abc_arg_08";
              checkBox -e -v 0 "abc_arg_09";
              checkBox -e -v 1 "abc_arg_10";
              checkBox -e -v 1 "abc_arg_11";
              abc_arg_cmd_run(31);
      break; 

      case 5 :
              //Ľ±ĹĂżÉĽÇ 1
              checkBox -e -v 0 "abc_arg_01";
              checkBox -e -v 1 "abc_arg_02";
              checkBox -e -v 1 "abc_arg_03";
              checkBox -e -v 1 "abc_arg_04";
              checkBox -e -v 1 "abc_arg_05";
              checkBox -e -v 1 "abc_arg_06";
              checkBox -e -v 1 "abc_arg_07";
              checkBox -e -v 1 "abc_arg_08";
              checkBox -e -v 1 "abc_arg_09";
              checkBox -e -v 0 "abc_arg_10";
              checkBox -e -v 1 "abc_arg_11";
      break; 

      case 6 :
              //Ľ±ĹĂżÉĽÇ 2              
              checkBox -e -v 0 "abc_arg_01";
              checkBox -e -v 1 "abc_arg_02";
              checkBox -e -v 0 "abc_arg_03";
              checkBox -e -v 1 "abc_arg_04";
              checkBox -e -v 1 "abc_arg_05";
              checkBox -e -v 1 "abc_arg_06";
              checkBox -e -v 1 "abc_arg_07";
              checkBox -e -v 1 "abc_arg_08";
              checkBox -e -v 1 "abc_arg_09";
              checkBox -e -v 0 "abc_arg_10";
              checkBox -e -v 1 "abc_arg_11";

       break;   
       
      case 7 :
              checkBox -e -v 1 "abc_arg_01";
              checkBox -e -v 0 "abc_arg_02";
              checkBox -e -v 0 "abc_arg_03";
              checkBox -e -v 0 "abc_arg_04";
              checkBox -e -v 1 "abc_arg_05";
              checkBox -e -v 0 "abc_arg_06";
              checkBox -e -v 0 "abc_arg_07";
              checkBox -e -v 1 "abc_arg_08";
              checkBox -e -v 0 "abc_arg_09";
              checkBox -e -v 1 "abc_arg_10";
              checkBox -e -v 1 "abc_arg_11";
       break;            
    }
} 
    
    
    
    


global proc Get_Croissants_ABCList()
{  
    string $now_project_Alembic = `workspace -q -fn`;
    string $ProjectType_Alembic[]= `getFileList -folder $now_project_Alembic -filespec "*.ini"`;
    string $ProjectNote_Alembic = $now_project_Alembic +"/"+ $ProjectType_Alembic[0];
           $noteId_Alembic = `fopen $ProjectNote_Alembic "r"` ;  
    string $note_info_Alembic = `fread $noteId_Alembic $note_info_Alembic` ; 
                                 fclose $noteId_Alembic;       

    string $note_info_Alembics[];  
           $note_info_Alembics = stringToStringArray($note_info_Alembic, "."); 
    string $meta_treeA_Alembic = $note_info_Alembics[3];
           $meta_BranchA_Alembic = stringToStringArray($meta_treeA_Alembic, "|"); 
    string $meta_treeB_Alembic = $note_info_Alembics[4];
           $meta_BranchB_Alembic = stringToStringArray($meta_treeB_Alembic, ","); 
           
    string $EPs_abc=`optionMenu -q -v Croissants_EP`;
    string $CUTs_GET=`optionMenu -q -v Croissants_CUT`;
    
    string $Alembic_Path = $now_project_Alembic + "/" + $meta_BranchA_Alembic[1] + "/" +$meta_BranchA_Alembic[2] + "/" + $EPs_abc + "/" + $CUTs_GET + "/ABC/";

    string $dir_list[] = `getFileList -folder $Alembic_Path -filespec "*.*"`;
    string $dir_list_sort[];
           $dir_list_sort=sort($dir_list);
    

        textScrollList -edit -removeAll Croissants_ABC_List;

        for ($i = 0; $i < size($dir_list_sort); $i++)
        {           
          textScrollList   -ams 1 -sc "" -dcc "Import_Croissants_Cache(2);" -e -a $dir_list_sort[$i] Croissants_ABC_List;
         
        }
        //.  Toggle Trick
      iconTextButton -e -c "Get_Croissants_ABC_BakeList"  Croissants_GET_ABC;


}



  
global proc selectRENameCam()
{
  string $ProjectPath = `workspace -q -fn`;
  string $Load_init[]= `getFileList -folder $ProjectPath -filespec "*.ini"`;
  string $ini_gets_each = $Load_init[0]; 
  string $GetsWorld[] = stringToStringArray($ini_gets_each, ".");
  //string $pEP_N=`optionMenu -q -v Croissants_EP`;
  string $pCut_N = `optionMenu -q -v Croissants_CUT`;
  string $pprEF =`intField -q -v Croissants_A02_ef`; 
  string $pprSF =`intField -q -v Croissants_A01_sf`; 
  string $SeLcamName = $GetsWorld[0] +"_" + $pCut_N + "_" + $pprSF + "_" + $pprEF +"_Cam";

select -r $SeLcamName;
Croissants_BakeCam;
}




global proc IncremnetTAG(int $case)
{
  switch($case)
  {
  case 1 :
  string $value =`intField -q -v Croissants_Increment_Tag`;
  int $math = $value;
  int $incremnetValue = $math + 1;
  intField -e -v $incremnetValue Croissants_Increment_Tag;
  break;
  
  case 2 :
  intField -e -v 0 Croissants_Increment_Tag;
  break;

  case 3 :
  string $value_C3 =`intField -q -tv Croissants_Increment_Tag`;
  int $math_C3 = $value_C3;
  int $incremnetValue_C3 = $math_C3 - 1;
  intField -e -v $incremnetValue_C3 Croissants_Increment_Tag;
  break;
  }
}  
  

global proc Import_Croissants_Cache(int $case)
{
    string $now_project_AlembicIO_I = `workspace -q -fn`;
    string $ProjectType_AlembicIO_I[]= `getFileList -folder $now_project_AlembicIO_I -filespec "*.ini"`;
    string $ProjectNote_AlembicIO_I = $now_project_AlembicIO_I +"/"+ $ProjectType_AlembicIO_I[0];
           $noteId_AlembicIO_I = `fopen $ProjectNote_AlembicIO_I "r"` ;  
    string $note_info_AlembicIO_I = `fread $noteId_AlembicIO_I $note_info_AlembicIO_I` ; 
                         fclose $noteId_AlembicIO_I;       

    string $note_info_AlembicIO_Is[];  
           $note_info_AlembicIO_Is = stringToStringArray($note_info_AlembicIO_I, "."); 
    string $meta_treeA_AlembicIO_I = $note_info_AlembicIO_Is[3];
           $meta_BranchA_AlembicIO_I = stringToStringArray($meta_treeA_AlembicIO_I, "|"); 
    string $meta_treeB_AlembicIO_I = $note_info_AlembicIO_Is[4];
           $meta_BranchB_AlembicIO_I = stringToStringArray($meta_treeB_AlembicIO_I, ","); 
           
string $EP_n=`optionMenu -q -v Croissants_EP`;
string $CUT_n=`optionMenu -q -v Croissants_CUT`;

string $Alembic_Path = $now_project_AlembicIO_I + "/" + $meta_BranchA_AlembicIO_I[1] + "/" +$meta_BranchA_AlembicIO_I[2] + "/" + $EP_n + "/" + $CUT_n + "/ABC/";

string $Croissants_ABC[] = `textScrollList -q -si Croissants_ABC_List`;

  switch($case)
  {
  
       //Import Alembic Cache via Exocortex Crate
      case 1 :
              for ($i=0; $i<size($Croissants_ABC); $i++)
              {
                string $ABC_filename = $Alembic_Path + $Croissants_ABC[$i];
                string $ABC = "filename=" + $ABC_filename + ";normals=" + "0"+ ";uvs=" + "1" + ";facesets=" + "1" + ";multi=" + "0" + ";fitTimeRange=" + "0";
                ExocortexAlembic_import -j $ABC;
              }
      break;                  

     //Import Alembic Cache via Maya
      case 11 :
              for ($i=0; $i<size($Croissants_ABC); $i++)
              {
                string $ABC_filename = $Alembic_Path + $Croissants_ABC[$i];                
                AbcImport -mode import $ABC_filename;
              }
      break;   

      //Attach Alembic Cache via Exocortex Crate
      case 2 :
              for ($i=0; $i<size($Croissants_ABC); $i++)
              {
              //$toKen_a = stringToStringArray($Croissants_ABC[$i], "_");
              //$token_b = $tK1[1];
              string $cache_name = $Croissants_ABC[$i];      
              string $Path = $Alembic_Path + $cache_name;
              string $Attach_Job = "filename=" + $Path + ";normals=" + "False" + ";uvs=" + "True" + ";facesets=" + "True" + ";attachToExisting=1;overXforms=" + "True" + ";overDforms=" + "False";
              ExocortexAlembic_import -j $Attach_Job;   
              }   
      break;  
      
      //Attach(import) Alembic Cache via Maya 
      case 21 :
              for ($i=0; $i<size($Croissants_ABC); $i++)
              {
              string $cache_name_m = $Croissants_ABC[$i];      
              string $Path_B = $Alembic_Path + $cache_name_m;              
              AbcImport -mode import -connect "/" $Path_B;   
              }   
      break;  


      case 3 :

                string $ABC_filename = $Alembic_Path + "_cam.abc";
                string $ABC = "filename=" + $ABC_filename + ";normals=" + "0"+ ";uvs=" + "1" + ";facesets=" + "1" + ";multi=" + "0" + ";fitTimeRange=" + "0";
                ExocortexAlembic_import -j $ABC;

      break;   

      case 4 :
              for ($i=0; $i<size($Croissants_ABC); $i++)
              {
                $GET_List = stringToStringArray($Croissants_ABC[$i], "_");
                int $GET_TypeSize = size($GET_List[0]);
                int $S = $GET_TypeSize + 2;
                string $SC_Assets = `substring $Croissants_ABC[$i] $S (size($Croissants_ABC[$i]) - 4)`;

                string $sel_name = $SC_Assets + ":" + $SC_Assets;                              
                select -r $sel_name;
                Unparent;
                select -cl;
              }   
      break; 



  }

}

global proc Import_Croissants_Cache_Op(int $case)
{

  switch($case)
  {
    case 1 :

          Import_Croissants_Cache(11);

    break;
    
    case 2 :

          Import_Croissants_Cache(22);

    break;
  }

}


global proc Get_Croissants_ABC_BakeList()
{
    string $EPs_abcBake=`optionMenu -q -v Croissants_EP`;
    string $CUTs_BakeList=`optionMenu -q -v Croissants_CUT`;
    string $Bake_list[] = `ls "*:BakeSet"`;
    string $Bake_list_sort[];
           $Bake_list_sort=sort($Bake_list);

          select -cl;
    textScrollList -edit -removeAll Croissants_ABC_List;
    for ($i = 0; $i < size($Bake_list_sort); $i++)
    {
                
        textScrollList   -ams 1 -sc "" -dcc "Sel_Croissants_BakeList()" -e -a $Bake_list_sort[$i] Croissants_ABC_List;
        			popupMenu -mm 1 -parent Croissants_ABC_List;
                        menuItem-rp "N"
                          -label "Bake This"
                          -c "BakeABC_Each";                         
                          
                        menuItem-rp "S"
                          -label "Select This"
                          -c "Sel_Croissants_BakeList_ADD";
    }

      //Toggle Trick
      iconTextButton -e -c "Get_Croissants_ABCList"  Croissants_GET_ABC;
      Croissants_BakeSet_List_PM(1);
 

      
}

global proc Croissants_BakeSet_List_PM(int $case)
{
    //Query PopupMenu
    int $PM_exQuery = `popupMenu -q -ex  QuickCroissants_POP`;
    if($PM_exQuery == 0)
    {
     //Pass 
    }
    else
    {
    popupMenu -e -dai  QuickCroissants_POP;    
    }    

    switch($case)
    {
    case 1 :
        popupMenu -mm 1 -parent Croissants_ABC_List QuickCroissants_POP;
        menuItem -rp "W" -l "Re-Sort"       -c "RMV_Croissants_NukeABCList"         -p QuickCroissants_POP Croissants_POPmm1;
        menuItem -rp "E" -l "Get Bake List" -c "Get_Croissants_ABC_BakeList"        -p QuickCroissants_POP Croissants_POPmm2;
        menuItem -rp "N" -l "Bake This"     -c "Croissants_BakeABC_EachBatch"          -p QuickCroissants_POP Croissants_POPmm3;
        menuItem -rp "S" -l "Select This"   -c "Sel_Croissants_BakeList_ADD"        -p QuickCroissants_POP Croissants_POPmm4;            
        menuItem -divider true -p QuickCroissants_POP Croissants_POPmm44; 
        menuItem -label "Delete Select File" -c "Del_Croissants_ABC_BakeList" -p QuickCroissants_POP Croissants_POPmm5; 
        menuItem -label "switch ATOM" -c "Croissants_BakeSet_List_PM(2)" -p QuickCroissants_POP Croissants_POPmm6;
    break;
    
    case 2 :
        popupMenu -mm 1 -parent Croissants_ABC_List QuickCroissants_POP;
        menuItem -rp "W" -l "Query Exists Files "  -c "Croissants_ATOM(4);"  -p QuickCroissants_POP Croissants_POPmm1;
        menuItem -rp "E" -l "Get ATOM Set "  -c "Croissants_ATOM(5);"  -p QuickCroissants_POP Croissants_POPmm2;
        //menuItem -rp "ES" -l "Select ATOM Set "  -c "Croissants_ATOM(6);"  -p QuickCroissants_POP Croissants_POPmm2B;        
        menuItem -rp "N" -l "ATOM Export"          -c "Croissants_ATOM(1);"  -p QuickCroissants_POP Croissants_POPmm3;
        menuItem -rp "S" -l "Clear List"          -c "Croissants_ATOM(8);"  -p QuickCroissants_POP Croissants_POPmm4;
        menuItem -divider true -p QuickCroissants_POP Croissants_POPmm44; 
        menuItem -label "Delete Select File" -c "Croissants_ATOM(9);" -p QuickCroissants_POP Croissants_POPmm5;
        menuItem -label "switch Alembic" -c "Croissants_BakeSet_List_PM(1)" -p QuickCroissants_POP Croissants_POPmm6;             
    break;            
    }
}

