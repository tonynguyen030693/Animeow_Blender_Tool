global proc MOD_CleanUP()
{
if (`window -ex ModEnd_WIN`) deleteUI ModEnd_WIN;
window -t "End of Modeling" -widthHeight 250 50  -mnb 0 -tb 1 -toolbox 1 -s 1 ModEnd_WIN;


	columnLayout -adj 1 columnLayout;
		rowLayout -numberOfColumns 2 -cw 1 150 -cw 2 80 -adj 2 rowLayout0;
		textField -tx "CH_SET" -w 150 -h 40  mNameFieldX;
		
          popupMenu -mm 1 -parent mNameFieldX;
              menuItem -label "CP_SET" -i "newPreset.png" -c "Mod_CleanUP_POP(1)";
              menuItem -divider true;		
              menuItem -label "BG_SET" -i "newPreset.png" -c "Mod_CleanUP_POP(2)";	
              menuItem -divider true;
              menuItem -label "PR_SET" -i "newPreset.png" -c "Mod_CleanUP_POP(3)";	
              menuItem -divider true;
              menuItem -label "CH_SET" -i "newPreset.png" -c "Mod_CleanUP_POP(4)";	
              menuItem -divider true;
		
		button -w 80 -h 40 -c "EndofModReName()" -l "Run" mRun_Btt;
	setParent..;
	separator -hr 1 -style "double" sep0;	


showWindow ModEnd_WIN;

}

global proc EndofModReName()
{
string $m_name = `textField -q -tx mNameFieldX`;    


string $sel[] =`ls -sl`;
  if (size($sel) == 0)
    {string $result = `group -em -w -n ModGrp`;string $result_R = `group -em -w -n RigGrp`;
        select -cl;
        group -w -n $m_name ModGrp RigGrp;
        
    }
  else
    {string $result = `group -w -n ModGrp $sel`;string $result_R = `group -em -w -n RigGrp`;
        xform -ws -a -rp 0 0 0 -sp 0 0 0;
        select -cl;
        group -w -n $m_name ModGrp RigGrp;
        xform -ws -a -rp 0 0 0 -sp 0 0 0;
    }
    
select -cl;

circle -c 0 0 0 -nr 0 1 0 -sw 360 -r 5 -d 3 -ut 0 -tol 0.01 -s 8 -ch 1 -n "Sub";
circle -c 0 0 0 -nr 0 1 0 -sw 360 -r 8 -d 3 -ut 0 -tol 0.01 -s 8 -ch 1 -n "World";
parent Sub World ;
parent World RigGrp ;

select -cl;
select -r ModGrp;
select -hi;
string $sel_Mod[] = `ls -sl`;
string $filterSelect[] = `filterExpand -sm 12 $sel_Mod`;
select -r $filterSelect;
$createSetResult = `sets -name "BakeSet"`;
}

