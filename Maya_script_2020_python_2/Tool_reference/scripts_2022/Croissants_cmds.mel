      }    
    
}
global proc Sel_Croissants_BakeList_ADD()
{
      string $Croissants_ABC[] = `textScrollList -q -si Croissants_ABC_List`; 
      for ($i=0; $i<size($Croissants_ABC); $i++)
      {
        
        string $BakeSET = $Croissants_ABC[$i];

        string $sel_name = $BakeSET; // + ":BakeSet";                            
        select -add $sel_name;
      }    
    
}


global proc Del_Croissants_ABC_BakeList()
{
    string $now_project_AlembicMD = `workspace -q -fn`;
    string $ProjectType_AlembicMD[]= `getFileList -folder $now_project_AlembicMD -filespec "*.ini"`;
    string $ProjectNote_AlembicMD = $now_project_AlembicMD +"/"+ $ProjectType_AlembicMD[0];
           $noteId_AlembicMD = `fopen $ProjectNote_AlembicMD "r"` ;  
    string $note_info_AlembicMD = `fread $noteId_AlembicMD $note_info_AlembicMD` ; 
                                 fclose $noteId_AlembicMD;       

    string $note_info_AlembicMDs[];  
           $note_info_AlembicMDs = stringToStringArray($note_info_AlembicMD, "."); 
    string $meta_treeA_AlembicMD = $note_info_AlembicMDs[3];
           $meta_BranchA_AlembicMD = stringToStringArray($meta_treeA_AlembicMD, "|"); 
    string $meta_treeB_AlembicMD = $note_info_AlembicMDs[4];
           $meta_BranchB_AlembicMD = stringToStringArray($meta_treeB_AlembicMD, ","); 
           
    string $EPs_abc=`optionMenu -q -v Croissants_EP`;
    string $CUTs_GET=`optionMenu -q -v Croissants_CUT`;
    
    string $AlembicMD_Path = $now_project_AlembicMD + "/" + $meta_BranchA_AlembicMD[1] + "/" +$meta_BranchA_AlembicMD[2] + "/" + $EPs_abc + "/" + $CUTs_GET + "/ABC/";


    $response_Del = `confirmDialog -title "Confirm" 
                    -message "ÁřÂĄ·Î ĆÄŔĎŔ» Áöżď°Ç°ˇżä?"
                    -button "Yes" 
                    -button "No"
                    -defaultButton "Yes"
                    -cancelButton "No"
                    -dismissString "No"`;
    
    // check response	  
    if( $response_Del == "Yes" ) 
    {   
        string $Croissants_ABC[] = `textScrollList -q -si Croissants_ABC_List`;

            for ($i=0; $i<size($Croissants_ABC); $i++)
            {
            string $Croissants_ABC_filename = $AlembicMD_Path+$Croissants_ABC[$i];
            sysFile -delete $Croissants_ABC_filename;    

            }
        Get_Croissants_ABCList();
        print("Ľ±ĹĂÇŃ ĆÄŔĎŔ» Áöżü˝Ŕ´Ď´Ů.\n"); 
    } 
    else if( $response_Del == "No" ) 
    {
      print("ČŢ~~~ ^^;\n");
    }
}





global proc Croissants_BakeCamFBX()
{
    Croissants_logStats(7); //MakeFolder
    $Curr_project = `workspace -q -fn`;
      $RootPath = stringToStringArray($Curr_project, "/");
      $project = $RootPath[0] + "\\" + $RootPath[1]+ "\\" + $RootPath[2];
    string $EP_n=`optionMenu -q -v Croissants_EP`;
    string $CUT_n=`optionMenu -q -v Croissants_CUT`;
    string $Alembic_Path = $project + "\\02_Scenes\\05_Lighting\\" + $EP_n + "\\" + $CUT_n + "\\ABC\\";
    string $ABC_filename = $Alembic_Path + "_cam";
    file -force -options "v=0;" -typ "FBX export" -pr -es $ABC_filename;
    Get_Croissants_ABCList();
    Croissants_logStats(8); //Write Info
}
 

global proc RMV_Croissants_NukeABCList()
{
    textScrollList  -e -ri "_cam.abc" Croissants_ABC_List;
    textScrollList  -e -ri "_plate.abc" Croissants_ABC_List;
}



