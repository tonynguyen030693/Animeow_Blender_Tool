//File Opne Scripts
//////////////////////////////////////////////////////////

global proc OPEN_Croissants_files(int $case)
{
    string $G_Croi_C_WS =`Croi_C_workspace`;
    string $G_Croi_Root=`Croi_Root`;
    string $G_Croi_Sub=`Croi_Sub`;    
    string $G_Croi_Scenes_01=`textField -q -tx croissants_TokenD`;
    string $G_Croi_Scenes_02=`textField -q -tx croissants_TokenF`;
    string $G_Croi_Scenes_03=`textField -q -tx croissants_TokenE`;    
    string $G_Croi_Scenes_04=`textField -q -tx croissants_TokenJ`;
    
    string $G_Croi_Scenes_05=`textField -q -tx croissants_TokenI`;
    string $Ani_SubDir=`textField -q -tx croissants_TokenH`;
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  //Ani&Light

  string $Ani_Path = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" + $G_Croi_Scenes_02 + "/" + $G_Croi_Root + "/" + $G_Croi_Sub + "/" +$Ani_SubDir + "/";
  string $Ani_Path_1 = $G_Croi_C_WS + "/" +$G_Croi_Scenes_01 + "/" + $G_Croi_Scenes_02 + "/" + $G_Croi_Root + "/" + $Ani_SubDir + "/" + $G_Croi_Sub + "/";
 
  string $Lit_Path_2 = $G_Croi_C_WS + "/" + $G_Croi_Scenes_01 + "/" +$G_Croi_Scenes_03 + "/" + $G_Croi_Root + "/" + $G_Croi_Sub + "/";
  string $Z_Path = $Lit_Path_2 + "Z_Source/";
  
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  //Assets  
  string $AssetsFile_C3 = $G_Croi_C_WS + "/"  +$G_Croi_Scenes_05 + "/" + (`optionMenu -q -v Croissants_Assets`) + "/" +(`optionMenu -q -v Croissants_Assets_2`) + "/";
  string $AssetsFile_C4 = $AssetsFile_C3 + "_His/";
  string $AssetsFile_C4_pub = $AssetsFile_C3 + "pub/";

  string $AssetsFile_C3_son = $G_Croi_C_WS + "/" + $G_Croi_Scenes_05 + "/" + (`optionMenu -q -v Croissants_Assets`) + "/" +(`optionMenu -q -v Croissants_Assets_2`) + "/" + (`optionMenu -q -v Croissants_Assets_3`) + "/";
  string $AssetsFile_C4_son = $AssetsFile_C3_son + "_His/";
  string $AssetsFile_C4_son_pub = $AssetsFile_C3_son + "pub/";

  
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  //Modeling

  string $AssetsFile_C6 = $G_Croi_C_WS + "/" + $G_Croi_Scenes_04 + "/" + (`optionMenu -q -v Croissants_MOD`) + "/" + (`optionMenu -q -v Croissants_MOD_2`) + "/"; 
  string $AssetsFile_C61 = $AssetsFile_C6 + "_His/";  
  
  string $AssetsFile_C6_son = $G_Croi_C_WS + "/" + $G_Croi_Scenes_04 + "/" + (`optionMenu -q -v Croissants_MOD`) + "/" + (`optionMenu -q -v Croissants_MOD_2`) + "/" + (`optionMenu -q -v Croissants_MOD_3`) + "/";
  string $AssetsFile_C61_son = $AssetsFile_C6_son + "_His/";
  
  string $Croissants_List_MOD[] = `textScrollList -q -si Croissants_Model_List_1`;  
  
  int $valueRefname =`checkBox -q -v ref_namerule`; 
  int $valueRefname_MOD =`checkBox -q -v MOD_ref_namerule`; 
  int $note_infos_Assets = `checkBox -q -v Episodic`;
  
  int $TokenRlue=`textField -q -tx croissants_TokenP`;   
  
  switch($case)
  {

      case 1 :

              string $Croissants_Ani[] = `textScrollList -q -si Croissants_Ani_List`;

                  for ($i=0; $i<size($Croissants_Ani); $i++)
                  {
                      if($TokenRlue == 0)
                      {                      
                          string $Ani_filename = $Ani_Path+$Croissants_Ani[$i];                          
                          if(`gmatch $Croissants_Ani[$i] "*ma"` == 1)
                          {                        
                            file -f  -ignoreVersion  -typ "mayaAscii" -o $Ani_filename; 
                          }
                          else if(`gmatch $Croissants_Ani[$i] "*mb"` == 1)
                          {
                            file -f  -ignoreVersion  -typ "mayaBinary" -o $Ani_filename;
                          }
                          else
                          {
                            file -f  -ignoreVersion -o $Ani_filename;
                          }
                      }
                      else if($TokenRlue == 1)    
                      {
                          string $Ani_filename = $Ani_Path_1+$Croissants_Ani[$i];
                          if(`gmatch $Croissants_Ani[$i] "*ma"` == 1)
                          {                        
                            file -f  -ignoreVersion  -typ "mayaAscii" -o $Ani_filename; 
                          }
                          else if(`gmatch $Croissants_Ani[$i] "*mb"` == 1)
                          {
                            file -f  -ignoreVersion  -typ "mayaBinary" -o $Ani_filename;
                          }
                          else
                          {
                            file -f  -ignoreVersion -o $Ani_filename;
                          }
                                             
                      } 
                            
                    GET_Croissants_TIME();
                  }
                    get_CurrUnit_CC();
                    Get_Croissants_ABCList();
      break;                  

      case 2 :
              
              string $Croissants_Lit[] = `textScrollList -q -si Croissants_Lit_List`;

                  for ($i=0; $i<size($Croissants_Lit); $i++)
                  {
                  string $Lit_filename = $Lit_Path_2+$Croissants_Lit[$i];
                  file -f  -ignoreVersion   -o $Lit_filename; //-typ "mayaAscii"
                  
                  }
                    get_CurrUnit_CC();
                    Get_Croissants_ABCList();
                    //textField -e -tx  "1"  Rs_REN_Range;
                    
                    
      break;     

      case 3 :
              //Open          
              string $Croissants_List[] = `textScrollList -q -si Croissants_Assets_List_1`;

                  for ($i=0; $i<size($Croissants_List); $i++)
                  {
                      if($note_infos_Assets == 0)
                      {
                      string $Lit_filename = $AssetsFile_C3+$Croissants_List[$i];
                      file -f  -ignoreVersion   -o $Lit_filename; //-typ "mayaAscii"  
                      }
                      else
                      {
                      string $Lit_filename = $AssetsFile_C3_son+$Croissants_List[$i];
                      file -f  -ignoreVersion   -o $Lit_filename;                      
                      }
                  get_CurrUnit_CC();
                  }     
      break;   
        
      case 33 :
              //Open  Lookdevpub        
              string $Croissants_List33[] = `textScrollList -q -si Croissants_LookDevPub_List`;

                  for ($i=0; $i<size($Croissants_List33); $i++)
                  {
                      if($note_infos_Assets == 0)
                      {
                      string $Lit_filename = $AssetsFile_C4_pub+$Croissants_List33[$i];
                      file -f  -ignoreVersion   -o $Lit_filename; //-typ "mayaAscii"  
                      }
                      else
                      {
                      string $Lit_filename = $AssetsFile_C4_son_pub+$Croissants_List33[$i];
                      file -f  -ignoreVersion   -o $Lit_filename;                      
                      }
                  get_CurrUnit_CC();
                  }     
      break;   
      case 4 : 
               //Reference     
              string $Croissants_List_Case4[] = `textScrollList -q -si Croissants_Assets_List_1`;

              
                  for ($i=0; $i<size($Croissants_List_Case4); $i++)
                  {
                      if($note_infos_Assets == 0)       
                      {                  
                      string $Lit_filename = $AssetsFile_C3+$Croissants_List_Case4[$i];
                      $getName = stringToStringArray($Croissants_List_Case4[$i], ".");
                                                                
                          if ($valueRefname == 1)
                          {
                            $AssetName = (`optionMenu -q -v Croissants_Assets_2`); 
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $AssetName -options "v=0" $Lit_filename; 
                          }
                          else
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                      }
                      
                      else
                      {
                      string $Lit_filename = $AssetsFile_C3_son+$Croissants_List_Case4[$i];
                      $getName = stringToStringArray($Croissants_List_Case4[$i], ".");
                                                
                            if ($valueRefname == 1)
                            {
                            $AssetName = (`optionMenu -q -v Croissants_Assets_3`);
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $AssetName -options "v=0" $Lit_filename; 
                            }
                            else                            
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                            
                        }
                  } 
                       
                  get_CurrUnit_CC();
                    
      break;  
                    
      case 44 : 
               //Reference   LookDevPub  
              string $Croissants_List_Case44[] = `textScrollList -q -si Croissants_LookDevPub_List`;
               
              
                  for ($i=0; $i<size($Croissants_List_Case44); $i++)
                  {
                      if($note_infos_Assets == 0)       
                      {                  
                      string $Lit_filename = $AssetsFile_C4_pub+$Croissants_List_Case44[$i];
                      $getName = stringToStringArray($Croissants_List_Case44[$i], ".");
                      $AssetName = (`optionMenu -q -v Croissants_Assets_2`);                                           
                        if ($valueRefname == 1)
                        {
                          checkBox -e -v 0 ref_namerule;
                          file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                        //file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $AssetName -options "v=0" $Lit_filename; 
                        }
                        else
                          file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                      }
                      else
                      {
                      string $Lit_filename = $AssetsFile_C4_son_pub+$Croissants_List_Case44[$i];
                      $getName = stringToStringArray($Croissants_List_Case44[$i], ".");
                      $AssetName = (`optionMenu -q -v Croissants_Assets_3`); 
                        if ($valueRefname == 1)
                        {
                          checkBox -e -v 0 ref_namerule;                                              
                          file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                        //file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $AssetName -options "v=0" $Lit_filename; 
                        }
                        else
                          file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $Lit_filename; 
                      } 
                  }                         
                  get_CurrUnit_CC();checkBox -e -v 1 ref_namerule; 
                    
      break;  

      case 41 :              
              //Import
              string $Croissants_List_Case41[] = `textScrollList -q -si Croissants_Assets_List_1`;

                  for ($i=0; $i<size($Croissants_List_Case41); $i++)
                  {
                      if($note_infos_Assets == 0)
                      {                  
                      string $Assets_filename41 = $AssetsFile_C3 + $Croissants_List_Case41[$i];                
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $Assets_filename41; //-typ "mayaAscii"
                      }
                      else
                      {
                      string $Assets_filename41 = $AssetsFile_C3_son + $Croissants_List_Case41[$i];                
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $Assets_filename41; //-typ "mayaAscii"                      
                      }
                  }
                  get_CurrUnit_CC();
                    
      break;  

      case 42 :
              //Open Assets History File
                  string $Croissants_List_Case42[] = `textScrollList -q -si Croissants_Assets_List_His`;

                    for ($i=0; $i<size($Croissants_List_Case42); $i++)
                    {
                      if($note_infos_Assets == 0)
                      {                                           
                      string $Assets_His_filename = $AssetsFile_C4+ $Croissants_List_Case42[$i];
                      file -f  -ignoreVersion   -o $Assets_His_filename; 
                      }
                      else
                      {
                      string $Assets_His_filename = $AssetsFile_C4_son+ $Croissants_List_Case42[$i];
                      file -f  -ignoreVersion   -o $Assets_His_filename;                       
                      }
                    }
                  get_CurrUnit_CC();
                  textScrollList -e -da Croissants_Assets_List_His;
      break;


      case 43 :              
              //Import - LookDev
              string $Croissants_List_Case43[] = `textScrollList -q -si Croissants_LookDevPub_List`;

                  for ($i=0; $i<size($Croissants_List_Case43); $i++)
                  {
                      if($note_infos_Assets == 0)
                      {                  
                      string $Assets_filename43 = $AssetsFile_C4_pub + $Croissants_List_Case43[$i];                
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $Assets_filename43; //-typ "mayaAscii"
                      }
                      else
                      {
                      string $Assets_filename43 = $AssetsFile_C4_son_pub + $Croissants_List_Case43[$i];                
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $Assets_filename43; //-typ "mayaAscii"                      
                      }
                  }
                  get_CurrUnit_CC();
                    
      break;  



      case 5 :  
              //Opne Source Files
                string $Croissants_src[] = `textScrollList -q -si Croissants_src_List`;

                  for ($i=0; $i<size($Croissants_src); $i++)
                  {
                  string $src_filename = $Z_Path+$Croissants_src[$i];
                  file -f  -ignoreVersion   -o $src_filename; //-typ "mayaAscii"
                  
                  }
                    get_CurrUnit_CC();
               
      break; 
      

      case 6 :
              //Opne Modeling file
                    for ($i=0; $i<size($Croissants_List_MOD); $i++)
                    {
                      if($note_infos_Assets == 0)
                      {                      
                      string $MOD_filename = $AssetsFile_C6+$Croissants_List_MOD[$i];
                      file -f  -ignoreVersion   -o $MOD_filename; //-typ "mayaAscii"
                      }
                      else
                      {
                      string $MOD_filename = $AssetsFile_C6_son+$Croissants_List_MOD[$i];
                      file -f  -ignoreVersion   -o $MOD_filename;                  
                      }
                    }
                  get_CurrUnit_CC();
                  //textScrollList -e -da Croissants_Mod_List_His;
      break;                

      case 61 :
            //Opne Modeling History file
                  string $Croissants_List_MOD_His[] = `textScrollList -q -si Croissants_Model_List_3`;

                    for ($i=0; $i<size($Croissants_List_MOD_His); $i++)
                    {
                      if($note_infos_Assets == 0)
                      {                      
                      string $MOD_His_filename = $AssetsFile_C61+$Croissants_List_MOD_His[$i];
                      file -f  -ignoreVersion   -o $MOD_His_filename; 
                      }
                      else
                      {
                      string $MOD_His_filename = $AssetsFile_C61_son+$Croissants_List_MOD_His[$i];
                      file -f  -ignoreVersion   -o $MOD_His_filename;                       
                      }
                    }  
                  get_CurrUnit_CC();
                  textScrollList -e -da Croissants_Model_List_1;
      break;
      
      case 62 :
          //Import Modeling file      
                    for ($i=0; $i<size($Croissants_List_MOD); $i++)
                    {
                      if($note_infos_Assets == 0)
                      {                        
                      string $MOD_filename = $AssetsFile_C6+$Croissants_List_MOD[$i];            
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $MOD_filename; 
                      }
                      else
                      {
                      string $MOD_filename = $AssetsFile_C6_son+$Croissants_List_MOD[$i];            
                      file -import  -ignoreVersion  -mergeNamespacesOnClash false -options "v=0;"  -pr $MOD_filename;                       
                      }
                    }
                  get_CurrUnit_CC();

      break;

      case 64 : 
               //Reference     
              string $Croissants_List_MOD_Ref[] = `textScrollList -q -si Croissants_Model_List_1`;

                  for ($i=0; $i<size($Croissants_List_MOD_Ref); $i++)
                  {
                      //Q File Depth Root/Sub or Root/EP/Sub
                      if($note_infos_Assets == 0)       
                      {                  
                      string $MOD_fileName = $AssetsFile_C6+$Croissants_List_MOD_Ref[$i];
                      $getName = stringToStringArray($Croissants_List_MOD_Ref[$i], ".");
                          //NameSpace Use Q                                      
                          if ($valueRefname_MOD == 1)
                          {
                            $ModName = (`optionMenu -q -v Croissants_MOD_2`); 
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $ModName -options "v=0" $MOD_fileName; 
                          }
                          else
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $MOD_fileName; 
                      }
                      
                      else
                      {
                      string $MOD_fileName = $AssetsFile_C6_son+$Croissants_List_MOD_Ref[$i];
                      $getName = stringToStringArray($Croissants_List_MOD_Ref[$i], ".");
                            //NameSpace Use Q                    
                            if ($valueRefname_MOD == 1)
                            {
                            $ModName = (`optionMenu -q -v Croissants_MOD_3`);
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace $ModName -options "v=0" $MOD_fileName; 
                            }
                            else                            
                            file -r -ignoreVersion -gl -mergeNamespacesOnClash false  -loadReferenceDepth "all" -namespace ":" -options "v=0" $MOD_fileName; 
                            
                        }
                  } 
                       
                  get_CurrUnit_CC();
                    
      break;  


  }

}


