global proc string Croi_C_workspace()
{
  string $q_Croi_CW = `workspace -q -fn`;    
  return $q_Croi_CW;
}

global proc string Croi_Root()
{
  string $q_Croi_Root=`optionMenu -q -v Croissants_EP`;
  return $q_Croi_Root;
}           


global proc string Croi_Sub()
{
  string $q_Croi_Sub_ni=`optionMenu -q -ni Croissants_CUT`;
  if($q_Croi_Sub_ni == 0)
  {
    print "";
  }
  else
  {
  string $q_Croi_Sub=`optionMenu -q -v Croissants_CUT`;
  return $q_Croi_Sub;
  }
}   



