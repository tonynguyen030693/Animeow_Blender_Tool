        Get_Croissants_AssetsList(42);
      }
      else 
      { 
      //Move
        Get_Croissants_AssetsList(41);
      }
  }
  
  

//////////////////////////////////////////////////////////////////////////////////////////////////////////////// 
////Modeling Command 
//for Clean Modeling

  global proc BakeSET_F()
  {
      string $ModGrp[] =`ls "ModGrp"`;
      if(size($ModGrp) == 0)
      {

      textField -e -tx  "ERROR !! You have to Select anitihng..."  Croissants_msg;
      }
      else
      {
      select -r -ne $ModGrp[0];
      select -hi;
      string $sel[] = `ls -sl`;
      string $filterSelect[] = `filterExpand -sm 12 $sel`;
      select -r $filterSelect;
      $createSetResult = `sets -name "BakeSet"`;      
      
      textField -e -tx  "OK !!!"  Croissants_msg;    
      }
      select -cl;
  
  }
  
  global proc BakeSET()
  {
    select -hi;
    string $sel[] = `ls -sl`;
    string $filterSelect[] = `filterExpand -sm 12 $sel`;
    select -r $filterSelect;
    $createSetResult = `sets -name "BakeSet"`;
  }
  
  
  
  global proc TakeName(int $case)
  {
    string $selObjects[] = `ls -sl`;
    string $getObjectN = $selObjects[0];  
    string $fixName = substituteAllString($selObjects[0], ":", "_"); 
    string $_exp_fixName = "_rs_"+ $fixName;
    switch($case)
    {
      case 1 :         
        textField -e -tx $fixName Croissants_ABC_name;
      break;

      case 2 :
        textField -e -tx $getObjectN Croissants_PUtil_name;
      break;

      case 3 :        
        textField -e -tx $_exp_fixName Croissants_msg;
      break;

      
    }
  }   



  
  global proc Croissants_Mod_OM(int $case)
  {
    int $note_infos_Mod = `checkBox -q -v Episodic`;  

    switch($case)
