}


global proc Croi_playPreViz_Tgl()
{
    int $bVis =`iconTextButton -q -vis Crio_PlayBackBTT`;
    if($bVis == 0)
    {
    iconTextButton -e -vis 1 Crio_PlayBackBTT;
    }
    else
    iconTextButton -e -vis 0 Crio_PlayBackBTT;

} 

global proc Croi_playPreViz()
{
    string $Previz_Croi_C_WS =`Croi_C_workspace`;
    string $Previz_Croi_Root=`Croi_Root`;
    string $Previz_Croi_Sub=`Croi_Sub`;    
    string $Previz_Croi_Render =`textField -q -tx croissants_TokenN`;
    string $AniPreViz_Path = $Previz_Croi_C_WS + "/" + $Previz_Croi_Render +"/_Previz" + "/" + $Previz_Croi_Root + "/";

    

              string $Croissants_AniPreViz_S[] = `textScrollList -q -si Croissants_Ani_List`;
              int $J = `size $Croissants_AniPreViz_S[0]`;
              if($J == 0)
              {
              
              textField -e -tx "please Select Ani File List" "Croissants_msg";  
              }              
              else{
              string $Croissants_AniPreViz_T = `substring $Croissants_AniPreViz_S[0] 1 ($J - 3)`;  
              string $AniPreViz_filename = $Croissants_AniPreViz_T+".mov";                
                                
              string $PV_FileCheck[]= `getFileList -folder $AniPreViz_Path -filespec ($Croissants_AniPreViz_T+".mov")`;                

    

                      if(`gmatch $PV_FileCheck[0] $AniPreViz_filename` == 0)
                      {                      
                      textField -e -tx "File Not Exists" "Croissants_msg";               
                      }
                      else
                      {
                      textField -e -tx "It's Playing soon..." "Croissants_msg";                        
                     
                      launch -movie ($AniPreViz_Path + $AniPreViz_filename);  
                      
                      pause -sec 1;
                      textField -e -tx "." "Croissants_msg";                                            
                      }
             }

}




global proc Cori_unknownPlugins()
{
  string $plugin;
  string $unknownPlugins[] = `unknownPlugin -query -list`;
  for ($plugin in $unknownPlugins)
  {
      unknownPlugin -remove $plugin;
  }
}

global proc Cori_KillNinza()
{
    string $ninza[] =`ls "Turtle*"`;

    if(size($ninza)!= 0)
    {
        for ($i = 0; $i < size($ninza); $i++)
        {
        lockNode -l 0 $ninza[$i];
        delete $ninza[$i];
        }
    }
    else        
        print "yes!!";

}



global proc Croissant_save_Files()
{
    int $TSR=`textField -q -tx croissants_TokenP`;

    if ($TSR == 0)
    {
      Cori_unknownPlugins;
      Cori_KillNinza;
      IncrementAndSave;
    }
    else if ($TSR == 1)
    {
      Cori_unknownPlugins;
      Cori_KillNinza;
      SaceScenePlus;
    }
    UI_ReFrash_CC(1);
}



global proc Croissant_setWorkspace()
{   
    string $G_Croi_C_WS = `Croi_C_workspace`;
    string $G_Croi_Rule[]= `getFileList -folder $G_Croi_C_WS -filespec "*.ini"`;
    string $Set_Croi_Rule = $G_Croi_C_WS +"/"+ $G_Croi_Rule[0];
           $Set_Croi_Rule_NOTE = `fopen $Set_Croi_Rule "r"` ;  
    string $G_Croi_Rule_Token = `fread $Set_Croi_Rule_NOTE $G_Croi_Rule_Token` ; 
                         fclose $Set_Croi_Rule_NOTE;       

    string $Croi_Rule_NOTE[];  
           $Croi_Rule_NOTE = stringToStringArray($G_Croi_Rule_Token, "."); 
    string $Croi_Token_TreeA = $Croi_Rule_NOTE[3];
           $Croi_Token_TreeA_Branch = stringToStringArray($Croi_Token_TreeA, "|"); 
    string $Croi_Token_TreeB = $Croi_Rule_NOTE[4];
           $Croi_Token_TreeB_Branch = stringToStringArray($Croi_Token_TreeB, ","); 


    textField -e -tx $Croi_Rule_NOTE[0] croissants_TokenA;
    textField -e -tx $Croi_Rule_NOTE[1] croissants_TokenB;
    textField -e -tx $Croi_Rule_NOTE[2] croissants_TokenC;
    textField -e -tx $Croi_Token_TreeA_Branch[1] croissants_TokenD;
    textField -e -tx $Croi_Token_TreeA_Branch[2] croissants_TokenE;
    textField -e -tx $Croi_Token_TreeA_Branch[3] croissants_TokenF;
    textField -e -tx $Croi_Token_TreeA_Branch[4] croissants_TokenG;
    textField -e -tx $Croi_Token_TreeA_Branch[5] croissants_TokenH;
    textField -e -tx $Croi_Token_TreeB_Branch[1] croissants_TokenI;
    textField -e -tx $Croi_Token_TreeB_Branch[2] croissants_TokenJ;
    textField -e -tx $Croi_Token_TreeB_Branch[3] croissants_TokenK;
    textField -e -tx $Croi_Token_TreeB_Branch[4] croissants_TokenL;
    textField -e -tx $Croi_Token_TreeB_Branch[5] croissants_TokenN;
    textField -e -tx $Croi_Token_TreeB_Branch[6] croissants_TokenO;
    textField -e -tx $Croi_Token_TreeB_Branch[7] croissants_TokenP;
    textField -e -tx $Croi_Token_TreeB_Branch[8] croissants_TokenQ;
    
    //remove space & New Line space
    string $reToken_01= $Croi_Rule_NOTE[5];
    string $tokenized_01[];
    tokenize $reToken_01 "\n" $tokenized_01;

    string $reToken_02= $Croi_Rule_NOTE[6];
    string $tokenized_02[];
    tokenize $reToken_02 "\n" $tokenized_02;

    textField -e -tx $tokenized_01[1] textField_Rule_01;
    textField -e -tx $tokenized_02[1] textField_Rule_02;
    
}

