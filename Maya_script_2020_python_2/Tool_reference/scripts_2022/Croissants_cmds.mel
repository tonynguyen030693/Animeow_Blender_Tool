    }     
}    


global proc Croissants_Open_workDir(int $case)
{  
    string $G_Croi_C_WS_Exp =`Croi_C_workspace`;
    string $G_Croi_Root_Exp=`Croi_Root`;
    string $G_Croi_Sub_Exp=`Croi_Sub`;    
    string $G_Croi_Scenes_01_Exp=`textField -q -tx croissants_TokenD`;
    string $G_Croi_Scenes_02_Exp=`textField -q -tx croissants_TokenF`;
    string $G_Croi_Scenes_03_Exp=`textField -q -tx croissants_TokenE`;
    
    string $G_Croi_Scenes_subB=`textField -q -tx croissants_TokenH`;
    
    string $Animation_Path = $G_Croi_C_WS_Exp + "/" + $G_Croi_Scenes_01_Exp + "/" +$G_Croi_Scenes_02_Exp + "/" + $G_Croi_Root_Exp +"/" + $G_Croi_Sub_Exp;
    string $Lighting_Path = $G_Croi_C_WS_Exp + "/" + $G_Croi_Scenes_01_Exp + "/" +$G_Croi_Scenes_03_Exp + "/" + $G_Croi_Root_Exp +"/" + $G_Croi_Sub_Exp;
  

  switch($case)
  {
      case 0 :    
            string $pre_checkFolder_animation[] = `getFileList -folder $Animation_Path -filespec "*.*"`;
            if(size($pre_checkFolder_animation) == 0)
            {
                  print "ľĆÁ÷ Ćú´ő°ˇ ľř˝Ŕ´Ď´Ů.";
       
            }
            else
            {    
                   string $win_aniExplorerPath = substituteAllString($Animation_Path, "/", "\\");
                  string $syscmd_aniExplorer = "start explorer /n,/e, " + $win_aniExplorerPath; 
                  system( $syscmd_aniExplorer );  
            }
      break;
      
      case 1 :
            string $pre_checkFolder_Lighting[] = `getFileList -folder $Lighting_Path -filespec "*.*"`;
            if(size($pre_checkFolder_Lighting) == 0)
            {
                  print "ľĆÁ÷ Ćú´ő°ˇ ľř˝Ŕ´Ď´Ů.";
       
            }
            else
            {    
                   string $win_LitExplorerPath = substituteAllString($Lighting_Path, "/", "\\");
                  string $syscmd_aniExplorer = "start explorer /n,/e, " + $win_LitExplorerPath; 
                  system( $syscmd_aniExplorer );  
            }
      break;
      

  }
} 
    