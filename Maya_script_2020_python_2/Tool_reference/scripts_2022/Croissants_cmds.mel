global proc Croissants_Filter(int $case)
{
      string $N_Filter=`textField -q -tx Croissants_Filter`;
      
      switch($case)
      {
      case 1 :
        string $Filter_Con1 = $N_Filter+"*";
        textField -e -tx $Filter_Con1 Croissants_Filter;
        Croissants_get_EPs(1);        
      break;

      case 2 :
        string $Filter_Con2 = $N_Filter+"*";
        textField -e -tx $Filter_Con2 Croissants_Filter;
        Croissants_get_EPs(2);
      break;
      }

}


