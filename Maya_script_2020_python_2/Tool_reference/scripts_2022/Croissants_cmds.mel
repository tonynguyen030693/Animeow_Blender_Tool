//Modeling Extra Command
global proc Croissants_Open_MOD(int $case)
{  


  string $G_Croi_Scenes_01=`textField -q -tx croissants_TokenD`;
  string $G_Croi_Scenes_07=`textField -q -tx croissants_TokenJ`;
  

  string $mRoot=`optionMenu -q -v Croissants_MOD`;
  string $mEp=`optionMenu -q -v Croissants_MOD_2`;
  string $mSub_Mod=`optionMenu -q -v Croissants_MOD_3`; 
  string $gModDir = (`Croi_C_workspace`) +"/"+ $G_Croi_Scenes_07 +"/"+ $mRoot + "/" + $mEp + "/" + $mSub_Mod + "/"; 

  switch($case)
  {
      case 0 :    
            string $pre_checkFolder_mod[] = `getFileList -folder $gModDir -filespec "*.*"`;
            if(size($pre_checkFolder_mod) == 0)
            {
                  print "ľĆÁ÷ Ćú´ő°ˇ ľř˝Ŕ´Ď´Ů.";
       
            }
            else
            {    
                   string $win_ModPath = substituteAllString($gModDir, "/", "\\");
                  string $syscmd_Explorer = "start explorer /n,/e, " + $win_ModPath; 
                  system( $syscmd_Explorer );  
            }
      break;
      
      case 1 :
            string $mesh[] =`ls -sl`;
            string $crosswalk_obj = $gModDir+"_Crosswalk"+"/"+$mesh[0]+".obj";
            string $crosswalk_objmtl = $gModDir+"_Crosswalk"+"/"+$mesh[0]+".mtl";
            file -force -options "groups=1;ptgroups=1;materials=1;smoothing=1;normals=1" -typ "OBJexport" -pr -es $crosswalk_obj;
            sysFile -delete $crosswalk_objmtl; 
            Croissants_Mod_OM(3);     
      break;
      
      case 2 :
            file -import -type "OBJ"  -ignoreVersion -mergeNamespacesOnClash false -options "mo=1"  -pr  -importFrameRate true  -importTimeRange "override" $crosswalk_obj;      
      break;
  }
}      


