global proc Croissants_Filter_Assets(int $case)
{
      string $AN_Filter=`textField -q -tx Croissants_Filter_Asset`;
      string $MD_Filter=`textField -q -tx Croissants_Filter_MOd`;
      
      switch($case)
      {
      case 1 :
              textField -e -tx "" Croissants_Filter_Asset;
              if($AN_Filter != "*")
              {
              string $Filter_ConA = "*"+$AN_Filter+"*";
              textField -e -tx $Filter_ConA Croissants_Filter_Asset;
              }
              else
              {
              textField -e -tx "*" Croissants_Filter_Asset;
              }        
              Get_Croissants_AssetsList(21);       
      break;

      case 2 :
              textField -e -tx "*" Croissants_Filter_Asset;
              Get_Croissants_AssetsList(21);
              
      break;

      case 3 :
              textField -e -tx "" Croissants_Filter_MOd;
              if($MD_Filter != "*")
              {
              string $Filter_ConM = "*"+$MD_Filter+"*";
              textField -e -tx $Filter_ConM Croissants_Filter_MOd;
              }
              else
              {
              textField -e -tx "*" Croissants_Filter_MOd;
              }        
              Get_Croissants_MOD_List(21);       
      break;

      case 4 :
              textField -e -tx "*" Croissants_Filter_MOd;
              Get_Croissants_MOD_List(21);
      break;

      }

}

  global proc makeMUltiSelect(int $case)
  {
  
      switch($case)
      {
          //Light file Field
          case 1 :
              $getAttr = `textScrollList -q -ams Croissants_Lit_List`;
              if ($getAttr == 1)
              {
              textScrollList -edit -ams 0 Croissants_Lit_List;
              button -e -bgc 0.5 0.5 0.5 makeHis_Btt; 
              }
              else
              {
              textScrollList -edit -ams 1 Croissants_Lit_List;
              button -e -bgc 0.3 0.9 0.11 makeHis_Btt;       
              }
          break;      
          
          
      }    
  }

  global proc Croissants_assets_OM(int $case)
  {
    int $note_infos_Assets = `checkBox -q -v Episodic`;  

    switch($case)
    {
    case 1 :
          if($note_infos_Assets == 0)
          {
           Get_Croissants_AssetsList(2);Get_Croissants_AssetsList(3);
          }
          else if ($note_infos_Assets == 1)
          {
          Get_Croissants_AssetsList(2);Get_Croissants_AssetsList(21);Get_Croissants_AssetsList(31);
          }    
    break;

    case 2 :
          if($note_infos_Assets == 0)
          {
           Get_Croissants_AssetsList(3);Get_Croissants_AssetsList(33);
          }
          else
          {
          Get_Croissants_AssetsList(21);Get_Croissants_AssetsList(31);Get_Croissants_AssetsList(33);
          }       
    break;
    
    case 3 :

          Get_Croissants_AssetsList(31);Get_Croissants_AssetsList(33);catchQuiet(Croi_Thumbs_Assets(2));
      
    break;  
    case 4 :
          if($note_infos_Assets == 0)
          {
           Get_Croissants_AssetsList(1);Get_Croissants_AssetsList(2);Get_Croissants_AssetsList(3);
          }
          else
          {
          Get_Croissants_AssetsList(1);Get_Croissants_AssetsList(2);Get_Croissants_AssetsList(21);Get_Croissants_AssetsList(31);Get_Croissants_AssetsList(33);
          }       
    break;      
    
    }
  
  }


  global proc Assets_BackUpSwitch()
  {
    int $ABackup_Op = `checkBox -q -v ABackupOp`;                                   
