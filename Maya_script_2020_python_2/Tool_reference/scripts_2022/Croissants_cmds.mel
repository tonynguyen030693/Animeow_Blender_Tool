//LDP Command
global proc LDPExport()
{
      string $winLDP = "LDPExport_UI";
      int $getLDPVis = `window -q -ex $winLDP`;
   
      if ($getLDPVis == 0) 
      {
      LDPExport_BatchUI();	 
      }

      else 
      {
         int $getLDPWinVis =`window  -q -vis  $winLDP`;
         if ($getLDPWinVis == 0)
          {window  -e -vis 1  $winLDP;}
         else
          {window  -e -vis 0  $winLDP;} 	 
      } 

      $ccPostion =`window -q -tlc  Croissants`; 
      int $LDP_TP = $ccPostion[0] +225;
      int $LDP_LP = $ccPostion[1] -225;
      window -e -tlc $LDP_TP $LDP_LP  LDPExport_UI;
}


global proc LDPExport_BatchUI(){
if (`window -q -exists LDPExport_UI`)deleteUI LDPExport_UI;
window -widthHeight 225 60 -mnb 0 -tb 1 -toolbox 1 -maximizeButton 0 -menuBar 0 -sizeable 1 -title "LookDev Pub" LDPExport_UI;

string $col =`columnLayout -adjustableColumn 1  -rowSpacing 1`;
rowColumnLayout -numberOfColumns 5 -cw 1 35 -cw 2 60 -cw 3 60 -cw 4 5 -cw 5 60 ;

text -l "inc" -h 25;
text -l "Dev";
text -l "Version";
separator -st "none";
separator -st "none";


intField -v 0  LDPExport_NumberToken;
textField -h 30 -tx "" LDPExport_DevToken;
textField -h 30 -tx "0001" LDPExport_NameToken;
separator -st "none";
button -l "Export" -c "LDPExport_Response";


popupMenu -mm 1 -parent LDPExport_DevToken;
    menuItem -label "_R01" -c "LDPExport_DevToken_auto(0)";
    menuItem -label "_R02" -c "LDPExport_DevToken_auto(1)";
    menuItem -label "_R03" -c "LDPExport_DevToken_auto(2)";
    menuItem -label "_R04" -c "LDPExport_DevToken_auto(3)";
    menuItem -label "_R05" -c "LDPExport_DevToken_auto(4)";


showWindow LDPExport_UI;
}
//
global proc LDPExport_Response()
{
    string $ThisFileis = `file -q -sn -shn`; 
    $getnShort = stringToStringArray($ThisFileis, ".");
    string $msg ="Publish the selected assets? \n\n"+$getnShort[0] +" <==[Check Name]";

    $response_LDP = `confirmDialog -title "Confirm" 
                              -message $msg
                              -button "Yes" 
                              -button "No"
                              -defaultButton "Yes"
                              -cancelButton "No"
                              -dismissString "No"`;
              
              // check response_LDP	  
              if( $response_LDP == "Yes" ) 
              {
                  LDPExport_BatchCMD();
                  deleteUI LDPExport_UI;      
              }              
              else if( $response_LDP == "No" ) 
              {
                print("Cancel Command...");
              }      
}  
 

global proc LDPExport_BatchCMD()
{
    string $now_project_LDP = `workspace -q -fn`;
    string $ProjectType_LDP[]= `getFileList -folder $now_project_LDP -filespec "*.ini"`;
    string $ProjectNote_LDP = $now_project_LDP +"/"+ $ProjectType_LDP[0];
           $noteId_LDP = `fopen $ProjectNote_LDP "r"` ;  
    string $note_info_LDP = `fread $noteId_LDP $note_info_LDP` ; 
                         fclose $noteId_LDP;       

    string $note_info_LDPs[];  
           $note_info_LDPs = stringToStringArray($note_info_LDP, "."); 
    string $meta_treeA_LDP = $note_info_LDPs[3];
           $meta_BranchA_LDP = stringToStringArray($meta_treeA_LDP, "|"); 
    string $meta_treeB_LDP = $note_info_LDPs[4];
           $meta_BranchB_LDP = stringToStringArray($meta_treeB_LDP, ","); 
    
    
    int $note_infos_LDP = `checkBox -q -v Episodic`;                    
    string $LDP_Assets =$now_project_LDP + "/" + $meta_BranchB_LDP[1] + "/";
                  
    string $LDP_Root0=`optionMenu -q -v Croissants_Assets`;
    string $LDP_Root1=`optionMenu -q -v Croissants_Assets_2`;
    string $LDP_Root2=`optionMenu -q -v Croissants_Assets_3`;
    string $LDP_path = $LDP_Assets + $LDP_Root0 + "/" + $LDP_Root1 + "/"+ $LDP_Root2 + "/pub/";
    
    string $LDP_inc =`intField -q -v LDPExport_NumberToken`;
    string $LDP_Dev =`textField -q -tx LDPExport_DevToken`;
    string $LDP_Ver =`textField -q -tx LDPExport_NameToken`;
 
 
 
     if($note_infos_LDP == 0)
     {
        string $LDP_F_name = $LDP_Root1 +$LDP_inc+$LDP_Dev+ "_LDP." + $LDP_Ver +".ma";    
        string $Export_LDP = $LDP_path + $LDP_F_name;
        
        int $checkLDP =`file -q -exists $Export_LDP`;
                      if($checkLDP != 0)
                      {
                            $response_LDP_Write = `confirmDialog -title "Confirm" 
                                            -message "The file already exists. Overwrite?"
                                            -button "Yes" 
                                            -button "No"
                                            -defaultButton "Yes"
                                            -cancelButton "No"
                                            -dismissString "No"`;
                            
                            // check response_LDP_Write	  
                            if( $response_LDP_Write == "Yes" ) 
                            {
                              file -f -options "v=0;" -typ "mayaAscii" -pr -es  $Export_LDP;   
                            }              
                            else if( $response_LDP_Write == "No" ) 
                            {
                              print("Cancel Command...");
                            }      
                      
                      }
                      else
                      {
                        sysFile -makeDir $LDP_path;
                        file -f -options "v=0;" -typ "mayaAscii" -pr -es  $Export_LDP;
                      }
        Get_Croissants_AssetsList(33);
      }
      else
      {
        string $LDP_F_name = $LDP_Root2 +$LDP_inc+$LDP_Dev+ "_LDP." + $LDP_Ver +".ma";    
        string $Export_LDP = $LDP_path + $LDP_F_name;
        
        int $checkLDP =`file -q -exists $Export_LDP`;
                      if($checkLDP != 0)
                      {
                            $response_LDP_Write = `confirmDialog -title "Confirm" 
                                            -message "The file already exists. Overwrite?"
                                            -button "Yes" 
                                            -button "No"
                                            -defaultButton "Yes"
                                            -cancelButton "No"
                                            -dismissString "No"`;
                            
                            // check response_LDP_Write	  
                            if( $response_LDP_Write == "Yes" ) 
                            {
                              file -f -options "v=0;" -typ "mayaAscii" -pr -es  $Export_LDP;   
                            }              
                            else if( $response_LDP_Write == "No" ) 
                            {
                              print("Cancel Command...");
                            }      
                      
                      }
                      else
                      {
                        sysFile -makeDir $LDP_path;
                        file -f -options "v=0;" -typ "mayaAscii" -pr -es  $Export_LDP;
                      }
        Get_Croissants_AssetsList(33);      
      }
    //keep old command
    //file -rn $Export_LDP; 
    //file -f -es  -options "v=0;" -type "mayaAscii";
}



global proc LDPExport_DevToken_auto(int $case)
{
  switch($case)
  {
    case 0 :
    textField -e -tx "_R01" LDPExport_DevToken;
    break;
  
    case 1 :
    textField -e -tx "_R02" LDPExport_DevToken;
    break;
    
    case 2 :
    textField -e -tx "_R03" LDPExport_DevToken;
    break;  

    case 3 :
    textField -e -tx "_R04" LDPExport_DevToken;
    break;

    case 4 :
    textField -e -tx "_R05" LDPExport_DevToken;
    break;

  }
}          



