global proc NoiceNodeExport()
{
    $Path = `workspace -q -fn`;
    string $init[]= `getFileList -folder $Path -filespec "*.ini"`;
    string $ini_gets = $init[0]; 
    string $G_I[] = stringToStringArray($ini_gets, ".");


    $RootPath = stringToStringArray($Path, "/");
    $project = $RootPath[0] + "\\" + $RootPath[1]+ "\\" + $RootPath[2];  


    string $EPs_Duplicate_1=`optionMenu -q -v Croissants_EP`;
    string $CUTs_Duplicate=`optionMenu -q -v Croissants_CUT`;
    string $Croissants_N_Path = $project + "\\02_Scenes\\05_Lighting\\" + $EPs_Duplicate_1 + "\\" + $CUTs_Duplicate + "\\";
    sysFile -makeDir $Croissants_N_Path;
    string $Croissants_F_Name = $G_I[0] + "_" + $EPs_Duplicate_1 + "_" + $CUTs_Duplicate + "_noice.ma";

    string $Croissants_F_ES = $Croissants_N_Path + $Croissants_F_Name;

          file -f -options "v=0;" -typ "mayaAscii" -pr -es $Croissants_F_ES;          
          file -f  -ignoreVersion  -o $Croissants_F_ES;
     
}
///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//make attr node
global proc make_noice_Repository()
{
  string $Op_user_tk1 = `textField -q -tx noice_pr`;
  string $Op_user_tk2 = `textField -q -tx noice_sr`;
  string $Op_user_tk3 = `textField -q -tx noice_v`;
  string $Op_User_v = "-pr "+$Op_user_tk1+ " -sr "+$Op_user_tk2+ " -v "+$Op_user_tk3;


  editRenderLayerGlobals -crl defaultRenderLayer;
  string $chkx[] = `ls "noice_attr"`;
  if ($chkx[0] == "noice_attr")
  {
    $fileName_pre = `renderSettings -firstImageName -fullPath`;
    string $fn_pre = $fileName_pre[0];
    setAttr -type "string" noice_attr.path $fn_pre;
    
    addAttr -ln "option" -dt "string"  noice_attr;
    setAttr -type "string" noice_attr.option $Op_User_v;  
  }
  else
    {
    spaceLocator -n "noice_attr" -p 0 0 0;
    addAttr -ln "path" -dt "string"  noice_attr;
    $fileName_pre = `renderSettings -firstImageName -fullPath`;
    string $fn_pre = $fileName_pre[0];
    setAttr -type "string" noice_attr.path $fn_pre;
    
    addAttr -ln "option" -dt "string"  noice_attr;
    setAttr -type "string" noice_attr.option $Op_User_v;
  }
}

global proc noice_Option_Add()
{
  string $Op_user_tk1 = `textField -q -tx noice_pr`;
  string $Op_user_tk2 = `textField -q -tx noice_sr`;
  string $Op_user_tk3 = `textField -q -tx noice_v`;
  string $Op_User_v = "-pr "+$Op_user_tk1+ " -sr "+$Op_user_tk2+ " -v "+$Op_user_tk3;
    
    addAttr -ln "option" -dt "string"  noice_attr;
    setAttr -type "string" noice_attr.option $Op_User_v;  

}


///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//Add Renderlayers AOVlist
global proc write_e_aovs()
{
    
    $Layer=`editRenderLayerGlobals -q -crl`;
    addAttr -ln $Layer  -dt "string"  noice_attr;
    
    select -cl;  
    string $get_ai3[]= `ls -typ "aiAOV"`;
    for ($i=0; $i<size($get_ai3); $i++)
    { 
     $state = `getAttr ($get_ai3[$i]+".enabled")`;
     if ($state == 1)
     {select -add $get_ai3[$i];}
     else
     {select -d $get_ai3[$i];}    
    }
    
    
    string $get_ai_name[]= `ls -sl`;
    for ($each in $get_ai_name)
    { 
        string $name=`getAttr ($each+".name")`;
        record_aovs($name);
    }
}
global proc record_aovs(string $name)
{
    $Layer=`editRenderLayerGlobals -q -crl`;    
    string $attr = "noice_attr."+$Layer;    
    string $oldstring =`getAttr $attr` ;
    string $aovs= $oldstring+" -l "+$name; 
    setAttr -type "string" $attr $aovs;
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//record with aovlist eche renderlayer
global proc record_aovs_zcmd() 
{
string $RL_Node = "renderLayerManager";
    string $eRenderLayerList[] = `listConnections $RL_Node`;   	
    for ($i=1;$i<size($eRenderLayerList);$i++)
	{
        editRenderLayerGlobals -crl $eRenderLayerList[$i];
        int $rb=`getAttr ($eRenderLayerList[$i]+".renderable")`;
        if($rb == 0)
        {}
        else
        write_e_aovs();
    }
editRenderLayerGlobals -crl defaultRenderLayer;
select -cl;
select -r noice_attr;
}


global proc postRenderMelCommand()
{

    unifiedRenderGlobalsWindow;
    string $preRenderLayer[]= `listAttr -ud noice_attr`;
    for ($i=1;$i<size($preRenderLayer);$i++)
    { 
      createRenderLayer -name $preRenderLayer[$i];
    }
    
    //-_-;;
    renderLayerEditorDeleteLayer RenderLayerTab option;
    
    setAttr "defaultRenderLayer.renderable" 0;
    setAttr "defaultResolution.width" 16;
    setAttr "defaultResolution.height" 16;    
    setAttr "defaultArnoldRenderOptions.bucketSize" 16;
    setAttr "defaultArnoldRenderOptions.maxSubdivisions" 5;

    setAttr "defaultRenderGlobals.enableDefaultLight" 0;
    setAttr "defaultRenderGlobals.extensionPadding" 4;
    setAttr "defaultRenderGlobals.animation" 1;                
    setAttr "defaultRenderGlobals.putFrameBeforeExt" 1;   

    Croissants_logStats(9); //Read Info
    Croissants_Prefix();

    setAttr "defaultArnoldRenderOptions.AASamples" 1;
    setAttr "defaultArnoldRenderOptions.GIDiffuseSamples" 0;
    setAttr "defaultArnoldRenderOptions.GISpecularSamples" 0;
    setAttr "defaultArnoldRenderOptions.GITransmissionSamples" 0;
    setAttr "defaultArnoldRenderOptions.GIVolumeSamples" 0;
    setAttr "defaultArnoldRenderOptions.GISssSamples" 0;   
    setAttr "defaultRenderGlobals.renderVersion" -type  "string" "noice";
    setAttr "defaultArnoldRenderOptions.aovMode" 0;


    setAttr "defaultArnoldDriver.mergeAOVs" 1;
    setAttr "defaultArnoldDriver.exrTiled" 0;
    workspaceControl -e -vis 0 unifiedRenderGlobalsWindow;
    setAttr -type "string" defaultRenderGlobals.postMel "";
    setAttr -type "string" defaultRenderGlobals.preMel ""; 
    
    int $checkNameSpace = `checkBox -q -v nameType_chk`;
    if ($checkNameSpace == 0){
        F_NameVariable(1);
       }
    else {
        F_NameVariable(2);
       }  

   
}

global proc F_NameVariable(int $case)
{

  switch($case)
  {
  case 1 :
      setAttr -type "string" defaultRenderGlobals.postRenderMel "postNoice(1);";
  break;

  case 2 :
      setAttr -type "string" defaultRenderGlobals.postRenderMel "postNoice(2);";
  break;

  case 3 :
      setAttr -type "string" defaultRenderGlobals.postRenderMel "postNoice(3);";
  break;
  }
  
}


global proc Croissants_Assets_Changer()
{

string $Croissants_Assets[] = `textScrollList -q -si Croissants_Assets_List_1`;
string $AS_project = `workspace -q -fn`;
string $AS_Root0=`optionMenu -q -v Croissants_Assets`;
string $AS_Root1=`optionMenu -q -v Croissants_Assets_2`;
string $AS_Root2=`optionMenu -q -v Croissants_Assets_3`;
string $AS_Path = $AS_project + "/02_Scenes/_Assets/" + $AS_Root0 + "/" + $AS_Root1 + "/" + $AS_Root2 + "/" ;

string $sels[] =`ls -sl`;
//string $current_ref=`referenceQuery -f -shn $sel[0]`;               
string $current_ref=`referenceQuery -f $sels[0]`;               

int $checkAniRN = size($Croissants_Assets);

    if($checkAniRN == 1)
    {
        for ($i=0; $i<size($Croissants_Assets); $i++)
        {
        if($Croissants_Assets[$i] == $current_ref)
          {
            inViewMessage -smg "It's Same file." -pos topRight -bkc 0x00000000 -fade;    
          }
        else
          {
            string $Croissants__RN = $AS_Path+$Croissants_Assets[$i]; 
            file -loadReference $sels[0] $Croissants__RN;   
            file -e -namespace $AS_Root2 $current_ref;  
            inViewMessage -smg "Replacement Complete" -pos topRight -bkc 0x00000000 -fade;
            
          }                          

        }
     }
        

    else
    {                            

        inViewMessage -smg $current_ref -pos topRight -bkc 0x00000000 -fade;
    }

}



global proc CMZ_FL_CLL_Func(int $case)
{

  string $CMZ_FL_List= "FL_Array,FL_Quick,FL_LIT,FL_Tools,FL_Tokeniz,FL_Etc";
  string $CMZ_FL_tokenized[];
  tokenize $CMZ_FL_List "," $CMZ_FL_tokenized;
  

              for ($i=0; $i<size($CMZ_FL_tokenized); $i++)
              {                     
                int $FLCL=`frameLayout -q -cl $CMZ_FL_tokenized[$i]`;
                if($FLCL==0)
                  {
                    frameLayout -e -cl 1 $CMZ_FL_tokenized[$i];    
                  }
              }

                string $LFName=`frameLayout -q -l $CMZ_FL_tokenized[$case]`;   
                frameLayout -e -cl 0 ("FL_"+$LFName);
           
}     




global proc Croi_GATE()
{

      int $GATE =`textScrollList -q -vis "Croissants_aniRN_H"`;
      if($GATE == 0)
      {
        textScrollList -e -vis 1 "Croissants_aniRN_H";
        textScrollList -e -vis 0 "Croissants_Lit_List";

          string $aniRN[]=`ls -typ "reference"`;    
          if (size($aniRN) == 0)
          {
            print "There are no Reference Node.";
            textScrollList -edit -removeAll Croissants_aniRN_H;
          }
          else
          {
            string $sel_Sort[];
            $sel_Sort=sort($aniRN);   
            textScrollList -edit -removeAll Croissants_aniRN_H;                             
            for ($i = 0; $i < size($sel_Sort); $i++)
            {           
            textScrollList   -ams 0 -sc "Croi_GATE_Key(1)" -dcc "Croi_GATE_Key(2)" -e -a $sel_Sort[$i] Croissants_aniRN_H;
            }
          }               
            textScrollList -e -ri "sharedReferenceNode"  Croissants_aniRN_H; 

      }
      else
      {
        textScrollList -edit -removeAll Croissants_aniRN_H;
        textScrollList -e -vis 0 "Croissants_aniRN_H";
        textScrollList -e -vis 1 "Croissants_Lit_List";
      }

}

global proc Croi_GATE_Key(int $case)
{

  string $ThisRN[] =`textScrollList -q -si Croissants_aniRN_H`;   
      switch($case)
      {
      case 1 :
            select -cl;
            select -ne -r $ThisRN[0];
      break;        
      
      case 2 :      
            textScrollList -e -ri $ThisRN[0] Croissants_aniRN_H;
      break;

      }

}





global proc GetRN_List_UI()
{
    if(`window -q -ex "RN_Lists"`)deleteUI("RN_Lists");
    window -mnb false -w 305 -mxb false -t "RN_List" -h 237 -tb true -s 0 -tlb true -mb true "RN_Lists";
    columnLayout -w 302 -h 230 "columnLayout4";
    columnLayout ;
    textScrollList -w 300 -ams true -h 200 RN_List;
    formLayout -p "columnLayout4" -w 300 "formLayout_RN_List";
    button -w 150 -h 30 -l "GET"  -c "GetRN_List(1)" GetRN_List_BTT1;
    button -w 50 -h 30 -l "RE:" -c "GetRN_List(2)" GetRN_List_BTT2;
    formLayout  -e -ap  "GetRN_List_BTT2" "left" 170 0 "formLayout_RN_List";

          popupMenu -mm 1 -parent  RN_List;
                        menuItem-rp "N" -label "Set Filter" -c "SelRN_List(2)";  
                        

    showWindow "RN_Lists";
}

global proc GetRN_List(int $case)
{

    switch($case)
    {
    
    case 1 :
      string $selects[]=`ls -typ "reference"`;    
      if (size($selects) == 0)
      {
        print "There are no Reference Node.";
        textScrollList -edit -removeAll RN_List;
      }
      else
      {
        string $selects_Sort[];
        $selects_Sort=sort($selects);   
        textScrollList -edit -removeAll RN_List;                             
        for ($i = 0; $i < size($selects_Sort); $i++)
        {           
        textScrollList   -ams 0 -sc "SelRN_List(1)" -dcc "GetRN_List(3)" -e -a $selects_Sort[$i] RN_List;
        }
      }               
        textScrollList -e -ri "sharedReferenceNode"  RN_List; 
    break;
    
    //Remove All List
    case 2 :
       textScrollList -edit -removeAll RN_List; 
    break;   


    //Remove Node from list
    case 3 :
      string $badRN[] =`textScrollList -q -si RN_List`;
      textScrollList -e -ri $badRN[0]  RN_List;
    break;

    }
}


global proc SelRN_List(int $case)
{
  string $ThisRN[] =`textScrollList -q -si RN_List`; 
  string $array[];
  $array = stringToStringArray($ThisRN[0], "_");
  string $A_Type = $array[1];
  
      switch($case)
      {
      case 1 :
            select -cl;
            select -ne -r $ThisRN[0];

            if($A_Type == "B")
            {
            optionMenu -e -v "BG" Croissants_Assets;
            Croissants_assets_OM(2);
            }
            else if($A_Type == "C")
            {
            optionMenu -e -v "CH" Croissants_Assets;
            Croissants_assets_OM(2);	
            }
            else if($A_Type == "M")
            {
            optionMenu -e -v "MC" Croissants_Assets;
            Croissants_assets_OM(2);	
            }
            else if($A_Type == "P")
            {
            optionMenu -e -v "PR" Croissants_Assets;
            Croissants_assets_OM(2);	
            }
      break;        
      
      case 2 :      
            string $RN_Filter_Name = $array[0]+"_"+$array[1]+"_"+$array[2];
            textField -e -tx $RN_Filter_Name Croissants_Filter_Asset;
            Croissants_Filter_Assets(1);
            Croissants_assets_OM(3);      
      break;
          
          //string $ThisRN[] =`textScrollList -q -si RN_List`; 
          //string $current_ref=`referenceQuery -f $ThisRN[0]`;  

      }
}

global proc Croi_make_Rig()  
{
    string $G_Croi_Scenes_04=`textField -q -tx croissants_TokenJ`;
    string $PUBType_B=`optionMenu -q -v Croissants_PUBType_B`; 
    string $mill_Path_RIG =(`Croi_C_workspace`)+"/"+$G_Croi_Scenes_04+"/"+(`Croi_MOD_Root`)+"/"+(`Croi_MOD_Sub`)+"/"+(`Croi_MOD_Name`);
    string $Croi_MkRig =  $mill_Path_RIG +"/"+(`Croi_MOD_Name`)+"_RIG.0001"+$PUBType_B;

    if($PUBType_B == ".mb")
    {
      $exportType="mayaBinary";
      
      file -rn $Croi_MkRig; 
      file -f -save  -options "v=0;" -type $exportType;   
    }
    else if($PUBType_B == ".ma")
    {
      $exportType="mayaAscii";
      
      file -rn $Croi_MkRig; 
      file -f -save  -options "v=0;" -type $exportType;   
    }

    Croissants_Mod_OM(3);                
    confirmDialog -title "Confirm Window" -message "Victory!!" -button "OK" -defaultButton "OK";

}


global proc Croi_ThumbsMulti(int $case)
{
      switch($case)
      {
        case 1 :          
          window -e -w 960 -h 960  "Croi_Thumb_UI";
          columnLayout -e -w 960 -h 960 Croi_Thumb_col;
          iconTextButton -e -w 960 -h 960 -dcc "Croi_ThumbsMulti(2);" Croi_Thumb;     
          
          $croi_Postion2 =`window -q -tlc  Croissants`; 
          int $mag_w2 = $croi_Postion2[1] -800;
          int $mag_h2 = $croi_Postion2[0] +50;
          window -e -tlc $mag_h2 $mag_w2  Croi_Thumb_UI;              
        break;   


        case 2 :          
          window -e -w 256 -h 256  "Croi_Thumb_UI";
          columnLayout -e -w 256 -h 256 Croi_Thumb_col;
          iconTextButton -e -w 256 -h 256 -dcc "Croi_ThumbsMulti(1);" Croi_Thumb;     
          
          $croi_Postion3 =`window -q -tlc  Croissants`; 
          int $mag_w3 = $croi_Postion3[1] -400;
          int $mag_h3 = $croi_Postion3[0] +300;
          window -e -tlc $mag_h3 $mag_w3  Croi_Thumb_UI;               
        break; 


        case 3 :
          if(`window -q -ex "Croi_Thumb_UI"`)deleteUI("Croi_Thumb_UI");
          window -mnb false -rtf true -w 256 -mxb false -t "Thumbs" -h 256 -tb true -s false -tlb true -mb true "Croi_Thumb_UI";
          columnLayout -w 256 -h 256 Croi_Thumb_col;
          iconTextButton -st "iconOnly" -en true -w 256 -i "CacheOnly.ico" -h 256 -al "center"  -p "Croi_Thumb_col" -dcc "Croi_ThumbsMulti(1);" Croi_Thumb;
          showWindow "Croi_Thumb_UI";        
          
          $croi_Postion =`window -q -tlc  Croissants`; 
          int $mag_w = $croi_Postion[1] -400;
          int $mag_h = $croi_Postion[0] +300;
          window -e -tlc $mag_h $mag_w  Croi_Thumb_UI;  
            
        break;

        
        case 4 :
            if(`window -q -ex "Croi_Thumb_UI"`)deleteUI("Croi_Thumb_UI");
        break;

        
     }
          
}

global proc Croi_Thumbs(int $case)
{

string $G_Croi_Scenes_04=`textField -q -tx croissants_TokenJ`;

string $MIll_loc = (`Croi_C_workspace`) +"/" + $G_Croi_Scenes_04 + "/" + (`Croi_MOD_Root`) + "/" + (`Croi_MOD_Sub`) + "/";
string $MIll_stuff = $MIll_loc + (`Croi_MOD_Name`) + "/";
string $MIll_snapShot=$MIll_stuff + "_Thumbs_"+(`Croi_MOD_Name`) + ".jpg";

int $CT =`currentTime -q`;

    switch($case)
    {

        case 1 :
            Croi_Thumbs_HUD(1);
            playblast  -st $CT -et $CT -fmt image  -cc 1 -v 0 -fp 0 -p 100 -c "jpg" -qlt 100 -wh 960 960 -cf $MIll_snapShot ;
            Croi_Thumbs_HUD(2);
        break;

        
        case 2 :
            iconTextButton -e -i "CacheOnly.ico" Croi_Thumb;            
            iconTextButton -e -i $MIll_snapShot Croi_Thumb;        
        break;
 

    }

}  

global proc Croi_Thumbs_Assets(int $case)
{
string $G_Croi_Scenes_03=`textField -q -tx croissants_TokenI`;

string $Assets_loc = (`Croi_C_workspace`) +"/" + $G_Croi_Scenes_03 + "/" + (`Croi_Assets_Root`) + "/" + (`Croi_Assets_Sub`) + "/";
string $Assets_stuff = $Assets_loc + (`Croi_Assets_Name`) + "/";
string $Assets_snapShot=$Assets_stuff + "_Thumbs_"+(`Croi_Assets_Name`) + ".jpg";

int $CT =`currentTime -q`;

    switch($case)
    {

        case 1 :
            Croi_Thumbs_HUD(1);
            playblast  -st $CT -et $CT -fmt image  -cc 1 -v 0 -fp 0 -p 100 -c "jpg" -qlt 100 -wh 960 960 -cf $Assets_snapShot ;
            Croi_Thumbs_HUD(2);
        break;

        case 2 :
            iconTextButton -e -i "CacheOnly.ico" Croi_Thumb;            
