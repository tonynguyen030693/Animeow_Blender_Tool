global proc Croissants_REN_nGet()
{
$List =`ls -sl`;
string $preName =$List[0];
textField -e -tx $preName Rs_REN_Field;
}

global proc Croissants_REN_Reset()
{
intField -e -v 1 Rs_REN_nField;
textField -e -tx "" Rs_REN_Field;
}

global proc Croissants_REN()
{
	string $sel[]=`ls -sl`;
	for ($i=0; $i <size($sel); $i++)
	{
	select -r $sel[$i];Croissants_REN_LOOP();
	}
}

global proc Croissants_REN_LOOP()
{
$List =`ls -sl`;

int $Number = `intField  -q -v  Rs_REN_nField`;
$String = `textField -q -tx Rs_REN_Field`;

if($Number<100)
{
    if($Number<10)
    {
    $NewName = $String+"_"+"00"+$Number;    
    $nList =`rename $List $NewName`;    
        string $shapes[] = `listRelatives -shapes -path $nList`;
        for($each in $shapes) 
        {
            $NewNameS = $String+"_"+"00"+$Number+"Shape";    
        	rename $each $NewNameS;
        }
    }
    else
    {
    $NewName = $String+"_"+"0"+$Number;            
    $nList =`rename $List $NewName`;
        string $shapes[] = `listRelatives -shapes -path $nList`;
        for($each in $shapes) 
        {
            $NewNameS = $String+"_"+"0"+$Number+"Shape";    
        	rename $each $NewNameS;
        }    
    }    
}
else
{
    $NewName = $String+"_"+$Number; 
    $nList =`rename $List $NewName`;
        string $shapes[] = `listRelatives -shapes -path $nList`;
        for($each in $shapes) 
        {
            $NewNameS = $String+"_"+$Number+"Shape";    
        	rename $each $NewNameS;
        }    
}
  int $up = $Number + 1;
  intField -e -v $up Rs_REN_nField; 
}



global proc Croissants_PFixP(int $SelF)
{

	switch ( $SelF)
	{
		case 1 :
		    string $objs[] = `ls -sl`;
		    for($i=0;$i < size($objs); $i++)
		    {
		            string $old_Name = $objs[$i];
		            string $prefix = `textField -q -text Rs_REN_Field`;
		            $newName = $prefix + "_"+$old_Name;    
		            rename $objs[$i] $newName;
		    }
		break;

		case 2 :
		    string $objs_2[] = `ls -sl`;
		    for($i=0;$i < size($objs_2); $i++)
		    {
		            string $old_Name = $objs_2[$i];
		            string $prefix = `textField -q -text Rs_REN_Field`;
		            $newName = $old_Name + "_"+ $prefix;    
		            rename $objs_2[$i] $newName;
		    }
		break;


	}

}



