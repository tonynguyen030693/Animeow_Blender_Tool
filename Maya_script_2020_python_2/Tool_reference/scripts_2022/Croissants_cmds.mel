global proc VrayExportJobSetPath()
{
    string $DL_project_Root = `workspace -q -fn`;
    $DL_project_Root_token = stringToStringArray($DL_project_Root, "/");
    string $token01  = $DL_project_Root_token[0] + "\\" + $DL_project_Root_token[1]+ "\\" + $DL_project_Root_token[2];    
    string $token02 =`optionMenu -q -v Croissants_EP`;
    string $token03 =`optionMenu -q -v Croissants_CUT`;

    string $VrayexFilePath= $token01 + "\99_temp\\" + $token02 + "\\" + $token03;
    string $VrayexFilePath_File= $token01 + "\99_temp\\" + $token02 + "\\" + $token03 + "\\" + $token02 + "_" + $token03 + ".vrscene";
    sysFile -makeDir $VrayexFilePath;
    textFieldGrp -e -text $VrayexFilePath_File frw_vrayFilePath;
    //only Deadline Commmand
    optionMenuGrp -e -sl 3  frw_mayaJobType;
    checkBox -e -v 1 frw_submitVRayJob;
    UpdateJobType();
}


global proc Croissants_VRayTool(int $case)
{
    switch($case)
    {

      case 1 :
          select -hi;
          string $selected[] = `ls -sl`;
          string $filterSelect[] = `filterExpand -sm 12 $selected`;
          select -r $filterSelect;
          string $shapes[] = `listRelatives -shapes -path $filterSelect`;
            for($each in $shapes) 
            {
              vray addAttributesFromGroup $each vray_subdivision 1;
              vray addAttributesFromGroup $each vray_subquality 1;
            }      
      break;
      
      case 2 :
          select -hi;
          string $selected_2[] = `ls -sl`;
          string $filterSelect_2[] = `filterExpand -sm 12 $selected_2`;
          select -r $filterSelect_2;
          string $shapes_2[] = `listRelatives -shapes -path $filterSelect_2`;
            for($each in $shapes_2) 
            {
              setAttr  ($each+".vrayMaxSubdivs") 6;
              setAttr  ($each+".vrayEdgeLength") 1;
            }      
      break;


    }


}

