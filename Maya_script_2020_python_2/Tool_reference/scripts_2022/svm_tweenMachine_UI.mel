if (`objExists svm_tweenMachine_UI`) delete svm_tweenMachine_UI;
global proc svm_tweenMachine_UI()
{
    global int $svm_tweenMachine_sliderState;
	
    //if (`windowPref -exists WIN_svm_tweenMachine` == true) windowPref -r WIN_svm_tweenMachine;
    if (`window -q -ex WIN_svm_tweenMachine` == true) deleteUI -window WIN_svm_tweenMachine;
	window	-t "svm_tweenMachine"
    		-wh 242 84
    		-rtf false
            -maximizeButton false
            -menuBar true
            -menuBarVisible true
    		-s true
    		-bgc 0.25 0.25 0.25
    		WIN_svm_tweenMachine;
        
        menu    -l "Options"
                -tearOff true
                -parent WIN_svm_tweenMachine
