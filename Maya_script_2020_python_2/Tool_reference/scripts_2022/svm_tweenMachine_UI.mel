            menuItem    -l "Reset slider"
                        -c ("floatSlider -e -v 0.500 SLIDER_svm_tweenMachine; svm_tweenMachine_printVal(0.500);")
                        -parent MENU_svm_tweenMachine_options
                    	MENUITEM_svm_tweenMachine_resetSlider;

            menuItem    -l "Special tick color"
                        -checkBox false
                        -parent MENU_svm_tweenMachine_options
                    	MENUITEM_svm_tweenMachine_tickColor;

            menuItem    -d true
                        -dl "Operate on:"
                        -parent MENU_svm_tweenMachine_options
                    	MENUITEM_svm_tweenMachine_divOperateOn;

            menuItem    -l "Keys in graphEditor"
                        -checkBox true
                        -parent MENU_svm_tweenMachine_options
                    	MENUITEM_svm_tweenMachine_operateKeys;

